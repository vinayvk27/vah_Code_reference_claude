  """
  Helpers for tools to emit form specs.
  
  Tools call build_form_emit(form_spec) which returns a string in a special
  format. The chat_controller streaming filter recognizes this format and
  yields a {"type": "form", "form_spec": {...}} SSE event instead of a text chunk.
  """
  
  import json
  
  FORM_EMIT_PREFIX = "<<FORM>>"
  FORM_EMIT_SUFFIX = "<<ENDFORM>>"
  
  
  def build_form_emit(form_spec: dict) -> str:
      """
      Wrap a form_spec into the special string the streaming layer detects.
      Tools return this string; the streaming filter parses and emits as form event.
      """
      return f"{FORM_EMIT_PREFIX}{json.dumps(form_spec)}{FORM_EMIT_SUFFIX}"
  
  
  def extract_form_spec(text: str):
      """
      Find and extract form_spec from text if present. Returns dict or None.
      Also returns the remaining text after stripping the form block.
      """
      if FORM_EMIT_PREFIX not in text:
          return None, text
      
      start = text.find(FORM_EMIT_PREFIX)
      end = text.find(FORM_EMIT_SUFFIX, start)
      if end == -1:
          return None, text  # Incomplete — let it stream more
      
      json_str = text[start + len(FORM_EMIT_PREFIX):end]
      remaining = text[:start] + text[end + len(FORM_EMIT_SUFFIX):]
      
      try:
          form_spec = json.loads(json_str)
          return form_spec, remaining
      except json.JSONDecodeError:
          return None, text  # Malformed — pass through as text

