def creator_needs_file_node(state: MaterialRequisitionState) -> dict:
    """
    Terminal node: emitted when a creator tries to create an MRR
    without uploading an Excel file or providing inline structured
    data. Returns a friendly text message AND a form_widget marker
    (parsed by chat_controller into a separate SSE event).
    """
    print(f"[DIAG-MRR] creator_needs_file_node entered.", flush=True)
    form_json = get_mrr_form_widget_json()
    form_marker = "[[FORM_WIDGET:" + json.dumps(form_json) + "]]"
    msg = (
        "Sure, I can help you create a material requisition. "
        "Use the form below, or upload an Excel file.\n\n"
        + form_marker
    )
    return {
        "messages": [AIMessage(content=msg)],
        "execution_log": state.get("execution_log", []) + [
            "Emitted MRR form widget."
        ]
    }
```

## Controller Marker-Detection Code (chat_controller.py)

### Helper function (module-level):

```python
FORM_MARKER_RE = re.compile(r"\[\[FORM_WIDGET:(.*?)\]\]", re.DOTALL)


def _emit_with_form_widget(full_text: str):
    """Yields SSE event dicts: chunk before, form_widget, chunk after."""
    match = FORM_MARKER_RE.search(full_text)
    if not match:
        yield {"type": "chunk", "text": full_text}
        return
    pre = full_text[:match.start()]
    post = full_text[match.end():]
    raw_json = match.group(1)
    try:
        form_obj = json.loads(raw_json)
    except Exception as e:
        print(f"[FORM-WIDGET] JSON parse error: {e}", flush=True)
        yield {"type": "chunk", "text": full_text}
        return
    if pre.strip():
        yield {"type": "chunk", "text": pre}
    yield {"type": "form_widget", "form": form_obj}
    if post.strip():
        yield {"type": "chunk", "text": post}
```

