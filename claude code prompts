elif event_kind == "on_chain_end":
    node_name = event.get("name", "")
    output = event.get("data", {}).get("output", {})
    
    if node_name == "output_formatter":
        output_type = output.get("output_type")
        
        if output_type == "chart":
            chart_spec = output.get("chart_spec")
            if chart_spec:
                yield json.dumps({"type": "chart", "chart_spec": chart_spec})
        
        elif output_type == "table":
            table_data = output.get("table_data")
            if table_data:
                yield json.dumps({"type": "table", 
                                  "columns": table_data["columns"], 
                                  "rows": table_data["rows"]})
        
        elif output_type == "text":
            text = output.get("text_response", "")
            if text:
                yield json.dumps({"type": "chunk", "text": text})
