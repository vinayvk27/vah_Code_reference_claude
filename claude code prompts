"""
Oracle ERP Query Helpers
=========================
Parameterized queries against the Oracle ERP database.
Each function gracefully degrades (returns None) on errors.
"""

import logging
from typing import Optional

from sqlalchemy import text

from app.dao.oracle import get_oracle_session

logger = logging.getLogger(__name__)


def get_item_availability(item_id: int) -> Optional[dict]:
    session = None
    try:
        session = get_oracle_session()
        row = session.execute(
            text("""
                SELECT i.ITEMID as item_id,
                       i.NAME as name,
                       q.ONHANDQUANTITY as onhand_quantity
                FROM SCMQUANTITYONHAND q
                JOIN scmitems i ON i.ITEMID = q.ITEMID
                WHERE q.ITEMID = :item_id
                FETCH FIRST 1 ROWS ONLY
            """),
            {"item_id": item_id},
        ).first()
        if row:
            return {"item_id": row.item_id, "name": row.name, "onhand_quantity": row.onhand_quantity}
        return None
    except Exception as e:
        logger.warning("get_item_availability failed for item_id=%s: %s", item_id, e)
        return None
    finally:
        if session:
            session.close()


def get_item_lpp(item_id: int, warehouse_id: int = 1) -> Optional[dict]:
    session = None
    try:
        session = get_oracle_session()
        row = session.execute(text("""
            SELECT B.ITEMID as item_id, C.NAME as name,
                   (B.PRICE * A.CONVERSIONRATE) as lpp_rate
            FROM SCMUNITOFMEASURES UOM, POHEADERS A, POLINES B,
                 SCMITEMS C, SCMCURRENCIES D, SCMSUPPLIERS SUP
            WHERE UOM.UNITOFMEASUREID = B.UNITOFMEASUREID
              AND SUP.SUPPLIERID = A.SUPPLIERID
              AND A.POHEADERID = B.POHEADERID
              AND B.STATUS = 'A'
              AND B.WAREHOUSEID = :wh
              AND C.WAREHOUSEID = B.WAREHOUSEID
              AND A.CURRENCYID = D.CURRENCYID
              AND B.ITEMID = C.ITEMID
              AND B.ITEMID = :item_id
              AND A.POHEADERID = (
                  SELECT MAX(A2.POHEADERID)
                  FROM POHEADERS A2, POLINES B2
                  WHERE A2.POHEADERID = B2.POHEADERID
                    AND B2.STATUS = 'A'
                    AND B2.WAREHOUSEID = :wh
                    AND B2.ITEMID = :item_id
              )
              AND ROWNUM = 1
        """), {"item_id": item_id, "wh": warehouse_id}).first()
        if row:
            return {"item_id": row.item_id, "name": row.name, "lpp_rate": float(row.lpp_rate or 0)}
        return None
    except Exception as e:
        logger.warning("get_item_lpp failed for item_id=%s: %s", item_id, e)
        return None
    finally:
        if session:
            session.close()


