STEP 1 — Add helpers (top of nodes.py, near _parse_form_submit_message)

    from typing import Optional
    from sqlalchemy import text

    def _lookup_project(db_session, project_code: str) -> Optional[dict]:
        \"""Resolve project code (e.g., 'YEA2719') to:
        {'project_id': int, 'description': str}
        Returns None if not found.\"""
        row = db_session.execute(text(\"""
            SELECT PROJECTID, DESCRIPTION
            FROM posproject
            WHERE PROJECTNUMBER = :code
            LIMIT 1
        \"""), {"code": project_code}).mappings().first()
        if not row:
            return None
        return {
            "project_id": int(row["PROJECTID"]),
            "description": row["DESCRIPTION"] or ""
        }

    def _lookup_latest_phase(db_session, project_id: int) -> Optional[int]:
        \"""Return the PROJECTPHASEID of the most recent phase for a
        project. Today projects have 1 phase, but ORDER BY ... DESC
        future-proofs for multi-phase.\"""
        row = db_session.execute(text(\"""
            SELECT PROJECTPHASEID
            FROM posprojectphases
            WHERE PROJECTID = :pid
            ORDER BY PROJECTPHASEID DESC
            LIMIT 1
        \"""), {"pid": project_id}).first()
        return int(row.PROJECTPHASEID) if row else None

