Define fake in-memory tools (no real DB, same as investigate script):

from langchain_core.tools import tool
from typing import Optional

@tool
def create_task(resource_id: int, project_id: str, product_id: str,
                task_idx: int, activity_idx: int,
                start_date: str, end_date: str, plan_hrs: float) -> str:
    """Create a task assignment. Requires all 8 fields."""
    return (f"[TOOL EXECUTED] Task created: employee={resource_id}, "
            f"project={project_id}, product={product_id}, "
            f"task_idx={task_idx}, activity_idx={activity_idx}, "
            f"start={start_date}, end={end_date}, hours={plan_hrs}")

@tool
def list_my_tasks(resource_id: int) -> str:
    """List tasks assigned to an employee."""
    return (f"[TOOL EXECUTED] Tasks for employee {resource_id}: "
            f"Task#1 (project=100, 8hrs), Task#2 (project=200, 4hrs)")

@tool
def log_hours(worklog_idx: int, hours: float,
              task_date: str, remarks: str) -> str:
    """Log hours against a task worklog."""
    return (f"[TOOL EXECUTED] Logged {hours}hrs on worklog {worklog_idx} "
            f"for {task_date}. Remark: {remarks}")

@tool
def list_pending_worklogs() -> str:
    """List worklogs pending approval."""
    return ("[TOOL EXECUTED] Pending worklogs: "
            "Worklog#5 (emp=3010, 8hrs, 2026-05-26), "
            "Worklog#6 (emp=2633, 6hrs, 2026-05-27)")

@tool
def approve_worklog(worklog_id: int, decision: str) -> str:
    """Approve or reject a worklog. decision must be APPROVED or REJECTED."""
    return f"[TOOL EXECUTED] Worklog {worklog_id} -> {decision}"

PERSONA_TOOLS = {
    "creator":  [create_task, list_my_tasks],
    "reviewer": [list_my_tasks, log_hours],
    "approver": [list_pending_worklogs, approve_worklog],
}

