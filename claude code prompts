#ORACLE DB Querys to get the data

#To get the Availabe quantity of the line Item
select a.itemid,b.name,a.onhandquantity from SCMQUANTITYONHAND a, scmitems b where a.itemid = b.itemid and a.onhandquantity <> 0 ;

#To get LPP cost of the line item
SELECT Distinct max (A.POHEADERID) , B.ITEMID,c.name, (B.PRICE *A.CONVERSIONRATE) AS "LPP RATE"  FROM SCMUNITOFMEASURES UOM,POHEADERS A, POLINES B,SCMITEMS C,SCMCURRENCIES D,SCMSUPPLIERS SUP WHERE  UOM.UNITOFMEASUREID = B.UNITOFMEASUREID AND SUP.SUPPLIERID = A.SUPPLIERID AND A.POHEADERID = B.POHEADERID AND B.STATUS = 'A'  AND B.WAREHOUSEID = 1 AND C.WAREHOUSEID = B.WAREHOUSEID AND A.CURRENCYID=D.CURRENCYID AND B.ITEMID =C.ITEMID and a.POHEADERID = (SELECT MAX(A.POHEADERID) FROM POHEADERS A, POLINES B WHERE A.POHEADERID = B.POHEADERID AND B.STATUS = 'A' and B.WAREHOUSEID = 1 AND B.ITEMID =C.ITEMID) group by B.ITEMID,c.name,(B.PRICE *A.CONVERSIONRATE) , C.ITEMUNITPRICE order by itemid desc ;


