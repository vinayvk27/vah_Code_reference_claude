Mirror rms_workflow/agents.py pattern. Define HRMSAgentConfig class and 3 agent configs:

  class HRMSAgentConfig:
      def __init__(self, name, persona, allowed_tools, description):
          self.name = name
          self.persona = persona
          self.allowed_tools = allowed_tools
          self.description = description
  
  HRMS_CREATOR = HRMSAgentConfig(
      name="HRMS_CREATOR",
      persona="creator",
      allowed_tools=["tool_create_leave_type", "tool_create_payslip"],
      description="Defines leave types and generates payslips."
  )
  
  HRMS_REVIEWER = HRMSAgentConfig(
      name="HRMS_REVIEWER",
      persona="reviewer",
      allowed_tools=[
          "tool_list_my_leave_balance",
          "tool_request_leave",
          "tool_my_payslip",
          "tool_list_my_leave_requests",
      ],
      description="Submits leave requests and views own payslip/balance."
  )
  
  HRMS_APPROVER = HRMSAgentConfig(
      name="HRMS_APPROVER",
      persona="approver",
      allowed_tools=[
          "tool_list_pending_leaves",
          "tool_decide_leave",
          "tool_view_any_payslip",
      ],
      description="Reviews and approves/rejects leave requests; views team payslips."
  )
  
  AGENT_REGISTRY = {
      "creator": HRMS_CREATOR,
      "reviewer": HRMS_REVIEWER,
      "approver": HRMS_APPROVER,
  }
  
  def get_agent_config(persona: str) -> HRMSAgentConfig:
      return AGENT_REGISTRY.get(persona)

