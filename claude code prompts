import { useState, useRef, useCallback, useEffect } from 'react';
import {
  Plus, Trash2, AlertCircle, Loader2,
  ChevronDown, CheckCircle2, Minimize2, Maximize2
} from 'lucide-react';

// ─── ItemAutocompleteCell ────────────────────────────────────────────────────
// Extracted as a proper component so useRef is called at the top level,
// not inside a .map() callback. This is the fix for the blank-page crash.
function ItemAutocompleteCell({
  value, tableName, rowIndex, col, isSubmitting,
  onItemChange, cellError
}) {
  const inputRef = useRef(null);
  const timerRef = useRef(null);
  const [query, setQuery] = useState('');
  const [suggestions, setSuggestions] = useState([]);
  const [loading, setLoading] = useState(false);
  const [isOpen, setIsOpen] = useState(false);
  const [dropdownPos, setDropdownPos] = useState(null);

  useEffect(() => {
    if (!query || query.length < 2) { setSuggestions([]); return; }
    setLoading(true);
    const controller = new AbortController();
    fetch(`/api/v1/mrr/search/items?q=${encodeURIComponent(query)}`, {
      headers: { Authorization: `Bearer ${localStorage.getItem('access_token')}` },
      signal: controller.signal,
    })
      .then(r => r.json())
      .then(data => setSuggestions(data.status === 'success' ? data.data : []))
      .catch(() => {})
      .finally(() => setLoading(false));
    return () => controller.abort();
  }, [query]);

  const handleChange = (e) => {
    const val = e.target.value;
    onItemChange(tableName, rowIndex, col.name, val);
    clearTimeout(timerRef.current);
    timerRef.current = setTimeout(() => setQuery(val), 300);
  };

  const handleFocus = (e) => {
    setIsOpen(true);
    const rect = e.target.getBoundingClientRect();
    setDropdownPos({
      top: rect.bottom + window.scrollY + 4,
      left: rect.left + window.scrollX,
      width: Math.max(rect.width, 240),
    });
  };

  const handleBlur = () => setTimeout(() => setIsOpen(false), 150);

  const handleSelect = (suggestion) => {
    onItemChange(tableName, rowIndex, col.name, suggestion.item_code || suggestion.label);
    setIsOpen(false);
    setSuggestions([]);
    setQuery('');
  };

  const cellInputBase = [
    'w-full px-2 py-1 text-[13px] font-medium rounded-lg border',
    'bg-white dark:bg-slate-800/80',
    'text-slate-800 dark:text-slate-200',
    'border-slate-200 dark:border-slate-700',
    'outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/20',
    'transition-colors',
    cellError ? 'border-red-500 ring-1 ring-red-500/20' : '',
  ].join(' ');

  return (
    <td className="px-2 py-1.5 align-top" style={{ position: 'relative' }}>
      <div ref={inputRef}>
        <div className="relative">
          <input
            type="text"
            value={value || ''}
            onChange={handleChange}
            onFocus={handleFocus}
            onBlur={handleBlur}
            onKeyDown={e => e.key === 'Escape' && setIsOpen(false)}
            placeholder={col.placeholder || ''}
            required={col.required}
            disabled={isSubmitting}
            autoComplete="off"
            className={cellInputBase}
          />
          <div className="absolute right-1.5 top-1/2 -translate-y-1/2 pointer-events-none">
            {loading
              ? <Loader2 size={12} className="animate-spin text-slate-400" />
              : suggestions.length > 0 && isOpen
                ? <ChevronDown size={10} className="text-slate-400" />
                : null}
          </div>
        </div>

        {isOpen && suggestions.length > 0 && dropdownPos && (
          <ul
            style={{ position: 'fixed', top: dropdownPos.top, left: dropdownPos.left, width: dropdownPos.width, zIndex: 9999 }}
            className="rounded-xl shadow-xl overflow-auto max-h-48
              bg-white dark:bg-slate-800
              border border-slate-200 dark:border-slate-700
              ring-1 ring-black/5 dark:ring-white/5"
          >
            {suggestions.map(s => (
              <li
                key={s.value || s.item_code}
                onMouseDown={e => { e.preventDefault(); handleSelect(s); }}
                className="px-3 py-2 cursor-pointer transition-colors
                  text-[13px] text-slate-700 dark:text-slate-200
                  hover:bg-blue-50 dark:hover:bg-blue-500/10
                  hover:text-blue-700 dark:hover:text-blue-300
                  first:rounded-t-xl last:rounded-b-xl"
              >
                <div className="font-semibold">{s.label || s.display_label}</div>
                {(s.description || (s.item_name && s.item_name !== s.display_label)) && (
                  <div className="text-[11px] text-slate-500 dark:text-slate-400 truncate">
                    {s.description || s.item_name}
                  </div>
                )}
              </li>
            ))}
          </ul>
        )}

        {isOpen && !loading && suggestions.length === 0 && query.length >= 2 && dropdownPos && (
          <div
            style={{ position: 'fixed', top: dropdownPos.top, left: dropdownPos.left, width: dropdownPos.width, zIndex: 9999 }}
            className="px-3 py-2.5 rounded-xl shadow-xl text-[12px]
              bg-white dark:bg-slate-800
              border border-slate-200 dark:border-slate-700
              text-slate-500 dark:text-slate-400"
          >
            No results found
          </div>
        )}
      </div>

      {cellError && (
        <p className="mt-0.5 text-[11px] text-red-400 flex items-center gap-1 truncate">
          <AlertCircle size={10} className="shrink-0" />
          <span>{cellError}</span>
        </p>
      )}
    </td>
  );
}

// ─── Main FormRenderer ───────────────────────────────────────────────────────
export default function FormRenderer({
  formSpec,
  formErrors = null,
  isSubmitting = false,
  onSubmit,
  onCancel,
}) {
  // ── State ──────────────────────────────────────────────────────────────────
  const [formData, setFormData] = useState(() => {
    const initial = {};
    formSpec.fields?.forEach(f => {
      if (f.type === 'items_table') {
        const emptyRow = {};
        f.columns.forEach(c => { emptyRow[c.name] = ''; });
        initial[f.name] = Array.from({ length: f.min_rows || 1 }, () => ({ ...emptyRow }));
      } else if (f.type === 'radio') {
        initial[f.name] = f.default ?? '';
      } else if (f.type === 'checkbox') {
        initial[f.name] = false;
      } else {
        initial[f.name] = f.default ?? '';
      }
    });
    return initial;
  });

  const [isExpanded, setIsExpanded] = useState(false);

  // Project autocomplete state
  const projectInputRef = useRef(null);
  const projectTimerRef = useRef(null);
  const [projectQuery, setProjectQuery] = useState('');
  const [projectSuggestions, setProjectSuggestions] = useState([]);
  const [projectLoading, setProjectLoading] = useState(false);
  const [isProjectOpen, setIsProjectOpen] = useState(false);

  // Close project dropdown on outside click
  useEffect(() => {
    const handler = e => {
      if (projectInputRef.current && !projectInputRef.current.contains(e.target)) {
        setIsProjectOpen(false);
      }
    };
    document.addEventListener('mousedown', handler);
    return () => document.removeEventListener('mousedown', handler);
  }, []);

  // Project search fetch
  useEffect(() => {
    if (!projectQuery || projectQuery.length < 2) { setProjectSuggestions([]); return; }
    setProjectLoading(true);
    const controller = new AbortController();
    fetch(`/api/v1/mrr/search/projects?q=${encodeURIComponent(projectQuery)}`, {
      headers: { Authorization: `Bearer ${localStorage.getItem('access_token')}` },
      signal: controller.signal,
    })
      .then(r => r.json())
      .then(data => setProjectSuggestions(data.status === 'success' ? data.data : []))
      .catch(() => {})
      .finally(() => setProjectLoading(false));
    return () => controller.abort();
  }, [projectQuery]);

  // ── Handlers ───────────────────────────────────────────────────────────────
  const handleFieldChange = (name, value) =>
    setFormData(prev => ({ ...prev, [name]: value }));

  const handleItemChange = useCallback((tableName, rowIndex, colName, value) => {
    setFormData(prev => {
      const updated = [...prev[tableName]];
      updated[rowIndex] = { ...updated[rowIndex], [colName]: value };
      return { ...prev, [tableName]: updated };
    });
  }, []);

  const addRow = (tableName, columns) => {
    const newRow = {};
    columns.forEach(c => { newRow[c.name] = ''; });
    setFormData(prev => ({ ...prev, [tableName]: [...prev[tableName], newRow] }));
  };

  const removeRow = (tableName, rowIndex) =>
    setFormData(prev => ({
      ...prev,
      [tableName]: prev[tableName].filter((_, i) => i !== rowIndex),
    }));

  const handleProjectInputChange = (e) => {
    const val = e.target.value;
    setFormData(prev => ({ ...prev, project_id: val }));
    clearTimeout(projectTimerRef.current);
    projectTimerRef.current = setTimeout(() => setProjectQuery(val), 300);
  };

  const selectProject = (project) => {
    setFormData(prev => ({ ...prev, project_id: project.project_id || project.value }));
    setIsProjectOpen(false);
    setProjectSuggestions([]);
    setProjectQuery('');
  };

  const handleSubmit = (e) => {
    e.preventDefault();
    const cleanedData = JSON.parse(JSON.stringify(formData));
    formSpec.fields?.forEach(field => {
      if (field.type === 'items_table') {
        cleanedData[field.name] = cleanedData[field.name].map(row => {
          const cleanRow = { ...row };
          field.columns.forEach(col => {
            if (col.conditional) {
              const parentVal = formData[col.conditional.field];
              if (parentVal !== col.conditional.value) delete cleanRow[col.name];
            }
          });
          return cleanRow;
        });
      }
    });
    onSubmit(cleanedData, formSpec.form_id);
  };

  // ── Helpers ────────────────────────────────────────────────────────────────
  const isColVisible = col =>
    !col.conditional || formData[col.conditional.field] === col.conditional.value;

  const getError = path => formErrors?.[path] || null;

  // ── Style constants ────────────────────────────────────────────────────────
  const sz = isExpanded ? {
    p: 'p-5',
    gap: 'gap-4',
    input: 'text-sm py-2.5',
    label: 'text-xs mb-1.5',
    title: 'text-base',
  } : {
    p: 'p-4',
    gap: 'gap-3',
    input: 'text-[13px] py-2',
    label: 'text-[11px] mb-1',
    title: 'text-sm',
  };

  const inputBase = [
