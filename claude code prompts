## NEW erp_approver_agent_node (full)

```python
def erp_approver_agent_node(state: MaterialRequisitionState) -> dict:
    """Fetches pending requests for ERP approval (ERP HOD).

    SQL column fixed: TOTALCOST → TOTAL_COST.
    RowMapping attribute access → dict-style access.
    """
    emp_no = state.get("emp_no", "")

    from app.workflows.material_workflow.approvers import is_erp_approver
    if not is_erp_approver(emp_no):
        return {
            "messages": [AIMessage(content="ERP approval is restricted to the ERP HOD. Please contact your administrator if you believe this is an error.")],
            "execution_log": state.get("execution_log", []) + ["Non-approver blocked from ERP approval"]
        }

    db = SessionLocal()
    try:
        query = text("""
            SELECT MATREQUISITIONID, MATREQUISITIONNO, REQUESTORID, REQUISITIONDATE,
                   TOTAL_COST, APPROVAL_STATUS, ERP_APPROVAL_STATUS, STATUS
            FROM mrr_matrequisitionheader
            WHERE APPROVAL_STATUS = 'APPROVED'
              AND (ERP_APPROVAL_STATUS IS NULL OR ERP_APPROVAL_STATUS = 'PENDING')
            ORDER BY REQUISITIONDATE ASC
        """)
        results = db.execute(query).mappings().all()

        if not results:
            return {"messages": [AIMessage(content="You have no pending ERP approvals at this time.")]}

        response_text = "### Pending ERP Approvals\n\n"
        response_text += "| Req ID | MRR No | Requestor | Total Cost | Status | Date |\n"
        response_text += "|---|---|---|---|---|---|\n"

        for r in results:
            date_str = r['REQUISITIONDATE'].strftime('%Y-%m-%d') if r['REQUISITIONDATE'] else 'N/A'
            response_text += f"| {r['MATREQUISITIONID']} | {r['MATREQUISITIONNO']} | {r['REQUESTORID']} | \u20b9{r['TOTAL_COST']} | {r['ERP_APPROVAL_STATUS'] or 'PENDING'} | {date_str} |\n"

        response_text += "\n*To approve a request, tell me: 'Approve requisition MRR/<id>/26-27'*"

        return {"messages": [AIMessage(content=response_text)]}

    except Exception as e:
        return {"messages": [AIMessage(content=f"Error fetching pending requests: {str(e)}")]}
    finally:
        db.close()
```

### Key changes:
- `TOTALCOST` → `TOTAL_COST` in SQL SELECT
- RowMapping attribute access (`r.MATREQUISITIONID`, `r.TOTALCOST`, `r.ERP_APPROVAL_STATUS`) → dict-style
- MRR year suffix `25-26` → `26-27`
- Added docstring
- No core logic changes

