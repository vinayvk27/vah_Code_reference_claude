async def sse_generator_with_orchestrator(
    db: Session,
    current_user: dict,
    raw_token: str,
    request_data: dict
) -> AsyncGenerator[str, None]:
    try:
        async for chunk in ChatController.stream_chat_with_orchestrator(
            db, current_user, raw_token, request_data
        ):
            yield f"data: {chunk}\n\n"
        yield "data: [DONE]\n\n"
    except PermissionError as e:
        yield f"data: {json.dumps({'error': str(e)})}\n\n"
        yield "data: [DONE]\n\n"
    except Exception as e:
        yield f"data: {json.dumps({'error': f'Server error: {str(e)}'})}\n\n"
        yield "data: [DONE]\n\n"


@router.post(
    "/stream",
    summary="Stream chat messages from the agent"
)
async def stream_chat_message(
    request: ChatStreamRequest,
    db: Session = Depends(get_db),
    current_user: CurrentUser = Depends(get_current_user),
    raw_token: str = Depends(oauth2_scheme),
):
    request_data = request.model_dump()

    # Reject old-shape requests containing "collection_name"
    if "collection_name" in request_data:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="Field 'collection_name' is deprecated. Use 'module_name' instead. The chat request shape changed in Task 3 — see the Frontend Migration Spec for details."
        )

    # Gate 1: module-level permission check
    module_name = request.module_name
    module_id = AuthController.get_module_id_by_name(module_name, db)
    if module_id is None:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail=f"Unknown module: {module_name}"
        )
    if not AuthController.check_module_access(
        current_user.emp_no,
        current_user.group_idx,
        current_user.role_ids,
        module_id,
        db
    ):
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail=f"You do not have access to module '{module_name}'."
        )

    return StreamingResponse(
        sse_generator_with_orchestrator(db, current_user.model_dump(), raw_token, request_data),
        media_type="text/event-stream",
    )


