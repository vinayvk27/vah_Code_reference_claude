  """
  Form Spec Schema
  ================
  The shape of form_spec JSON that tools emit and frontend renders.
  
  EXAMPLE:
    {
      "version": 1,
      "form_id": "hrms_apply_leave",
      "title": "Apply for Leave",
      "submit_label": "Submit Request",
      "cancel_label": "Cancel",
      "description": "Optional helper text below title",
      "fields": [
        {
          "name": "leave_type_id",
          "label": "Leave Type",
          "type": "select",
          "required": true,
          "options": [
            {"value": 1, "label": "Casual Leave (10 left)"},
            {"value": 2, "label": "Sick Leave (8 left)"}
          ],
          "default": 1
        },
        {
          "name": "from_date",
          "label": "From Date",
          "type": "date",
          "required": true,
          "default": "2026-06-15"
        },
        {
          "name": "reason",
          "label": "Reason",
          "type": "textarea",
          "required": true,
          "max_length": 500,
          "placeholder": "Brief explanation"
        }
      ]
    }
  
  Supported field types:
    - text:      single-line string
    - textarea:  multi-line string
    - number:    integer or float
    - date:      YYYY-MM-DD
    - select:    dropdown from options[]
    - checkbox:  boolean
  
  Common field attributes:
    - name (required):       field key sent back in submission
    - label (required):      display label
    - type (required):       one of above
    - required (bool):       must be filled
    - default (any):         pre-filled value
    - placeholder (str):     hint text inside empty input
    - help_text (str):       helper text below the field
    - min_length / max_length:  string length constraints
    - min / max:             numeric/date constraints
    - options (for select):  [{"value":..., "label":...}]
  """
  
  from typing import Any, Dict, List, Optional
  
  
  def validate_form_data(form_spec: dict, form_data: dict) -> Optional[str]:
      """
      Server-side validation of form submission against its spec.
      Returns None if valid, or a string error message describing the first failure.
      
      Validates: required fields, type basics, min/max where applicable.
      """
      fields = form_spec.get("fields", [])
      
      for field in fields:
          name = field.get("name")
          if not name:
              continue
          
          required = field.get("required", False)
          value = form_data.get(name)
          
          # Required check
          if required and (value is None or value == ""):
              return f"Field '{field.get('label', name)}' is required."
          
          # Skip remaining checks if no value provided (and not required)
          if value is None or value == "":
              continue
          
          ftype = field.get("type", "text")
          
          # Length constraints (text, textarea)
          if ftype in ("text", "textarea"):
              if not isinstance(value, str):
                  return f"Field '{name}' must be a string."
              ml = field.get("max_length")
              mn = field.get("min_length")
              if ml is not None and len(value) > ml:
                  return f"Field '{name}' exceeds max length of {ml}."
              if mn is not None and len(value) < mn:
                  return f"Field '{name}' below min length of {mn}."
          
          # Numeric constraints
          if ftype == "number":
              try:
                  num_val = float(value)
              except (TypeError, ValueError):
                  return f"Field '{name}' must be a number."
              mn = field.get("min")
              mx = field.get("max")
              if mn is not None and num_val < mn:
                  return f"Field '{name}' below min {mn}."
              if mx is not None and num_val > mx:
                  return f"Field '{name}' exceeds max {mx}."
          
          # Date format
          if ftype == "date":
              import re
              if not isinstance(value, str) or not re.match(r'^\d{4}-\d{2}-\d{2}$', value):
                  return f"Field '{name}' must be in YYYY-MM-DD format."
          
          # Select option validity
          if ftype == "select":
              valid_values = [opt.get("value") for opt in field.get("options", [])]
              # Match value (note: types may differ — compare as strings)
              if str(value) not in [str(v) for v in valid_values]:
                  return f"Field '{name}' has invalid option."
      
      return None  # all good

