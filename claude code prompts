def extract_json_safely(raw_text: str) -> str:
    """Safely extracts JSON from a string, handling markdown blocks without breaking quotes."""
    text = raw_text.strip()
    if "```" in text:
        parts = text.split("```")
        if len(parts) >= 3:
            extracted = parts[1].strip()
            if extracted.lower().startswith("json"):
                extracted = extracted[4:].strip()
            return extracted
    return text

