## How to Implement It Cleanly

Your AI suggested upgrading the intent classifier to also determine data scope. That's right. But instead of keeping `scope_guard_node` as a separate node with its own LLM call, **collapse it into the intent classifier in one LLM call.** This is cleaner, faster, and removes a node from the graph.

Here's exactly what to change:

### 1. Remove `scope_guard_node` from `nodes.py` and `graph.py`

Delete the function and its wiring entirely. The scope detection moves into `analytics_intent_classifier_node`.

### 2. Update `analytics_intent_classifier_node`

Replace the current single-classification prompt with a combined prompt that returns both intent AND scope:

```python
def analytics_intent_classifier_node(state: AnalyticsState) -> AnalyticsState:
    print(f"[DIAG-ANALYTICS] intent_classifier_node entered.", flush=True)
    
    user_question = _get_last_user_message(state)
    persona = state.get("selected_agent_role", "reviewer")
    collection = state.get("selected_collection", "")
    emp_id = state.get("user_id", "")

    prompt = f"""You are a routing classifier for an enterprise analytics system.
Analyze this question from an employee and classify it on TWO dimensions.

Employee persona: {persona}
Employee ID: {emp_id}
User question: "{user_question}"

DIMENSION 1 — INTENT (what kind of answer is needed):
- SQL_DATA: needs numbers, counts, aggregations, charts, or tables from the database
- SQL_INSIGHT: needs trend analysis, explanation, or written summary derived from data
- RAG: needs company policy, procedures, or static knowledge not in the database
- DENY: is a write/delete/harmful operation, or asks for something completely unrelated

DIMENSION 2 — SCOPE (whose data is being requested):
- PERSONAL: the question is about the employee themselves only
  Examples: "my hours", "how many tasks did I complete", "show my leave balance"
- GROUP: the question is about other people, a team, all employees, or the whole organization
  Examples: "all employees", "the team", "everyone", "each resource", "other people", 
            "compare across employees", "total company hours", "each and every worker"

Return ONLY a valid JSON object. No explanation, no markdown:
{{"intent": "SQL_DATA", "scope": "PERSONAL"}}"""

    try:
        llm = get_llm_non_streaming()
        response = llm.invoke([HumanMessage(content=prompt)])
        raw = (response.content or "").strip()
        
        # Strip markdown if LLM wraps it
        raw = re.sub(r'^```json\s*', '', raw, flags=re.IGNORECASE)
        raw = re.sub(r'^```\s*', '', raw)
        raw = re.sub(r'\s*```$', '', raw)
        
        classification = json.loads(raw.strip())
        intent = classification.get("intent", "SQL_DATA").upper()
        scope = classification.get("scope", "PERSONAL").upper()
        
        print(f"[DIAG-ANALYTICS] classifier -> intent={intent}, scope={scope}", flush=True)
        
    except (json.JSONDecodeError, Exception) as e:
        print(f"[DIAG-ANALYTICS] ❌ Classifier error: {e}. Raw: '{raw}'", flush=True)
        intent = "SQL_DATA"
        scope = "PERSONAL"

    # Scope enforcement: check if this persona has self-restriction
    filters = COLLECTION_TABLE_MAP.get(collection, {}).get(
        "persona_filters", {}
    ).get(persona, {})
    has_self_restriction = any(f is not None for f in filters.values())

    if scope == "GROUP" and has_self_restriction:
        # User is asking for group data but only has personal access
        state["has_permission"] = False
        state["denial_message"] = (
            f"You can only view your own data (employee {emp_id}). "
            f"You asked about data across multiple employees or the whole team, "
            f"which requires approver access. "
            f"Try asking: 'Show MY hours logged this month' or 'What are MY pending tasks?'"
        )
        state["intent_type"] = "DENY"
        print(f"[DIAG-ANALYTICS] ❌ BLOCKED — group scope with restricted persona", flush=True)
    else:
        state["intent_type"] = intent

    return state
```

### 3. Update `graph.py` — Remove scope_guard, fix wiring

```python
def build_analytics_graph():
    g = StateGraph(AnalyticsState)

    # Nodes — no scope_guard anymore
    g.add_node("permission_check", analytics_permission_check_node)
    g.add_node("permission_blocked", analytics_permission_blocked_node)
    g.add_node("intent_classifier", analytics_intent_classifier_node)
    g.add_node("sql_generator", analytics_sql_generator_node)
    g.add_node("sql_validator", analytics_sql_validator_node)
    g.add_node("sql_executor", analytics_sql_executor_node)
    g.add_node("output_formatter", analytics_output_formatter_node)
    g.add_node("error_handler", analytics_error_node)

    g.set_entry_point("permission_check")

    # permission_check → intent_classifier (no scope_guard in between)
    g.add_conditional_edges("permission_check", permission_router, {
        "proceed": "intent_classifier",
        "blocked": "permission_blocked",
    })

    # intent_classifier → routes (DENY now handled inside classifier)
    g.add_conditional_edges("intent_classifier", intent_router, {
        "SQL_DATA": "sql_generator",
        "SQL_INSIGHT": "sql_generator",
        "RAG": "output_formatter",
        "DENY": "permission_blocked",
        "ERROR": "error_handler",
    })

    g.add_edge("sql_generator", "sql_validator")

    g.add_conditional_edges("sql_validator", validation_router, {
        "valid": "sql_executor",
        "retry": "sql_generator",
        "error": "error_handler",
    })

    g.add_conditional_edges("sql_executor", execution_router, {
        "success": "output_formatter",
        "error": "error_handler",
    })

    g.add_edge("output_formatter", END)
    g.add_edge("permission_blocked", END)
    g.add_edge("error_handler", END)

    return g.compile()
```

### 4. Update `intent_router` to handle DENY from classifier

Your current `intent_router` function only covered `SQL_DATA/SQL_INSIGHT/RAG/DENY/ERROR`. It already has DENY — but the classifier was previously not setting it. Now it will, so `intent_router` handles it correctly without changes.

```python
def intent_router(state: AnalyticsState) -> Literal["SQL_DATA", "SQL_INSIGHT", "RAG", "DENY", "ERROR"]:
    # DENY now comes from two places: the classifier's explicit DENY, 
    # AND from scope enforcement inside the classifier
    return state.get("intent_type", "SQL_DATA")
```

