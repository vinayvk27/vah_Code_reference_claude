def _parse_worklog_approval_command(message: str) -> dict:
    """
    Parse an approve/reject command for a worklog.
    Returns {'action': 'approve'|'reject'|'list', 'worklog_id': int|None}.
    """
    import re
    msg = (message or "").lower().strip()

    # "approve worklog 5", "approve 5", "reject worklog 3", "reject 3"
    m = re.search(r'\b(approve|reject)\b(?:\s+worklog)?\s+(\d+)', msg)
    if m:
        verb = m.group(1)
        wl_id = int(m.group(2))
        return {"action": verb, "worklog_id": wl_id}

    return {"action": "list", "worklog_id": None}

Note: bare "approve" / "reject" with NO id falls through to "list"
(we will NOT guess a worklog). If the user typed an approve/reject
verb but no id, we should tell them to specify one — handle that
explicitly (see node logic).

