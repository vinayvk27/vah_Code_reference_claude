def _get_user_context(user_id: str, user_dept: str, persona: str) -> dict:
    """Build user context dict for tool calls."""
    return {
        "sub": user_id,
        "user_id": user_id,
        "persona": persona,
        "dept": user_dept
    }


def _get_user_grade(user_id: str) -> str | None:
    """Fetch user's grade from Resource table."""
    db_snap = SessionLocal()
    try:
        resource = db_snap.query(Resource).filter(Resource.Emp_no == user_id).first()
        return resource.Grade if resource else None
    finally:
        db_snap.close()


def _get_agent_prompt(agent_name: str) -> str:
    """Get persona-specific prompt from database."""
    db_session = SessionLocal()
    try:
        agent_row = db_session.query(Agent).filter(
            Agent.agent_name == agent_name
        ).first()
        return agent_row.system_prompt if agent_row else ""
    finally:
        db_session.close()


def _build_uploaded_files_context(uploaded_files: list) -> str:
    """Build context string for uploaded files (bulk processing)."""
    if not uploaded_files:
        return ""

    files_context = []
    for f in uploaded_files:
        files_context.append(
            f"File: {f.get('filename', 'unknown')} ({f.get('file_type', 'unknown')}, {f.get('row_count', 0)} rows)"
        )
        preview = f.get("preview", []) or []
        for row in preview[:3]:
            files_context.append(f"  - {row}")
        if len(preview) > 3:
            files_context.append(f"  ... and {len(preview) - 3} more rows")
        files_context.append("")
    return "\n".join(files_context)
