def _validate_creator_row(row: dict) -> tuple:
    """Validate one creator-Excel row. Return (fields_dict, error)."""
    import re
    from datetime import datetime
    errors = []
    out = {}

    int_specs = [
        ("resource_id", ["Employee ID", "EmployeeID", "Emp ID", "EmpID", "Resource ID"]),
        ("project_id",  ["Project ID", "ProjectID", "Project"]),
        ("product_id",  ["Product ID", "ProductID", "Product"]),
        ("task_idx",    ["Task Index", "TaskIndex", "Task Idx", "TaskIdx"]),
        ("activity_idx",["Activity Index", "ActivityIndex", "Activity Idx", "Activity"]),
    ]
    for field, headers in int_specs:
        val = _get_cell(row, *headers)
        if val is None:
            errors.append(f"missing {field}")
        else:
            try:
                out[field] = int(float(val))   # tolerate "100.0"
            except Exception:
                errors.append(f"invalid {field} ('{val}')")

    sd = _get_cell(row, "Start Date", "StartDate", "From")
    ed = _get_cell(row, "End Date", "EndDate", "To")

    # Excel may parse dates as datetime; normalize to YYYY-MM-DD
    def _to_iso_date(v):
        if v is None: return None
        if hasattr(v, "strftime"): return v.strftime("%Y-%m-%d")
        return str(v).strip()

    sd, ed = _to_iso_date(sd), _to_iso_date(ed)
    out["start_date"], out["end_date"] = sd, ed

    if not sd:
        errors.append("missing start_date")
    if not ed:
        errors.append("missing end_date")
    if sd and ed:
        try:
            sdp = datetime.strptime(sd, "%Y-%m-%d")
            edp = datetime.strptime(ed, "%Y-%m-%d")
            if edp < sdp:
                errors.append("end date is before start date")
        except Exception:
            errors.append(f"invalid date (use YYYY-MM-DD)")

    hours_val = _get_cell(row, "Planned Hours", "PlannedHours", "Plan Hours", "Hours")
    if hours_val is None:
        errors.append("missing plan_hrs")
    else:
        try:
            h = float(hours_val)
            if h <= 0:
                errors.append("plan_hrs must be positive")
            else:
                out["plan_hrs"] = h
        except Exception:
            errors.append(f"invalid plan_hrs ('{hours_val}')")

    if errors:
        return None, "; ".join(errors)
    return out, None


def _validate_reviewer_row(row: dict) -> tuple:
    """Validate one reviewer-Excel row (logging hours)."""
    from datetime import datetime
    errors = []
    out = {}

    tval = _get_cell(row, "Task ID", "TaskID", "Task Id", "WorkLogIdx")
    if tval is None:
        errors.append("missing task_id")
    else:
        try:
            out["worklog_idx"] = int(float(tval))
        except Exception:
            errors.append(f"invalid task_id ('{tval}')")

    dval = _get_cell(row, "Date", "Task Date", "TaskDate")
    if dval is None:
        errors.append("missing date")
    else:
        d = dval.strftime("%Y-%m-%d") if hasattr(dval, "strftime") else str(dval).strip()
        try:
            datetime.strptime(d, "%Y-%m-%d")
            out["task_date"] = d
        except Exception:
            errors.append(f"invalid date ('{d}')")

    hval = _get_cell(row, "Hours", "TimeSpent", "Time Spent")
    if hval is None:
        errors.append("missing hours")
    else:
        try:
            h = float(hval)
            if h <= 0:
                errors.append("hours must be positive")
            else:
                out["hours"] = h
        except Exception:
            errors.append(f"invalid hours ('{hval}')")

    rval = _get_cell(row, "Remark", "Remarks", "UserRemarks", "Note")
    if rval is None or str(rval).strip() == "":
        errors.append("missing remark")
    else:
        out["remarks"] = str(rval).strip()

    if errors:
        return None, "; ".join(errors)
    return out, None


def _validate_approver_row(row: dict) -> tuple:
    """Validate one approver-Excel row (bulk approve)."""
    errors = []
    out = {}

    wval = _get_cell(row, "Worklog ID", "WorklogID", "Worklog Id", "Idx")
    if wval is None:
        errors.append("missing worklog_id")
    else:
        try:
            out["worklog_log_idx"] = int(float(wval))
        except Exception:
            errors.append(f"invalid worklog_id ('{wval}')")

    if errors:
        return None, "; ".join(errors)
    return out, None

