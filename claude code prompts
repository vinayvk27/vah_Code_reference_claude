INSERT IGNORE INTO dpah_module_usergroups (module_id, group_id)
SELECT m.module_id, DISTINCT r.GroupIDx
FROM dpah_modules m
CROSS JOIN resources r
WHERE m.module_name = 'MRR' AND r.GroupIDx IS NOT NULL;

-- Junior (7), Mid (8), Senior (9) in every group can invoke MRR_GENERAL_CREATOR.
INSERT IGNORE INTO dpah_role_agent_access (role_id, group_id, agent_id)
SELECT roles.role_id, groups.group_id, a.agent_id
FROM dpah_agents a
CROSS JOIN (SELECT 7 AS role_id UNION SELECT 8 UNION SELECT 9) roles
CROSS JOIN (SELECT DISTINCT group_id FROM dpah_module_usergroups WHERE module_id = (SELECT module_id FROM dpah_modules WHERE module_name = 'MRR')) groups
WHERE a.agent_name = 'MRR_GENERAL_CREATOR';

