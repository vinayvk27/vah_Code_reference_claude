"""
Oracle ERP Database Access
===========================
Sets up SQLAlchemy engine to Oracle ERP database.
Lazy-initialized to avoid errors if Oracle is unreachable at startup.
"""

from sqlalchemy import create_engine, text
from sqlalchemy.orm import sessionmaker

from app.core.config import settings

ORACLE_URL = (
    f"oracle+oracledb://{settings.ORACLE_USER}:{settings.ORACLE_PASSWORD}"
    f"@{settings.ORACLE_HOST}:{settings.ORACLE_PORT}"
    f"/?service_name={settings.ORACLE_SERVICE}"
)

_oracle_engine = None

def get_oracle_engine():
    global _oracle_engine
    if _oracle_engine is None:
        _oracle_engine = create_engine(ORACLE_URL, pool_pre_ping=True)
    return _oracle_engine

def get_oracle_session():
    engine = get_oracle_engine()
    SessionLocal = sessionmaker(bind=engine)
    return SessionLocal()
```

