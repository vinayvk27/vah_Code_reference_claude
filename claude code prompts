def mrr_cancel_node(state: MaterialRequisitionState) -> dict:
    """Clears pending_mrr_data and emits cancellation message."""
    return {
        "messages": [AIMessage(content=(
            "Your MRR submission has been cancelled. "
            "Upload a new Excel file when you're ready."
        ))],
        "pending_mrr_data": None,
        "execution_log": state.get("execution_log", []) + [
            "MRR cancelled by user."
        ]
    }
