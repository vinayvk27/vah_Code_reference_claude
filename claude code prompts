==============================================================================
In app/controllers/auth_controller.py, ADD a new function (do NOT replace existing functions):

  def authenticate_dev_mode(emp_no: str, dept: str, db: Session) -> dict:
      """
      Dev-mode authentication: looks up emp_no + dept in the resources table.
      No password check. Returns the same user_context shape as the LDAP path.
      Raises ValueError if user not found or dept doesn't match.
      """
      from app.models.db_schema import Resource
      
      # Normalize inputs
      emp_no_clean = (emp_no or "").strip()
      dept_clean = (dept or "").strip().upper()
      
      if not emp_no_clean or not dept_clean:
          raise ValueError("emp_no and dept are both required for dev login")
      
      resource = db.query(Resource).filter(Resource.Emp_no == emp_no_clean).first()
      if not resource:
          raise ValueError(f"No employee found with emp_no={emp_no_clean}")
      
      # Compare dept case-insensitively
      resource_dept = (resource.Dept or "").strip().upper()
      if resource_dept != dept_clean:
          raise ValueError(f"Dept mismatch — resource {emp_no_clean} is in {resource_dept}, not {dept_clean}")
      
      # Build user context using the existing helper (same as LDAP path)
      user_context = build_user_context_by_empno(emp_no_clean, db)
      return user_context

  IMPORTANT: build_user_context_by_empno already exists from earlier work and is what the LDAP path uses to build the JWT payload after authentication. Reuse it — do NOT duplicate that logic.

