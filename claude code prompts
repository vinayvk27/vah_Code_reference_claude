                    <tr>
                      {tableField.columns.filter(isColVisible).map(col => (
                        <th key={col.name} className="px-2 py-2 text-left font-semibold whitespace-nowrap text-slate-600 dark:text-slate-300">
                          {col.label}
                          {col.required && <span className="text-red-400 ml-0.5">*</span>}
                        </th>
                      ))}
                      <th className="w-8" />
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-slate-100 dark:divide-slate-700/60">
                    {formData[tableField.name]?.map((row, rowIndex) => (
                      <tr key={rowIndex}>
                        {tableField.columns.filter(isColVisible).map(col => {
                          const cellError = getError(`${tableField.name}.${rowIndex}.${col.name}`);

                          // Item autocomplete — extracted component (fixes hooks-in-map crash)
                          if (col.name === 'item_name' && col.type === 'text') {
                            return (
                              <ItemAutocompleteCell
                                key={col.name}
                                value={row[col.name]}
                                tableName={tableField.name}
                                rowIndex={rowIndex}
                                col={col}
                                isSubmitting={isSubmitting}
                                onItemChange={handleItemChange}
                                cellError={cellError}
                              />
                            );
                          }

                          // Regular table cell
                          const cellCls = [
                            'w-full px-2 py-1 text-[13px] font-medium rounded-lg border',
                            'bg-white dark:bg-slate-800/80',
                            'text-slate-800 dark:text-slate-200',
                            'border-slate-200 dark:border-slate-700',
                            'outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/20',
                            'transition-colors',
                            cellError ? 'border-red-500 ring-1 ring-red-500/20' : '',
                          ].join(' ');

                          return (
                            <td key={col.name} className="px-2 py-1.5 align-top">
                              <input
                                type={col.type || 'text'}
                                value={row[col.name] || ''}
                                onChange={e => handleItemChange(tableField.name, rowIndex, col.name, e.target.value)}
                                required={col.required}
                                min={col.min}
                                disabled={isSubmitting}
                                className={cellCls}
                              />
                              {cellError && <ErrorMsg text={cellError} />}
                            </td>
                          );
                        })}
                        <td className="px-2 py-1.5 text-center align-top">
                          <button
                            type="button"
                            onClick={() => removeRow(tableField.name, rowIndex)}
                            disabled={isSubmitting || (formData[tableField.name]?.length ?? 0) <= (tableField.min_rows || 1)}
                            className="p-1 rounded text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
                          >
                            <Trash2 size={14} />
                          </button>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              <button
                type="button"
                onClick={() => addRow(tableField.name, tableField.columns)}
                disabled={isSubmitting}
                className="w-full mt-2 py-1.5 rounded-lg border border-dashed
                  border-slate-300 dark:border-slate-600
                  text-[11px] font-medium text-slate-500
                  hover:border-blue-400 hover:text-blue-400 hover:bg-blue-500/5
                  transition-all duration-150 flex items-center justify-center gap-1.5"
              >
                <Plus size={12} />
                Add Row
              </button>
            </div>
          ))}

          {/* Footer */}
          <div className="flex items-center justify-between pt-3 mt-1 border-t border-slate-100 dark:border-slate-700/60">
            <button
              type="button"
              onClick={onCancel}
              disabled={isSubmitting}
              className="px-3 py-1.5 text-[12px] font-medium rounded-lg
                text-slate-500 dark:text-slate-400
                hover:bg-slate-100 dark:hover:bg-slate-700/40
                hover:text-slate-700 dark:hover:text-slate-200
                transition-all duration-150 disabled:opacity-40"
            >
              {formSpec.cancel_label || 'Cancel'}
            </button>
            <button
              type="submit"
              disabled={isSubmitting}
              className="px-5 py-1.5 text-[12px] font-semibold rounded-lg
                bg-blue-600 hover:bg-blue-500 active:bg-blue-700
                text-white shadow-sm shadow-blue-500/20
                disabled:opacity-40 disabled:cursor-not-allowed
                transition-all duration-150 min-w-[80px] text-center"
            >
              {isSubmitting ? (
                <span className="flex items-center justify-center gap-1.5">
                  <Loader2 size={11} className="animate-spin" />
                  Submitting...
                </span>
              ) : (formSpec.submit_label || 'Submit')}
            </button>
          </div>
        </form>
      )}
    </div>
  );
}

