  def reviewer_agent_node(state: HRMSState) -> HRMSState:
      """
      HRMS Filler (reviewer persona) agent.
      Helps employees check leave balance, submit leave requests, view own payslip.
      """
      user_emp_id = state.get("user_id")
      user_dept = state.get("user_dept", "")
      user_personas = (state.get("collection_agents") or {}).get("HRMS", []) or []
      user_context = _get_user_context(state)
      
      # Look up name and grade for context
      user_name = ""
      user_grade = None
      db_snap = SessionLocal()
      try:
          resource = db_snap.query(Resource).filter(Resource.Emp_no == str(user_emp_id)).first()
          if resource:
              user_name = resource.Name or ""
              user_grade = resource.Grade
              user_context["name"] = user_name
              user_context["grade"] = user_grade
      finally:
          db_snap.close()
      
      # Fetch DB-backed snapshot of THIS user's HRMS data
      db_snap = SessionLocal()
      try:
          leave_balance = hrms_store.compute_leave_balance(db_snap, int(user_emp_id))
          my_requests = hrms_store.list_leave_requests(db_snap, resource_id=int(user_emp_id))
          my_payslips = hrms_store.list_payslips(db_snap, resource_id=int(user_emp_id))
      except Exception:
          leave_balance = []
          my_requests = []
          my_payslips = []
      finally:
          db_snap.close()
      
      snapshot_lines = []
      if leave_balance:
          snapshot_lines.append("Leave balance:")
          for b in leave_balance[:10]:
              snapshot_lines.append(f"  - {b['leave_type_name']} (id={b['leave_type_id']}): {b['remaining_days']} of {b['max_days']} remaining")
      if my_requests:
          snapshot_lines.append("Your leave requests:")
          for r in my_requests[:15]:
              snapshot_lines.append(f"  - #{r['request_id']} {r['leave_type_name']} {r['from_date']} to {r['to_date']} ({r['status']})")
      if my_payslips:
          snapshot_lines.append("Your payslips:")
          for p in my_payslips[:10]:
              snapshot_lines.append(f"  - {p['pay_month']}: Net Pay {p['net_pay']}")
      snapshot_block = "\n".join(snapshot_lines) if snapshot_lines else "(no data yet)"
      
      # Base prompt from DB
      base_prompt = _get_agent_prompt("HRMS_REVIEWER")
      
      system_prompt = (
          f"{base_prompt}\n\n"
          f"=== CURRENT USER CONTEXT ===\n"
          f"Employee ID: {user_emp_id}\n"
          f"Employee Name: {user_name}\n"
          f"Department: {user_dept}\n"
          f"Grade: {user_grade or 'N/A'}\n"
          f"Persona: FILLER\n\n"
          f"=== CONVERSATION HISTORY IS AUTHORITATIVE ===\n"
          f"Recent messages between you and the user are included in this conversation. "
          f"The DATA SNAPSHOT below is fetched at the start of THIS request — it does NOT include actions you took earlier in this same conversation.\n"
          f"When the user asks 'what did I just submit', 'what was that request', or anything referring to recent activity, "
          f"FIRST check conversation history for tool actions you confirmed in earlier turns.\n\n"
          f"=== HOW TO PERFORM ACTIONS (CRITICAL) ===\n"
          f"Your platform does NOT support normal tool calling. You MUST use a special protocol.\n\n"
          f"Format: <<ACTION>>{{\"tool\": \"<name>\", \"args\": {{...}}}}<<END>>\n\n"
          f"Available tools for HRMS FILLER (you):\n"
          f"- tool_list_my_leave_balance — show remaining leave days (no args)\n"
          f"- tool_request_leave — submit a leave request\n"
          f"  args: {{\"leave_type_id\": <int>, \"from_date\": \"YYYY-MM-DD\", \"to_date\": \"YYYY-MM-DD\", \"reason\": \"<string>\"}}\n"
          f"- tool_my_payslip — view your payslip for a month\n"
          f"  args: {{\"pay_month\": \"YYYY-MM\"}}\n"
          f"- tool_list_my_leave_requests — list all your leave requests (no args)\n\n"
          f"RULES:\n"
          f"1. When user gives all details, IMMEDIATELY emit the <<ACTION>>...<<END>> block. Do NOT ask 'shall I proceed?'.\n"
          f"2. If user asks about another employee's data or to approve a leave, politely refuse:\n"
          f"   'I only handle your own data. To view someone else's payslip or approve leaves, you need approver access.'\n"
          f"3. After action block, write a brief confirmation (1-2 sentences).\n\n"
          f"=== CURRENT DATA SNAPSHOT ===\n{snapshot_block}\n"
      )
      
      # Tool wrappers
      @tool
      def list_my_leave_balance() -> str:
          """List the user's leave balance by type."""
          return hrms_tools.tool_list_my_leave_balance(user_context)
      
      @tool
      def request_leave(leave_type_id: int, from_date: str, to_date: str, reason: str) -> str:
          """Submit a new leave request."""
          return hrms_tools.tool_request_leave(leave_type_id, from_date, to_date, reason, user_context)
      
      @tool
      def my_payslip(pay_month: str) -> str:
          """View payslip for a month (YYYY-MM)."""
          return hrms_tools.tool_my_payslip(pay_month, user_context)
      
      @tool
      def list_my_leave_requests() -> str:
          """List all of the user's leave requests."""
          return hrms_tools.tool_list_my_leave_requests(user_context)
      
      llm = get_llm()
      llm_with_tools = llm.bind_tools([list_my_leave_balance, request_leave, my_payslip, list_my_leave_requests])
      
      # Build message list — system prompt + full conversation history
      messages = list(state.get("messages") or [])
      message_list = [SystemMessage(content=system_prompt)] + messages
      
      # Invoke LLM
      response = llm_with_tools.invoke(message_list)
      
      # Action parser
      actions = extract_actions(response.content or "")
      
      if actions:
          for action in actions:
              tool_name = action.get("tool")
              tool_args = action.get("args") or {}
              try:
                  if tool_name == "tool_list_my_leave_balance":
                      list_my_leave_balance.invoke(tool_args)
                  elif tool_name == "tool_request_leave":
                      request_leave.invoke(tool_args)
                  elif tool_name == "tool_my_payslip":
                      my_payslip.invoke(tool_args)
                  elif tool_name == "tool_list_my_leave_requests":
                      list_my_leave_requests.invoke(tool_args)
              except PermissionError:
                  pass
              except Exception:
                  pass
          
          clean_content = strip_actions(response.content)
          full_text = clean_content.strip()
      else:
          full_text = (response.content or "").strip()
      
      msgs = list(state.get("messages") or [])
      msgs.append(AIMessage(content=full_text))
      state["messages"] = msgs
      return state

