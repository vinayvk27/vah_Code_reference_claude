    selected_collection: str
    selected_agent_role: str
    parsed_intent: str
    classifier_confidence: str
    append_soft_correction: bool
    has_permission: bool
    messages: Annotated[list, add_messages]
    execution_log: List[str]
    uploaded_files: list
    denial_message: Optional[str]

    # MRR Form State Machine Fields
    current_step: str
    latest_submission: Optional[Dict[str, Any]]

    # Material Requisition Transaction Data
    form_state: Dict[str, Any]
    items: List[Dict[str, Any]]
    total_cost: float
    routing_decision: Optional[str]

