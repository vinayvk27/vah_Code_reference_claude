async def sse_generator_with_orchestrator(
    db: Session,
    current_user: dict,
    raw_token: str,
    request_data: dict
) -> AsyncGenerator[str, None]:
    try:
        async for chunk in ChatController.stream_chat_with_orchestrator(
            db, current_user, raw_token, request_data
        ):
            yield f"data: {chunk}\n\n"
        yield "data: [DONE]\n\n"
    except PermissionError as e:
        yield f"data: {json.dumps({'error': str(e)})}\n\n"
        yield "data: [DONE]\n\n"
    except Exception as e:
        yield f"data: {json.dumps({'error': f'Server error: {str(e)}'})}\n\n"
        yield "data: [DONE]\n\n"


@router.post(
    "/stream",
    summary="Stream chat messages from the agent"
)
async def stream_chat_message(
    request: ChatStreamRequest,
    db: Session = Depends(get_db),
    current_user: dict = Depends(get_current_user),
    raw_token: str = Depends(oauth2_scheme)
):
    request_data = request.model_dump()

    if not current_user.get("collection_agents"):
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="No agent permissions associated with this user. Contact your administrator."
        )

    return StreamingResponse(
        sse_generator_with_orchestrator(db, current_user, raw_token, request_data),
        media_type="text/event-stream",
    )


async def sse_generator_with_file(
    db: Session,
    current_user: dict,
    raw_token: str,
    request_data: dict,
    uploaded_files: list
) -> AsyncGenerator[str, None]:
    try:
        request_data["uploaded_files"] = uploaded_files
        async for chunk in ChatController.stream_chat_with_file(
            db, current_user, raw_token, request_data
        ):
            yield f"data: {chunk}\n\n"
        yield "data: [DONE]\n\n"
    except PermissionError as e:
        yield f"data: {json.dumps({'error': str(e)})}\n\n"
        yield "data: [DONE]\n\n"
    except Exception as e:
        yield f"data: {json.dumps({'error': f'Server error: {str(e)}'})}\n\n"
        yield "data: [DONE]\n\n"


@router.post(
    "/stream-with-file",
    summary="Stream chat with file upload"
)
async def stream_chat_with_file_upload(
    collection_name: Annotated[str, Form(...)],
    message: Annotated[str, Form(...)],
    files: Annotated[list[UploadFile], File(...)],
    chat_history: Annotated[Optional[str], Form()] = None,
    thread_id: Annotated[Optional[str], Form()] = None,
    db: Session = Depends(get_db),
    current_user: dict = Depends(get_current_user),
    raw_token: str = Depends(oauth2_scheme)
):
    if not files or len(files) == 0:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="At least one file must be uploaded."
        )

    request_data = {
        "collection_name": collection_name,
        "message": message,
        "chat_history": json.loads(chat_history) if chat_history else [],
        "thread_id": thread_id,
    }

    if not current_user.get("collection_agents"):
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="No agent permissions associated with this user."
        )

    uploaded_files = []
    for file in files:
        try:
            content = await file.read()
            file_data = await ChatController.parse_uploaded_file(file.filename, content)
            uploaded_files.append(file_data)
        except Exception as e:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail=f"Error processing file '{file.filename}': {str(e)}"
            )

    return StreamingResponse(
        sse_generator_with_file(db, current_user, raw_token, request_data, uploaded_files),
        media_type="text/event-stream",
    )


