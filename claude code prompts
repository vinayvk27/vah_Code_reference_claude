#Project Table
CREATE TABLE `posproject` (
  `PROJECTID` int(11) NOT NULL,
  `WAREHOUSEID` smallint(6) DEFAULT NULL,
  `PROJECTNUMBER` varchar(20) DEFAULT NULL,
  `DESCRIPTION` varchar(250) DEFAULT NULL,
  `COSTTYPEID` smallint(6) DEFAULT NULL,
  `PROJECTSTARTDATE` varchar(20) DEFAULT NULL,
  `PROJECTENDDATE` varchar(20) DEFAULT NULL,
  `WHOCOLUMN` varchar(100) DEFAULT NULL,
  `PRJ_MTL_COST_LKHS` decimal(10,2) DEFAULT NULL,
  `DELIVERY_VALUE_CRORE` decimal(10,2) DEFAULT NULL,
  `MTL_EST_COST_FROM_DEL_VAL_LAKHS` decimal(10,2) DEFAULT NULL,
  `CUSTOMERNAME` varchar(100) DEFAULT NULL,
  `ESTIMATED_MAN_HRS` decimal(10,2) DEFAULT NULL,
  `TRAVEL_EXPENSES_L` decimal(10,2) DEFAULT NULL,
  `PROJECT_CATEGORY` varchar(45) DEFAULT NULL,
  `PM_NAME` varchar(45) DEFAULT NULL,
  `DELIVERY_FY` varchar(45) DEFAULT NULL,
  PRIMARY KEY (`PROJECTID`),
  KEY `IDX_POSPROJ_PROJNUMBER` (`PROJECTNUMBER`,`WAREHOUSEID`)
) ENGINE=InnoDB DEFAULT CHARSET=latin1 COLLATE=latin1_swedish_ci;

