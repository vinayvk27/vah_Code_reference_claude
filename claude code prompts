import re
from pydantic import BaseModel, Field
from typing import Literal

# Keyword lists — ordered by priority (most specific first)

OUT_OF_DOMAIN_KEYWORDS = [
    "weather", "joke", "salary", "payslip", "leave balance",
    "hello", "hi there", "good morning", "good evening",
    "who are you", "what can you do", "tell me about",
    "news", "global", "stock price", "material requisition",
    "approve mrr", "issue stock",
]

APPROVER_KEYWORDS = [
    "approve all", "approve pending",
    "show pending approvals", "show pending approval",
    "pending approvals", "approval queue", "to approve",
    "approve worklog", "reject worklog",
    "approve timesheet", "reject timesheet",
    "approve ", "reject ", "sign off", "signoff",
]

CREATOR_KEYWORDS = [
    "create task", "create a task", "new task", "add task",
    "add a task", "assign task", "assign a task",
    "create timesheet", "set up task", "setup task",
    "i need to create", "i want to create", "make a task",
]

REVIEWER_KEYWORDS = [
    "show my tasks", "show my task", "my tasks", "my task",
    "show tasks", "list my tasks", "list tasks",
    "my assignments", "my assigned", "assigned to me",
    "what tasks", "what are my", "show my current",
    "log hours", "log time", "log my hours", "fill hours",
    "fill timesheet", "fill my timesheet", "enter hours",
    "enter time", "i worked", "log worklog", "record hours",
    "submit hours", "show my worklogs", "my worklogs",
    "my entries", "pending entries", "my pending",
]


def _normalize(message: str) -> str:
    if not message:
        return ""
    text = message.lower().strip()
    text = re.sub(r"[,.;:!?'\"()\\[\\]{}]+", " ", text)
    text = re.sub(r"\s+", " ", text)
    return text


def _build_in_domain(persona: str, confidence: str, reasoning: str) -> RMSIntentClassification:
    return RMSIntentClassification(
        domain="IN_DOMAIN",
        collection="rms_timesheet",
        persona=persona,
        confidence=confidence,
        reasoning=reasoning,
    )


def _build_out_of_domain(reasoning: str) -> RMSIntentClassification:
    return RMSIntentClassification(
        domain="OUT_OF_DOMAIN",
        collection="",
        persona="",
        confidence="HIGH",
        reasoning=reasoning,
    )


def classify_rms_intent(user_message: str) -> RMSIntentClassification:
    """
    Keyword-based intent classifier for RMS. No LLM call — deterministic.
    All IN_DOMAIN classifications use collection rms_timesheet
    (rms_projectplan is not routed to; it is reserved for future use).
    """
    text = _normalize(user_message)

    if not text:
        return _build_out_of_domain("Empty message")

    # Step 1: Out-of-domain check.
    for kw in OUT_OF_DOMAIN_KEYWORDS:
        if kw in text:
            return _build_out_of_domain(f"Matched out-of-domain keyword: {kw}")

    # Step 2: Approver (most specific action verbs).
    for kw in APPROVER_KEYWORDS:
        if kw in text:
            return _build_in_domain("approver", "HIGH",
                                     f"Matched approver keyword: {kw}")

    # Step 3: Creator.
    for kw in CREATOR_KEYWORDS:
        if kw in text:
            return _build_in_domain("creator", "HIGH",
                                     f"Matched creator keyword: {kw}")

    # Step 4: Reviewer (viewing tasks + logging hours).
    for kw in REVIEWER_KEYWORDS:
        if kw in text:
            return _build_in_domain("reviewer", "HIGH",
                                     f"Matched reviewer keyword: {kw}")

    # Step 5: No keyword matched — out of domain.
    return _build_out_of_domain(
        "No RMS-related keyword matched. Treating as out-of-domain."
    )
