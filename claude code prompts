FIX
Replace the get_item_details_from_db(item_name) call inside
form_submit_handler_node with a direct, minimal inline SQL lookup
against com_search:

    from sqlalchemy import text
    # ... already in the function scope ...

    # Inline item lookup (avoids the legacy availability chain).
    # We only need: item_id, item_name, unit_price_rs.
    def _lookup_item(db_session, keyword: str) -> dict | None:
        row = db_session.execute(text(\"""
            SELECT DP_PART_NO              AS item_id,
                   ITEM_NAME               AS item_name,
                   LPP_VALUE_UNITPRICE_INR AS unit_price_rs
            FROM com_search
            WHERE DP_PART_NO = :kw
              AND WAREHOUSE = '1'
            LIMIT 1
        \"""), {"kw": keyword}).mappings().first()
        return dict(row) if row else None

