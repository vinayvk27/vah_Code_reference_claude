    #     api_key=settings.LLM_API_KEY,
    #     temperature=0,
    # )
    raise NotImplementedError("Fill in based on app/core/llm.py")


TEST_QUERIES = [
    ("list_all", "Show me all tasks."),
    ("list_filtered", "Show me tasks for resource 3010."),
    ("create", "Create a task for resource 5000 on project 300 with 12 hours."),
    ("create_then_list", "Create a task for resource 6000 on project 400 with 4 hours, then show all tasks."),
]


def run_model_tests(model_name: str):
    print("\\n" + "#" * 72)
    print(f"# MODEL: {model_name}")
    print("#" * 72)

    results = {}

    for test_id, query in TEST_QUERIES:
        print(f"\\n{'=' * 72}")
        print(f"TEST [{test_id}] — query: {query!r}")
        print("-" * 72)

        TOOL_CALL_LOG.clear()
        capture = RawOutputCapture()

        try:
            llm = build_llm_for_model(model_name)
            tools = [list_tasks_tool, create_task_tool]
            agent = create_react_agent(llm, tools, REACT_PROMPT)
            executor = AgentExecutor(
                agent=agent,
                tools=tools,
                verbose=True,
                handle_parsing_errors=True,
                max_iterations=4,
                callbacks=[capture],
            )
            result = executor.invoke({"input": query}, config={"callbacks": [capture]})
            output = result.get("output", "")

            tools_invoked = len(TOOL_CALL_LOG) > 0
            print("-" * 72)
            print(f"[RESULT] final output: {output[:300]}")
            print(f"[DIAG] tools actually invoked: {tools_invoked} ({len(TOOL_CALL_LOG)} calls)")
            print(f"[DIAG] tool call log: {TOOL_CALL_LOG}")
            print(f"[DIAG] number of raw LLM generations: {len(capture.raw_outputs)}")
            for i, raw in enumerate(capture.raw_outputs):
                print(f"  --- RAW LLM OUTPUT #{i+1} ---")
                print("  " + raw.replace("\\n", "\\n  ")[:800])
            results[test_id] = {
                "completed": True,
                "tools_invoked": tools_invoked,
                "tool_calls": len(TOOL_CALL_LOG),
            }
        except Exception as e:
            print("-" * 72)
            print(f"[RESULT] CRASHED with exception: {type(e).__name__}: {e}")
            print(f"[DIAG] tools invoked before crash: {len(TOOL_CALL_LOG)}")
            print(f"[DIAG] raw LLM outputs before crash: {len(capture.raw_outputs)}")
            for i, raw in enumerate(capture.raw_outputs):
                print(f"  --- RAW LLM OUTPUT #{i+1} (before crash) ---")
                print("  " + raw.replace("\\n", "\\n  ")[:800])
            traceback.print_exc()
            results[test_id] = {
                "completed": False,
                "tools_invoked": len(TOOL_CALL_LOG) > 0,
                "error": f"{type(e).__name__}: {e}",
            }

    # Per-model verdict
    print(f"\\n{'*' * 72}")
    print(f"* VERDICT for {model_name}:")
    total = len(TEST_QUERIES)
    completed = sum(1 for r in results.values() if r.get("completed"))
    invoked = sum(1 for r in results.values() if r.get("tools_invoked"))
    print(f"*   Tests completed without crash: {completed}/{total}")
    print(f"*   Tests where tools were actually invoked: {invoked}/{total}")
    if completed == total and invoked == total:
        print(f"*   ==> RELIABLE for ReAct tool calling.")
    elif invoked >= total // 2:
        print(f"*   ==> PARTIALLY reliable — some failures.")
    else:
        print(f"*   ==> UNRELIABLE for ReAct tool calling.")
    print("*" * 72)
    return results


if __name__ == "__main__":
    print("\\nMULTI-MODEL ReAct VIABILITY DIAGNOSTIC")
    print("Same code, same tools, same prompt — only the MODEL changes.\\n")
    print(f"Models to test: {MODELS_TO_TEST}\\n")

    all_results = {}
    for model_name in MODELS_TO_TEST:
        try:
            all_results[model_name] = run_model_tests(model_name)
        except NotImplementedError as e:
            print(f"\\n[SETUP NEEDED] {e}")
            print("Edit build_llm_for_model() to construct the LLM correctly.")
            break
        except Exception as e:
            print(f"\\n[MODEL {model_name} setup failed]: {e}")
            traceback.print_exc()

    # Final comparison table
    print("\\n\\n" + "=" * 72)
    print("FINAL COMPARISON")
    print("=" * 72)
    for model_name, results in all_results.items():
        total = len(TEST_QUERIES)
        completed = sum(1 for r in results.values() if r.get("completed"))
        invoked = sum(1 for r in results.values() if r.get("tools_invoked"))
        print(f"{model_name:35s} | completed {completed}/{total} | tools invoked {invoked}/{total}")
    print("=" * 72)
    print("\\nIf a paid frontier model (Claude/Gemini) shows completed N/N and")
    print("tools invoked N/N, while the internal model shows failures, this")
    print("PROVES the reliability gap is the MODEL, not the application code.")

