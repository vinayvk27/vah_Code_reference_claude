-- 1. Is the user actually in resources, and what's their GroupIDx?
SELECT Emp_no, Name, Email, Department, GroupIDx, IsActive
FROM resources
WHERE Emp_no = '2052';

-- 2. Does this user have any role assigned in the NEW table?
SELECT ur.user_role_id, ur.emp_id, ur.role_id, r.role_name, ur.is_active
FROM dpah_user_roles ur
LEFT JOIN dpah_roles r ON r.role_id = ur.role_id
WHERE ur.emp_id = '2052';

-- 3. Does the user's group have any module access?
SELECT mug.group_idx, mug.module_id, m.module_name
FROM dpah_module_usergroups mug
JOIN dpah_modules m ON m.module_id = mug.module_id
WHERE mug.group_idx = (SELECT GroupIDx FROM resources WHERE Emp_no = '2052');