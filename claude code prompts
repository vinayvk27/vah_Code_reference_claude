def _handle_creator_excel(state, uploaded_files, current_emp_no, execution_log):
    rows = uploaded_files[0].get("data") or []
    if not rows:
        return {
            "messages": [AIMessage(content="The uploaded file has no rows to process.")],
            "execution_log": execution_log + ["Creator Excel: empty file."],
        }
    created = 0
    errors_report = []
    try:
        db = SessionLocal()
        try:
            for i, row in enumerate(rows, start=2):  # row 1 is header
                fields, err = _validate_creator_row(row)
                if err:
                    errors_report.append(f"Row {i}: {err}")
                    continue
                try:
                    timesheet_store.create_task(
                        db=db,
                        resource_id=fields["resource_id"],
                        project_id=fields["project_id"],
                        product_id=fields["product_id"],
                        task_idx=fields["task_idx"],
                        activity_idx=fields["activity_idx"],
                        start_date=fields["start_date"],
                        end_date=fields["end_date"],
                        plan_hrs=fields["plan_hrs"],
                        created_by=current_emp_no,
                    )
                    created += 1
                except Exception as e:
                    db.rollback()
                    errors_report.append(f"Row {i}: DB error: {e}")
        finally:
            db.close()
    except Exception as e:
        return {
            "messages": [AIMessage(content=f"Could not process the file due to a database error: {e}")],
            "execution_log": execution_log + [f"Creator Excel session error: {e}"],
        }

    msg_lines = [f"**Bulk Task Creation Summary**", ""]
    msg_lines.append(f"- Created: **{created}** tasks")
    msg_lines.append(f"- Skipped: **{len(errors_report)}** rows")
    if errors_report:
        msg_lines.append("")
        msg_lines.append("**Errors:**")
        for e in errors_report[:20]:   # cap output
            msg_lines.append(f"- {e}")
        if len(errors_report) > 20:
            msg_lines.append(f"- ...and {len(errors_report)-20} more.")
    return {
        "messages": [AIMessage(content="\n".join(msg_lines))],
        "execution_log": execution_log + [f"Creator Excel: created={created} skipped={len(errors_report)}"],
    }

