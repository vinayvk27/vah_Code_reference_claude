def parse_user_input(state: MaterialRequisitionState) -> dict:
    """Parses widget submissions and safely updates LangGraph state."""
    latest_message = state["messages"][-1].content

    updates = {}

    # PROPER STATE UPDATE: Return the new values instead of modifying state directly
    if not state.get("current_step"):
        updates["current_step"] = "HEADER"
        updates["items"] = []
        updates["total_cost"] = 0.0

    try:
        payload = json.loads(latest_message)
        if isinstance(payload, dict) and payload.get("action") == "widget_submit":
            updates["latest_submission"] = payload
            return updates
    except Exception:
        pass

    updates["latest_submission"] = None
    return updates


def handle_header(state: MaterialRequisitionState) -> dict:
    submission = state.get("latest_submission")
    msg = state["messages"][-1].content

    # 1. Handle Widget Submission (if user used the form)
    if submission and submission.get("widget_id") == "mrr_header_form":
        return {
            "form_state": submission.get("data", {}),
            "current_step": "ITEMS",
            "messages": [AIMessage(content="Header details saved. Please add items or upload an Excel sheet.")]
        }

    # 2. Natural Language Extraction
    try:
        extractor = get_header_extractor_agent()
        extracted = extractor.invoke(msg)

        if extracted.has_minimum_data and extracted.project_id:
            updates = {
                "form_state": {
                    "project_id": extracted.project_id,
                    "phase_id": extracted.phase_id,
                    "warehouse": extracted.warehouse,
                    "requisition_type": extracted.requisition_type,
                    "need_by_date": extracted.need_by_date,
                    "remarks": extracted.remarks
                },
                "current_step": "ITEMS"
            }

            # --- PROCESS ITEMS IN PROMPT ---
            if extracted.items and len(extracted.items) > 0:
                cart_items = []
                total_cost = 0.0

                for ext_item in extracted.items:
                    item_data = get_item_details_from_db(ext_item.keyword)
                    if item_data:
                        line_total = ext_item.qty * item_data["unit_price_rs"]
                        cart_items.append({
                            "item_name": item_data["item_name"],
                            "item_id": item_data["item_id"],
                            "qty": ext_item.qty,
                            "unit_price_rs": item_data["unit_price_rs"],
                            "total": line_total
                        })
                        total_cost += line_total

                if cart_items:
                    updates["items"] = cart_items
                    updates["total_cost"] = total_cost
                    updates["messages"] = [
                        AIMessage(content=f"Got it! Started request for Project **{extracted.project_id}**.\n\n\u2705 Automatically added **{len(cart_items)} items** to your cart. Total: **\u20b9{total_cost}**.\n\nYou can add more items or type **'Submit'** to finish.")
                    ]
                    return updates

            # Fallback if no items were found in prompt
            updates["messages"] = [AIMessage(content=f"Got it! Started request for Project **{extracted.project_id}** (Phase: **{extracted.phase_id}**).\n\nWhat items would you like to add?")]
            return updates

    except Exception as e:
        print(f"Extraction Error: {e}")

    # 3. Default: Show Form
    return {
        "messages": [
            AIMessage(content="Please fill out the project details or just type them to me:"),
            AIMessage(content=get_header_widget_payload())
        ]
    }


def handle_items(state: MaterialRequisitionState) -> dict:
    msg = state["messages"][-1].content
    uploaded_files = state.get("uploaded_files", [])

    # 1. Handle Excel Bulk Uploads
    if uploaded_files:
        new_items = state.get("items", [])
        total_added = 0

        for file in uploaded_files:
            for row in file.get("data", []):
                # Map common excel column names
                item_code = row.get("item_code") or row.get("ItemCode") or row.get("Part Number")
                qty_raw = row.get("qty") or row.get("Quantity") or row.get("Qty")

                if item_code and qty_raw:
                    try:
                        qty = float(qty_raw)
                        # Query the database for live price and availability
                        item_data = get_item_details_from_db(str(item_code))

                        if item_data:
                            new_item = {
                                "item_name": item_data["item_name"],
                                "item_id": item_data["item_id"],
                                "qty": qty,
                                "unit_price_rs": item_data["unit_price_rs"],
                                "total": qty * item_data["unit_price_rs"]
                            }
                            new_items.append(new_item)
                            total_added += 1
                    except Exception:
                        pass # Skip invalid or missing rows

        if total_added > 0:
            new_total = sum(i["total"] for i in new_items)
            return {
                "items": new_items,
                "total_cost": new_total,
                "messages": [AIMessage(content=f"\u2705 Processed Excel file! Added {total_added} valid items to your cart. Total cost is now \u20b9{new_total}.\n\nYou can add more items or type 'Submit' to finish.")]
            }
        else:
            return {"messages": [AIMessage(content="I couldn't find any valid items or quantities in that file. Please ensure your columns are named 'ItemCode' and 'Qty'.")]}

    # 2. Handle Text Submission
    if "submit" in msg.lower() or "done" in msg.lower():
        if not state.get("items"):
            return {"messages": [AIMessage(content="Your cart is empty. Please add an item first.")]}
        return {"current_step": "EVALUATING"}

    # 3. Handle Item Lookup
    try:
        # Extract the keyword (e.g., '04617') using the LLM
        extraction = get_item_extractor_agent().invoke(msg)
        item_data = get_item_details_from_db(extraction.keyword)

        if not item_data:
            return {"messages": [AIMessage(content=f"I couldn't find any item matching '{extraction.keyword}' in the catalog.")]}

        # Return the Widget with REAL data (Price and Qty)
        return {
            "messages": [
                AIMessage(content=f"Found item: **{item_data['item_name']}**"),
                AIMessage(content=get_item_widget_payload(item_data))
            ]
        }
    except Exception as e:
        return {"messages": [AIMessage(content=f"Error searching for item: {str(e)}")]}


def evaluate_and_route(state: MaterialRequisitionState) -> dict:
    """Final node: Saves the completed requisition to MySQL and determines routing."""
    total = state.get("total_cost", 0.0)
    decision = "PENDING_MANAGER" if total >= 2000 else "PENDING_ERP"

    header_data = state.get("form_state", {})
    items = state.get("items", [])
    user_id = state.get("emp_no", state.get("user_id", "system"))

    db = SessionLocal()
    try:
        # 1. Insert Header into mrr_matrequisitionheader
        header_query = text("""
            INSERT INTO mrr_matrequisitionheader (
                MATREQUISITIONNO, STATUS, VERIFICATION_STATUS, VERIFICATION_DATE,
                APPROVAL_STATUS, APPROVAL_DATE, ERP_APPROVAL_STATUS, ERP_APPROVAL_DATE,
                SUPPLIERID, SUPPLIERSITEID, REQTRANSACTIONTYPE, COMMENTS,
                DEPARTMENTID, REQUESTORID, REQUISITIONDATE, TOTALCOST, PROJECTID, PHASEID
            ) VALUES (
                :mrrno, :status, NULL, NULL,
                NULL, NULL,
                NULL, NULL,
                0, 0, 'MATERIAL REQUISITION', '',
                1, :user, NOW(), :total, :proj, :phase
            )
        """)
        # Generate MRR number
        seq_result = db.execute(text("SELECT IFNULL(MAX(MATREQUISITIONID), 0) + 1 AS next_id FROM mrr_matrequisitionheader")).first()
        next_id = seq_result.next_id if seq_result else 1
        mrr_no = f"MRR/{next_id}/25-26"

        result = db.execute(header_query, {
            "mrrno": mrr_no,
            "status": "ENTERED",
            "total": total,
            "proj": header_data.get("project_id", "N/A"),
            "phase": header_data.get("phase_id", "N/A"),
            "user": user_id,
        })

        # Get the newly generated header ID
        header_id = result.lastrowid

        # 2. Insert Lines into mrr_matrequisitionlines
        if items:
            line_query = text("""
                INSERT INTO mrr_matrequisitionlines (
                    MATREQUISITIONID, ITEMID, ITEMNAME, REQUANTITY, ITEMCOST,
                    UOMID, ITEMREVISIONID, ISSUEQTY, RETURNQUANTITY, CLOSEREASON
                ) VALUES (
                    :hid, :iid, :iname, :qty, :itemcost,
                    0, 0, 0, 0, ''
                )
            """)
            for item in items:
                db.execute(line_query, {
                    "hid": header_id,
                    "iid": item.get("item_id", "0"),
                    "iname": item.get("item_name", ""),
                    "qty": item.get("qty", 0),
                    "itemcost": item.get("total", 0),
                })

        db.commit()

        # Store the new_requisition_id for auto-verifier
        return {
            "routing_decision": decision,
            "current_step": "END",
            "new_requisition_id": header_id,
            "messages": [AIMessage(content=f"Requisition saved with ID: {header_id} (MRR No: {mrr_no})")]
        }

    except Exception as e:
        db.rollback()
        return {
            "current_step": "END",
            "messages": [AIMessage(content=f"Database Error: Failed to save requisition. Details: {str(e)}")]
        }
    finally:
        db.close()


def auto_verifier_node(state: MaterialRequisitionState) -> dict:
    """
    Auto-verification logic. Deterministic, no LLM.
    Reads the new requisition's total cost. Routes based on
    the 2000-rupee rule.
    """
    print(f"[DIAG-MRR] auto_verifier_node entered. new_requisition_id={state.get('new_requisition_id')}", flush=True)
    requisition_id = state.get("new_requisition_id")
    if not requisition_id:
        return {
            "messages": [AIMessage(content="No requisition to verify.")],
            "execution_log": state.get("execution_log", []) + ["Verifier: no requisition_id in state."]
        }

    db = SessionLocal()
    try:
        # Compute total cost
        total_cost_row = db.execute(text("""
            SELECT COALESCE(SUM(ITEMCOST), 0) AS total
            FROM mrr_matrequisitionlines
            WHERE MATREQUISITIONID = :rid
        """), {"rid": requisition_id}).first()
        total_cost = float(total_cost_row.total or 0)

        now = datetime.now()

        if total_cost < 2000:
            # Auto-approve manager stage, route to ERP
            db.execute(text("""
                UPDATE mrr_matrequisitionheader
                SET VERIFICATION_STATUS = 'APPROVED',
                    VERIFICATION_DATE = :now,
                    APPROVAL_STATUS = 'APPROVED',
                    APPROVAL_DATE = :now,
                    ERP_APPROVAL_STATUS = 'PENDING',
                    COMMENTS = 'Auto-approved by verifier (total < 2000).'
                WHERE MATREQUISITIONID = :rid
            """), {"now": now, "rid": requisition_id})
            db.commit()
            confirmation = (
                f"Your requisition (total cost: \u20b9{total_cost:.2f}) "
                f"was auto-approved and is now awaiting ERP approval."
            )
        else:
            # Route to manager queue
            db.execute(text("""
                UPDATE mrr_matrequisitionheader
                SET VERIFICATION_STATUS = 'APPROVED',
                    VERIFICATION_DATE = :now,
                    APPROVAL_STATUS = 'PENDING'
                WHERE MATREQUISITIONID = :rid
            """), {"now": now, "rid": requisition_id})
            db.commit()
            confirmation = (
                f"Your requisition (total cost: \u20b9{total_cost:.2f}) "
                f"has been submitted for manager approval."
            )

        return {
            "messages": [AIMessage(content=confirmation)],
            "execution_log": state.get("execution_log", []) + [
                f"Auto-verifier: total={total_cost}, "
                f"{'auto-approved' if total_cost < 2000 else 'pending manager'}."
            ]
        }
    finally:
        db.close()


