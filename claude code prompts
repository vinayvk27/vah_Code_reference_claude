## 5. The new parse_intent_node function

```python
def parse_intent_node(state: HRMSState) -> dict:
    """
    Classify user intent using LLM classifier.
    Returns domain, collection, persona, confidence, and reasoning.
    """
    messages = state.get("messages", [])
    last_user_message = ""
    for msg in reversed(messages):
        if isinstance(msg, HumanMessage):
            last_user_message = str(msg.content)
            break

    if not last_user_message:
        return {
            "parsed_intent": "OUT_OF_DOMAIN",
            "selected_collection": "",
            "selected_agent_role": "",
            "classifier_confidence": "LOW",
            "append_soft_correction": False,
            "execution_log": state.get("execution_log", []) + ["No user message found."]
        }

    from app.workflows.hrms_workflow.intent import classify_hrms_intent
    classification = classify_hrms_intent(last_user_message)

    append_soft_correction = (
        classification.domain == "IN_DOMAIN"
        and classification.confidence in ("MEDIUM", "LOW")
    )

    return {
        "parsed_intent": classification.domain,
        "selected_collection": classification.collection,
        "selected_agent_role": classification.persona.lower() if classification.persona else "",
        "classifier_confidence": classification.confidence,
        "append_soft_correction": append_soft_correction,
        "execution_log": state.get("execution_log", []) + [
            f"Intent classified: domain={classification.domain}, "
            f"collection={classification.collection}, "
            f"persona={classification.persona}, "
            f"confidence={classification.confidence}, "
            f"reasoning={classification.reasoning}"
        ]
    }
```

## 6. The new permission_check_node function

```python
def permission_check_node(state: HRMSState) -> dict:
    """
    Check user permissions via DB (check_agent_access).
    Sets has_permission to True/False.
    OUT_OF_DOMAIN requests short-circuit with a denial message.
    """

    from app.controllers.auth_controller import AuthController

    parsed_intent = state.get("parsed_intent", "")
    selected_agent_role = state.get("selected_agent_role", "")
    selected_collection = state.get("selected_collection", "")
    emp_no = state.get("emp_no", "")
    group_idx = state.get("group_idx", 0)
    role_ids = state.get("role_ids", [])

    execution_log = state.get("execution_log", [])

    # OUT_OF_DOMAIN short-circuits
    if parsed_intent == "OUT_OF_DOMAIN":
        execution_log.append("Out-of-domain request; routing to blocked node.")
        return {
            "has_permission": False,
            "denial_message": (
                "I can only help with HRMS tasks like leave management, "
                "payslips, or leave approvals. Could you rephrase your request?"
            ),
            "execution_log": execution_log
        }

    # IN_DOMAIN: look up agent in DB and check access
    if not selected_collection or not selected_agent_role:
        execution_log.append("Classifier returned incomplete result; denying.")
        return {
            "has_permission": False,
            "denial_message": (
                "I wasn't able to understand your request. "
                "Could you rephrase it?"
            ),
            "execution_log": execution_log
        }

    # Build the expected agent_name following the convention:
    # {MODULE}_{COLLECTION_SUFFIX}_{PERSONA}
    # e.g., hrms_leave_data + creator → HRMS_LEAVE_DATA_CREATOR
    collection_suffix = selected_collection.upper().replace("HRMS_", "")
    expected_agent_name = f"HRMS_{collection_suffix}_{selected_agent_role.upper()}"

    # Look up the agent by name first to get its agent_id
    db = SessionLocal()
    try:
        from app.models.db_schema import Agent
        agent_row = db.query(Agent).filter(
            Agent.agent_name == expected_agent_name,
            Agent.is_active == 1
        ).first()

        if not agent_row:
            execution_log.append(f"Agent {expected_agent_name} not found in DB.")
            return {
                "has_permission": False,
                "denial_message": (
                    f"The {selected_agent_role} role for {selected_collection} "
                    f"is not available."
                ),
                "execution_log": execution_log
            }

        # Check access via Gate 2
        agent_or_none = AuthController.check_agent_access(
            emp_no=emp_no,
            group_idx=group_idx,
            role_ids=role_ids,
            agent_id=agent_row.agent_id,
            db=db
        )

        if agent_or_none is None:
            execution_log.append(
                f"Permission DENIED: user lacks {expected_agent_name}."
            )
            return {
                "has_permission": False,
                "denial_message": (
                    f"You don't have {selected_agent_role.lower()} access to "
                    f"{selected_collection.replace('_', ' ')}. "
                    f"Please contact your administrator if you need this permission."
                ),
                "execution_log": execution_log
            }

        execution_log.append(f"Permission GRANTED: {expected_agent_name}")
        return {
            "has_permission": True,
            "denial_message": None,
            "execution_log": execution_log
        }
    finally:
        db.close()
```

## 7. The new permission_router function

```python
def permission_router(state: HRMSState) -> str:
    """
    Conditional router from permission_check_node.
    - If has_permission is False -> permission_blocked
    - If has_permission is True -> route to correct agent based on selected_agent_role
    """
    if not state.get("has_permission", False):
        return "permission_blocked"

    selected_role = state.get("selected_agent_role", "").lower()

    if selected_role == "creator":
        return "creator_agent"
    elif selected_role == "reviewer":
        return "reviewer_agent"
    elif selected_role == "approver":
        return "approver_agent"
    else:
        return "permission_blocked"
```

