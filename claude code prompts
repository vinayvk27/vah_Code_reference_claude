  """
  HRMS Workflow Node Functions
  ============================
  Node functions for the HRMS LangGraph workflow.
  Mirrors rms_workflow/nodes.py — only HRMS-specific changes inside each function.
  """
  
  from typing import Optional
  from langchain_core.messages import HumanMessage, AIMessage, SystemMessage
  from sqlalchemy.orm import Session
  
  from app.dao.database import SessionLocal
  from app.models.db_schema import Agent, Resource
  from app.workflows.hrms_workflow.state import HRMSState
  from app.workflows.hrms_workflow.prompts import (
      KEYWORD_TO_PERSONA,
      DEFAULT_PERSONA,
      QUERY_KEYWORDS,
      PERSONA_ACTIONS,
      AGENT_DB_NAMES,
  )
  
  
  # ===========================================================================
  # Helpers (mirror RMS pattern)
  # ===========================================================================
  
  def _get_user_context(state: HRMSState) -> dict:
      """Build user context dict consumed by tools."""
      return {
          "user_id": state.get("user_id"),
          "user_dept": state.get("user_dept"),
          "persona": state.get("selected_agent_role"),
          "collection_agents": state.get("collection_agents", {}),
      }
  
  
  def _get_agent_prompt(agent_name: str) -> str:
      """Fetch system_prompt for the given agent from the DB."""
      db = SessionLocal()
      try:
          row = db.query(Agent).filter(Agent.agent_name == agent_name).first()
          return row.system_prompt if row and row.system_prompt else ""
      finally:
          db.close()
  
  
  # ===========================================================================
  # parse_intent_node
  # ===========================================================================
  
  def parse_intent_node(state: HRMSState) -> HRMSState:
      """
      Infer the persona to handle the user's message based on keywords.
      Sets state['selected_agent_role'] and state['parsed_intent'].
      """
      # Get the most recent user message
      messages = state.get("messages") or []
      user_msg = ""
      for m in reversed(messages):
          if isinstance(m, HumanMessage):
              user_msg = (m.content or "").lower()
              break
      
      # If explicit role provided AND user has it, prefer that
      explicit_role = state.get("selected_agent_role")
      collection = state.get("selected_collection", "HRMS")
      user_personas = (state.get("collection_agents") or {}).get(collection, []) or []
      
      if explicit_role and explicit_role in user_personas:
          state["parsed_intent"] = "explicit_hint"
          state["selected_agent_role"] = explicit_role
          return state
      
      # Keyword scan — priority: APPROVER > CREATOR > FILLER > QUERY > default
      matched_persona = None
      matched_keyword = None
      
      # Build priority order from KEYWORD_TO_PERSONA grouped by persona
      priority = ["approver", "creator", "reviewer"]
      for target_persona in priority:
          for kw, persona in KEYWORD_TO_PERSONA.items():
              if persona == target_persona and kw in user_msg:
                  matched_persona = persona
                  matched_keyword = kw
                  break
          if matched_persona:
              break
      
      # QUERY intent: route to user's highest privilege persona
      if not matched_persona:
          for kw in QUERY_KEYWORDS:
              if kw in user_msg:
                  if "approver" in user_personas:
                      matched_persona = "approver"
                  elif "creator" in user_personas:
                      matched_persona = "creator"
                  else:
                      matched_persona = "reviewer"
                  matched_keyword = kw
                  break
      
      # Default
      if not matched_persona:
          matched_persona = DEFAULT_PERSONA
          matched_keyword = "(default)"
      
      state["selected_agent_role"] = matched_persona
      state["parsed_intent"] = f"keyword:{matched_keyword}"
      return state
  
  
  # ===========================================================================
  # permission_check_node
  # ===========================================================================
  
  def permission_check_node(state: HRMSState) -> HRMSState:
      """
      Check if the user has the inferred persona for the selected collection.
      If not, populate state['denial_message'] with a helpful redirect.
      """
      collection = state.get("selected_collection", "HRMS")
      wanted = state.get("selected_agent_role")
      user_personas = (state.get("collection_agents") or {}).get(collection, []) or []
      
      if wanted in user_personas:
          state["has_permission"] = True
          state["denial_message"] = None
          return state
      
      # Build a helpful denial
      state["has_permission"] = False
      
      # Map internal persona to user-facing label (reviewer -> filler)
      label_map = {"creator": "creator", "reviewer": "filler", "approver": "approver"}
      ui_user_personas = [label_map.get(p, p) for p in user_personas]
      ui_wanted = label_map.get(wanted, wanted)
      
      wanted_action = PERSONA_ACTIONS.get(wanted, f"perform {wanted} actions")
      
      if user_personas:
          suggested = user_personas[0]
          suggested_action = PERSONA_ACTIONS.get(suggested, f"perform {suggested} actions")
          state["denial_message"] = (
              f"I see you want to {wanted_action}, "
              f"but you only have {', '.join(ui_user_personas)} access for {collection}. "
              f"Did you want to {suggested_action} instead?"
          )
      else:
          state["denial_message"] = (
              f"You don't have access to {collection}."
          )
      return state
  
  
  # ===========================================================================
  # permission_router
  # ===========================================================================
  
  def permission_router(state: HRMSState) -> str:
      """
      Conditional edge after permission_check.
      Returns one of: 'permission_blocked', 'creator_agent', 'reviewer_agent', 'approver_agent'.
      """
      if not state.get("has_permission"):
          return "permission_blocked"
      
      role = state.get("selected_agent_role")
      if role == "creator":
          return "creator_agent"
      if role == "approver":
          return "approver_agent"
      return "reviewer_agent"  # default for reviewer or unknown
  
  
  # ===========================================================================
  # permission_blocked_node
  # ===========================================================================
  
  def permission_blocked_node(state: HRMSState) -> HRMSState:
      """
      Emit the denial message as an AIMessage and end.
      """
      denial = state.get("denial_message") or "You do not have permission for this action."
      msgs = list(state.get("messages") or [])
      msgs.append(AIMessage(content=denial))
      state["messages"] = msgs
      return state
  
  
