                : <ChevronDown size={13} className="text-slate-400" />}
            </div>
            {isProjectOpen && projectSuggestions.length > 0 && (
              <ul className="absolute z-[200] top-full mt-1 w-full max-h-56 overflow-auto
                bg-white dark:bg-slate-800
