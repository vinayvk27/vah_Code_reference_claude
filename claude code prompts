## FULL CODE — New Node Functions

### `creator_path_router`

```python
def creator_path_router(state: MaterialRequisitionState) -> str:
    """
    Routes to the correct sub-path for the creator persona:
    - excel_handler: user uploaded an Excel file
    - submit_mrr: user confirmed pending MRR submission
    - cancel_mrr: user cancelled pending MRR submission
    - form_flow: existing conversational form path
    """
    last_msg = ""
    msgs = state.get("messages", [])
    for m in reversed(msgs):
        if isinstance(m, HumanMessage):
            last_msg = str(m.content).strip().lower()
            break

    pending = state.get("pending_mrr_data")

    # User just confirmed pending MRR submission
    if pending and last_msg in ("confirm_mrr", "confirm submit", "confirm"):
        return "submit_mrr"

    # User cancelled pending submission
    if pending and last_msg in ("cancel_mrr", "cancel"):
        return "cancel_mrr"

    # Excel uploaded — handle it
    uploaded = state.get("uploaded_files", [])
    if uploaded:
        return "excel_handler"

    # Default — conversational form flow
    return "form_flow"
```

### `excel_handler_node`

```python
def excel_handler_node(state: MaterialRequisitionState) -> dict:
    """
    Handles MRR Excel upload.
    Reads excel_data from state.uploaded_files, validates,
    resolves, and either:
    - On valid: stores in pending_mrr_data, returns summary message
      with confirmation form widget.
    - On invalid: returns error messages.
    """
    from app.services.mrr_validator import validate_and_resolve_mrr_excel

    uploaded_files = state.get("uploaded_files", [])
    if not uploaded_files:
        return {
            "messages": [AIMessage(content=(
                "I didn't see an Excel file in your upload. "
                "Please upload the MRR Excel file."
            ))],
            "execution_log": state.get("execution_log", []) + [
                "Excel handler: no uploaded_files in state."
            ]
        }

    # Find the first Excel file in uploaded_files
    excel_file = None
    for f in uploaded_files:
        if f.get("file_type") == "excel" and f.get("data"):
            excel_file = f
            break

    if not excel_file:
        return {
            "messages": [AIMessage(content=(
                "The file you uploaded is not a valid Excel file. "
                "Please upload a .xlsx file with the MRR data."
            ))],
            "execution_log": state.get("execution_log", []) + [
                "Excel handler: no excel file_type found in uploaded_files."
            ]
        }

    # Build a CurrentUser-like object for the validator
    from app.models.dto_schemas import CurrentUser
    try:
        current_user = CurrentUser(
            emp_no=state.get("emp_no", ""),
            group_idx=state.get("group_idx", 0),
            role_ids=state.get("role_ids", []),
            role_names=state.get("role_names", []),
            dept=state.get("user_dept", "")
        )
    except Exception as e:
        return {
            "messages": [AIMessage(content=(
                f"Could not build user context: {e}"
            ))],
            "execution_log": state.get("execution_log", []) + [
                f"Excel handler: CurrentUser construction failed: {e}"
            ]
        }

    # Call validator
    result = validate_and_resolve_mrr_excel(excel_file["data"], current_user)

    if not result.get("valid"):
        errors = result.get("errors", [])
        error_text = "Your MRR upload has the following issues:\n\n"
        for i, err in enumerate(errors, 1):
            error_text += f"{i}. {err}\n"
        error_text += "\nPlease fix and re-upload the Excel file."
        return {
            "messages": [AIMessage(content=error_text)],
            "execution_log": state.get("execution_log", []) + [
                f"Excel validation failed: {len(errors)} errors."
            ]
        }

    # Valid — emit summary + confirmation form widget
    summary = result.get("summary_for_user", "")
    warnings = result.get("warnings", [])
    warning_text = ""
    if warnings:
        warning_text = "\n\n**Warnings:**\n"
        for w in warnings:
            warning_text += f"- {w}\n"

    # Embed form widget for confirmation
    form_payload = {
        "type": "confirmation",
        "title": "Confirm MRR Submission",
        "fields": [],   # no fields, just confirm/cancel buttons
        "buttons": [
            {"label": "Confirm Submit", "value": "confirm_mrr"},
            {"label": "Cancel", "value": "cancel_mrr"}
        ]
    }
    import json
    form_str = json.dumps(form_payload)
    full_message = (
        summary + warning_text +
        f"\n\nPlease confirm or cancel below:\n\n"
        f"<<FORM>>{form_str}<<ENDFORM>>"
    )

    return {
        "messages": [AIMessage(content=full_message)],
        "pending_mrr_data": result,  # save for confirmation step
        "execution_log": state.get("execution_log", []) + [
            "Excel validated; awaiting user confirmation."
        ]
    }
```

### `mrr_submission_node`

```python
def mrr_submission_node(state: MaterialRequisitionState) -> dict:
    """
    Performs DB inserts for the validated MRR data stored in
    pending_mrr_data. Then routes to auto_verifier_node.
    """
    pending = state.get("pending_mrr_data")
    if not pending or not pending.get("valid"):
        return {
            "messages": [AIMessage(content=(
                "No MRR data to submit. Please upload an Excel file first."
            ))],
            "execution_log": state.get("execution_log", []) + [
                "Submission node: no pending_mrr_data in state."
            ]
        }

    header = pending["header"]
    lines = pending["lines"]

    db = SessionLocal()
    try:
        from app.services.mariadb_queries import (
            get_max_matrequisition_id, get_max_matrequisition_line_id
        )
        next_header_id = get_max_matrequisition_id() + 1
        next_line_id = get_max_matrequisition_line_id() + 1

        # Insert header
        db.execute(text("""
            INSERT INTO mrr_matrequisitionheader (
                MATREQUISITIONID, MATREQUISITIONNO, WAREHOUSEID,
                REQUISITIONTYPE, REQUESTORID, REQUISITIONDATE,
                DEPARTMENTID, NEEDBYDATE, STATUS, PROJECTID,
                PROJECTPHASEID, REQTRANSACTIONTYPE, SUPPLIERID,
                SUPPLIERSITEID, DESCRIPTION, COMMENTS, TOTALCOST
            ) VALUES (
                :mid, :mno, :wh, :rtype, :req, NOW(),
                :dept, :needby, :status, :proj,
                :phase, :rtt, :sup, :supsite, :desc, :comm, :total
            )
        """), {
            "mid": next_header_id,
            "mno": header["mrr_no"],
            "wh": header["warehouse_id"],
            "rtype": header["requisition_type"],
            "req": header["requestor_id"],
            "dept": header["department_id"],
            "needby": header["need_by_date"],
            "status": header["status"],
            "proj": header["project_id"],
            "phase": header["project_phase_id"],
            "rtt": header["req_transaction_type"],
            "sup": header["supplier_id"],
            "supsite": header["supplier_site_id"],
            "desc": header.get("description", ""),
            "comm": header.get("comments", ""),
            "total": header["total_cost"]
        })

        # Insert lines
        for i, line in enumerate(lines):
            db.execute(text("""
                INSERT INTO mrr_matrequisitionlines (
                    MATREQUISITIONLINEID, MATREQUISITIONID, ITEMID,
                    ITEMREVISIONID, UOMID, REQUANTITY, ISSUEQTY,
                    RETURNQUANTITY, STATUS, CLOSEREASON, ITEMCOST,
                    RETURN_DATE
                ) VALUES (
                    :lid, :mid, :iid, :rev, :uom, :qty, 0, 0,
                    'ENTERED', '', :cost, :retdate
                )
            """), {
                "lid": next_line_id + i,
                "mid": next_header_id,
                "iid": line["item_id"],
                "rev": line["item_revision_id"],
                "uom": line["uom_id"],
                "qty": line["requisition_qty"],
                "cost": line["item_cost"],
                "retdate": line.get("return_date")
            })

        db.commit()

        # Update state for auto-verifier
        confirmation = (
            f"Your MRR **{header['mrr_no']}** has been submitted.\n"
            f"Total cost: \u20b9{header['total_cost']:,.2f}\n\n"
            f"Running verification..."
        )

        return {
            "messages": [AIMessage(content=confirmation)],
            "new_requisition_id": next_header_id,
            "pending_mrr_data": None,  # clear
            "execution_log": state.get("execution_log", []) + [
                f"MRR {header['mrr_no']} inserted with id={next_header_id}, "
                f"{len(lines)} line items."
            ]
        }

    except Exception as e:
        db.rollback()
        import traceback
        traceback.print_exc()
        return {
            "messages": [AIMessage(content=(
                f"Submission failed: {str(e)}. "
                "Please try again or contact support."
            ))],
            "execution_log": state.get("execution_log", []) + [
                f"Submission node: insert failed: {e}"
            ]
        }
    finally:
        db.close()
```

