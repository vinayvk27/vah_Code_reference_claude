## NEW FUNCTIONS IN mariadb_queries.py

### a. `resolve_item_from_partno(dp_part_no: str) -> Optional[dict]`

```python
def resolve_item_from_partno(dp_part_no: str) -> Optional[dict]:
    """
    Single lookup against com_search by DP_PART_NO.
    Returns dict with item_id, item_revision_id, uom_name, qoh, price_inr,
    description — or None if no match.
    """
    session = None
    try:
        session = SessionLocal()
        row = session.execute(
            text("""
                SELECT ITEMID, ITEMREVISIONID, UOM, QOH, PRICE, DESCRIPTION
                FROM com_search
                WHERE DP_PART_NO = :pn AND WAREHOUSE = '1'
                LIMIT 1
            """),
            {"pn": dp_part_no},
        ).first()
        if row:
            try:
                qoh = float(row.QOH) if row.QOH else None
            except (ValueError, TypeError):
                qoh = None
            return {
                "item_id": row.ITEMID,
                "item_revision_id": row.ITEMREVISIONID,
                "uom_name": row.UOM,
                "qoh": qoh,
                "price_inr": float(row.PRICE) if row.PRICE is not None else None,
                "description": row.DESCRIPTION or "",
            }
        return None
    except Exception as e:
        logger.warning("resolve_item_from_partno failed for '%s': %s", dp_part_no, e)
        return None
    finally:
        if session:
            session.close()
```

