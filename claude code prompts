def creator_path_router(state: MaterialRequisitionState) -> str:
    """
    Routes to the correct sub-path for the creator persona.
    """
    print(f"[DIAG-MRR] creator_path_router entered. persona={state.get('selected_agent_role')}", flush=True)

    msgs = state.get("messages") or []
    last_msg = ""
    for m in reversed(msgs):
        if isinstance(m, HumanMessage):
            content = getattr(m, "content", None)
            if content is not None:
                last_msg = str(content).strip().lower()
                break

    # Normalize: replace any whitespace runs and underscores so "confirm mrr",
    # "confirm_mrr", "confirm  mrr" all collapse to "confirm mrr".
    normalized = " ".join(last_msg.replace("_", " ").split())

    pending = state.get("pending_mrr_data")
    print(f"[DIAG-MRR] creator_path_router: last_msg={last_msg!r}, normalized={normalized!r}, has_pending={pending is not None}", flush=True)

    confirm_keywords = {"confirm", "confirm mrr", "confirm submit", "yes", "submit", "ok submit"}
    cancel_keywords = {"cancel", "cancel mrr", "no", "discard"}

    # User confirmed pending submission
    if pending and normalized in confirm_keywords:
        print(f"[DIAG-MRR] creator_path_router -> submit_mrr", flush=True)
        return "submit_mrr"

    # User cancelled
    if pending and normalized in cancel_keywords:
        print(f"[DIAG-MRR] creator_path_router -> cancel_mrr", flush=True)
        return "cancel_mrr"

    # Excel uploaded
    uploaded = state.get("uploaded_files") or []
    if uploaded:
        print(f"[DIAG-MRR] creator_path_router -> excel_handler", flush=True)
        return "excel_handler"

    # No files and no confirm/cancel — ask user to upload Excel
    # (form_flow is currently broken for this case; bypass it)
    print(f"[DIAG-MRR] creator_path_router -> creator_needs_file", flush=True)
    return "creator_needs_file"


def excel_handler_node(state: MaterialRequisitionState) -> dict:
    """Handles MRR Excel upload."""
    print(f"[DIAG-MRR] excel_handler_node entered. emp_no={state.get('emp_no')}", flush=True)

    from app.services.mrr_validator import validate_and_resolve_mrr_excel

    uploaded_files = state.get("uploaded_files") or []
    
    # Safer way to handle potential empty list in diagnostics
    first_file = uploaded_files[0] if uploaded_files else None
    print(f"[DIAG-MRR] excel_handler_node: first file keys={list(first_file.keys()) if first_file else 'none'}, file={first_file}", flush=True)

    if not uploaded_files:
        return {
            "messages": [AIMessage(content=(
                "I didn't see an Excel file in your upload. Please upload the MRR Excel file."
            ))],
            "execution_log": (state.get("execution_log") or []) + [
                "Excel handler: no uploaded_files in state."
            ]
        }

    excel_file = None
    for f in uploaded_files:
        if not f:
            continue
        if f.get("file_type") == "excel" and f.get("data"):
            excel_file = f
            break

    print(f"[DIAG-MRR] excel_handler_node: excel_file found={excel_file is not None}", flush=True)

    if not excel_file:
        return {
            "messages": [AIMessage(content=(
                "The file you uploaded is not a valid Excel file. Please upload a .xlsx file with the MRR data."
            ))],
            "execution_log": (state.get("execution_log") or []) + [
                "Excel handler: no excel file_type found in uploaded_files."
            ]
        }

    from app.models.dto_schemas import CurrentUser
    try:
        current_user = CurrentUser(
            emp_no=state.get("emp_no") or "",
            name=state.get("user_info", {}).get("name", "") if state.get("user_info") else "",
            email=state.get("user_info", {}).get("email", "") if state.get("user_info") else "",
            hierarchy=state.get("user_info", {}).get("hierarchy", {}) if state.get("user_info") else {},
            group_idx=state.get("group_idx") or 0,
            role_ids=state.get("role_ids") or [],
            role_names=state.get("role_names") or [],
            dept=state.get("user_dept") or ""
        )
    except Exception as e:
        import traceback
        traceback.print_exc()
        return {
            "messages": [AIMessage(content=f"Could not build user context: {e}")],
            "execution_log": (state.get("execution_log") or []) + [
                f"Excel handler: CurrentUser construction failed: {e}"
            ]
        }

    print(f"[DIAG-MRR] excel_handler_node: calling validator with {len(excel_file['data'])} rows", flush=True)

    try:
        result = validate_and_resolve_mrr_excel(excel_file["data"], current_user)
    except Exception as e:
        import traceback
        traceback.print_exc()
        return {
            "messages": [AIMessage(content=f"Validator error: {e}")],
            "execution_log": (state.get("execution_log") or []) + [
                f"Excel handler: validator threw: {e}"
            ]
        }

    print(f"[DIAG-MRR] excel_handler_node: validator returned valid={result.get('valid')}", flush=True)

    if not result.get("valid"):
        errors = result.get("errors", [])
        error_text = "Your MRR upload has the following issues:\n\n"
        for i, err in enumerate(errors, 1):
            error_text += f"{i}. {err}\n"
        error_text += "\nPlease fix and re-upload the Excel file."
        return {
            "messages": [AIMessage(content=error_text)],
            "execution_log": (state.get("execution_log") or []) + [
                f"Excel validation failed: {len(errors)} errors."
            ]
        }

    summary = result.get("summary_for_user", "")
    warnings = result.get("warnings", [])
    warning_text = ""
    if warnings:
        warning_text = "\n\n**Warnings:**\n"
        for w in warnings:
            warning_text += f"- {w}\n"

    form_payload = {
        "type": "confirmation",
        "title": "Confirm MRR Submission",
        "fields": [],
        "buttons": [
            {"label": "Confirm Submit", "value": "confirm_mrr"},
            {"label": "Cancel", "value": "cancel_mrr"}
        ]
    }
    import json
    form_str = json.dumps(form_payload)
    full_message = (
        summary + warning_text +
        f"\n\nPlease confirm or cancel below:\n\n"
        f"<<FORM>>{form_str}<<ENDFORM>>"
    )

    return {
        "messages": [AIMessage(content=full_message)],
        "pending_mrr_data": result,
        "execution_log": (state.get("execution_log") or []) + [
            "Excel validated; awaiting user confirmation."
        ]
    }


def mrr_submission_node(state: MaterialRequisitionState) -> dict:
    """
    Performs DB inserts for the validated MRR data stored in
    pending_mrr_data. Then routes to auto_verifier_node.
    """
    print(f"[DIAG-MRR] mrr_submission_node entered. has_pending_data={state.get('pending_mrr_data') is not None}", flush=True)
    pending = state.get("pending_mrr_data")
    if not pending or not pending.get("valid"):
        return {
            "messages": [AIMessage(content=(
                "No MRR data to submit. Please upload an Excel file first."
            ))],
            "execution_log": state.get("execution_log", []) + [
                "Submission node: no pending_mrr_data in state."
            ]
        }

    header = pending["header"]
    lines = pending["lines"]

    db = SessionLocal()
    try:
        from app.services.mariadb_queries import (
            get_max_matrequisition_id, get_max_matrequisition_line_id
        )
        next_header_id = get_max_matrequisition_id() + 1
        next_line_id = get_max_matrequisition_line_id() + 1

        # Insert header
        db.execute(text("""
            INSERT INTO mrr_matrequisitionheader (
                MATREQUISITIONID, MATREQUISITIONNO, WAREHOUSEID,
                REQUISITIONTYPE, REQUESTORID, REQUISITIONDATE,
                DEPARTMENT, NEEDBYDATE, STATUS, PROJECTID,
                PROJECTPHASEID, REQTRANSACTIONTYPE, SUPPLIERID,
                SUPPLIERSITEID, DESCRIPTION, COMMENTS, TOTAL_COST
            ) VALUES (
                :mid, :mno, :wh, :rtype, :req, NOW(),
                :dept, :needby, :status, :proj,
                :phase, :rtt, :sup, :supsite, :desc, :comm, :total
            )
        """), {
            "mid": next_header_id,
            "mno": header["mrr_no"],
            "wh": header["warehouse_id"],
            "rtype": header["requisition_type"],
            "req": header["requestor_id"],
            "dept": header["department"],
            "needby": header["need_by_date"],
            "status": header["status"],
            "proj": header["project_id"],
            "phase": header["project_phase_id"],
            "rtt": header["req_transaction_type"],
            "sup": header["supplier_id"],
            "supsite": header["supplier_site_id"],
            "desc": header.get("description", ""),
            "comm": header.get("comments", ""),
            "total": header["total_cost"]
        })

        # Insert lines
        for i, line in enumerate(lines):
            db.execute(text("""
                INSERT INTO mrr_matrequisitionlines (
                    MATREQUISITIONLINEID, MATREQUISITIONID, ITEMID,
                    ITEMREVISIONID, UOMID, REQUISITIONQTY, ISSUEQTY,
                    RETURNQUANTITY, STATUS, CLOSEREASON, ITEMCOST,
                    RETURN_DATE
                ) VALUES (
                    :lid, :mid, :iid, :rev, :uom, :qty, 0, 0,
                    'ENTERED', '', :cost, :retdate
                )
            """), {
                "lid": next_line_id + i,
                "mid": next_header_id,
                "iid": line["item_id"],
                "rev": line["item_revision_id"],
                "uom": line["uom_id"],
                "qty": line["requisition_qty"],
                "cost": line["item_cost"],
                "retdate": line.get("return_date")
            })

        db.commit()

        # Update state for auto-verifier
        confirmation = (
            f"Your MRR **{header['mrr_no']}** has been submitted.\n"
            f"Total cost: \u20b9{header['total_cost']:,.2f}\n\n"
            f"Running verification..."
        )

        return {
            "messages": [AIMessage(content=confirmation)],
            "new_requisition_id": next_header_id,
            "pending_mrr_data": None,  # clear
            "execution_log": state.get("execution_log", []) + [
                f"MRR {header['mrr_no']} inserted with id={next_header_id}, "
                f"{len(lines)} line items."
            ]
        }

    except Exception as e:
        db.rollback()
        import traceback
        traceback.print_exc()
        return {
            "messages": [AIMessage(content=(
                f"Submission failed: {str(e)}. "
                "Please try again or contact support."
            ))],
            "execution_log": state.get("execution_log", []) + [
                f"Submission node: insert failed: {e}"
            ]
        }
    finally:
        db.close()


