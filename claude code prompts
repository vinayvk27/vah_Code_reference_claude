  const inputError = [
    inputBase,
    'border-red-400 dark:border-red-500/70',
    'focus:border-red-400 focus:ring-red-400/15',
  ].join(' ');

  const labelBase = [
    'block font-semibold uppercase tracking-widest',
    'text-slate-500 dark:text-slate-400',
    sz.label,
  ].join(' ');

  // ── Field Renderer ─────────────────────────────────────────────────────────
  const renderField = (field) => {
    const error = getError(field.name);
    const cls = error ? inputError : inputBase;

    // Project autocomplete
    if (field.name === 'project_id' && field.type === 'text') {
      return (
        <div key={field.name}>
          <label className={labelBase}>
            {field.label}
            {field.required && <span className="inline-block w-1 h-1 rounded-full bg-blue-500 ml-1 mb-0.5 align-middle" />}
