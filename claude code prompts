from fastapi import Depends, HTTPException, status
from fastapi.security import OAuth2PasswordBearer
from app.core.security import decode_access_token
from app.models.dto_schemas import CurrentUser

oauth2_scheme = OAuth2PasswordBearer(tokenUrl="/api/v1/auth/login")


def get_current_user(token: str = Depends(oauth2_scheme)) -> CurrentUser:
    """
    FastAPI dependency that extracts, decodes, and validates the Bearer token.
    Returns a CurrentUser Pydantic model for type-safe access in route handlers.
    """
    payload = decode_access_token(token)
    if not payload:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Invalid or expired token",
        )
    return CurrentUser(
        emp_no=payload["sub"],
        group_idx=payload["group_idx"],
        role_ids=payload["role_ids"],
        role_names=payload["role_names"],
        name=payload["name"],
        email=payload["email"],
        dept=payload["dept"],
        hierarchy=payload["hierarchy"],
    )

