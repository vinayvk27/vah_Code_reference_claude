    "required": true,
    "options": [
      {"value": "returnable", "label": "Returnable"},
      {"value": "non_returnable", "label": "Non-Returnable"}
    ],
    "default": "returnable"
  }

Add a radio renderer in the scalar fields section alongside the existing 
select/text/textarea/checkbox handlers:

  } else if (field.type === 'radio') {
    inputElement = (
      <div className="flex flex-wrap gap-2 pt-0.5">
