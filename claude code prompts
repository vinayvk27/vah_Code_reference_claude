from app.workflows.rms_workflow.intent import classify_rms_intent

test_messages = [
    "show my tasks",
    "log 4 hours today on task 1",
    "create a task for project 5",
    "create a task for myself, project 100, product 10, task index 5, activity 1, from 2026-05-25 to 2026-05-30, planned 16 hours",
    "log 8 hours on task 1 for 2026-05-26 with remark design work",
    "show pending approvals",
    "approve worklog 5",
    "tell me a joke",
    "could you release it",
]

for msg in test_messages:
    result = classify_rms_intent(msg)
    print(f"\n--- {msg!r}")
    print(f"  domain={result.domain}, collection={result.collection!r}, persona={result.persona!r}, confidence={result.confidence}")
    print(f"  reasoning: {result.reasoning}")