# app/core/llm.py
from langchain_openai import ChatOpenAI

from app.core.config import settings


def get_llm() -> ChatOpenAI:
    """
    Returns a ChatOpenAI instance configured with the internal LLM API.

    Uses the AI_API_URL as base_url and AI_API_KEY from settings.
    Streaming is enabled for real-time token streaming.
    """
    return ChatOpenAI(
        model=settings.AI_MODEL,
        base_url=settings.AI_API_URL,
        api_key=settings.AI_API_KEY,
        streaming=True,
    )
