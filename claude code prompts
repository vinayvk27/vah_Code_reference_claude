def get_llm_non_streaming() -> ChatOpenAI:
    """
    Returns a non-streaming ChatOpenAI instance configured with the internal LLM API.

    Used for structured-output calls (e.g., intent classifiers) where streaming
    is unnecessary and triggers a known pydantic/openai version-mismatch bug
    (TypeError: argument 'by_alias': 'NoneType' object cannot be converted to 'PyBool').
    """
    return ChatOpenAI(
        model=settings.AI_MODEL,
        base_url=settings.AI_API_URL,
        api_key=settings.AI_API_KEY,
        streaming=False,
    )

from app.core.llm import get_llm_non_streaming

llm = get_llm_non_streaming()