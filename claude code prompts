# ============================================================
# RMS Demo Tables (Dev copies - never touch production data)
# ============================================================
class PpTaskAssignment(Base):
    """Demo table for task assignments - pp_project_task_assigment_demo"""
    __tablename__ = "pp_project_task_assigment_demo"

    WorkLogIdx = Column(Integer, primary_key=True, autoincrement=True)
    Resource = Column(Integer, nullable=False)
    PlanIdx = Column(Integer)
    ProjectIdx = Column(Integer)
    ProductIdx = Column(Integer)
    TaskIdx = Column(Integer)
    ActivityIdx = Column(Integer)
    StartDate = Column(Date)
    EndDate = Column(Date)
    PlanHrs = Column(Float)
    IsCompleted = Column(SmallInteger, default=0)
    created_by = Column(String(10))
    created_date = Column(Date)


class PpWorklog(Base):
    """Demo table for worklogs - pp_worklogs_demo"""
    __tablename__ = "pp_worklogs_demo"

    Idx = Column(Integer, primary_key=True, autoincrement=True)
    WorkLogIdx = Column(Integer, nullable=False)
    TaskDate = Column(Date)
    TimeSpentInSec = Column(Integer)
    DateOfEntry = Column(Date)
    IsApproved = Column(Integer, nullable=True)  # NULL=pending, 1=approved, 0=rejected
    ApprovedBy = Column(Integer)
    ApprovedDate = Column(Date)
    UserRemarks = Column(Text)
    ApproverRemarks = Column(Text)
    Resource = Column(Integer)
