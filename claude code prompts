            <p className="text-[12px] font-semibold text-emerald-400">{formSpec.title} submitted</p>
            <p className="text-[11px] text-slate-500 dark:text-slate-400">Your request has been sent for review.</p>
          </div>
        </div>
      )}

      {/* ── Cancelled ── */}
      {formSpec.status === 'cancelled' && (
        <p className="text-[11px] text-slate-400 dark:text-slate-500 italic">Request cancelled.</p>
      )}

      {/* ── Form ── */}
      {!formSpec.status && (
        <form onSubmit={handleSubmit} className={`flex flex-col ${sz.gap}`}>

          {/* Global error */}
          {formErrors && Object.keys(formErrors).length > 0 && (
            <div className="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-medium
              bg-red-50 dark:bg-red-500/10 text-red-500 dark:text-red-400
