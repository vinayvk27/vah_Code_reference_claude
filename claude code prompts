# After authorization check, before list-display:
last_user_msg = _get_last_user_message(state.get("messages", []))
cmd = _parse_approval_command(last_user_msg)

if cmd["action"] in ("approve_one", "reject_one"):
    mrr_id = cmd["mrr_id"]
    action = cmd["action"]
    db = SessionLocal()
    try:
        verify = db.execute(text("""
            SELECT MATREQUISITIONID, MATREQUISITIONNO, APPROVAL_STATUS
            FROM mrr_matrequisitionheader
            WHERE MATREQUISITIONID = :id AND APPROVAL_STATUS = 'PENDING'
        """), {"id": mrr_id}).mappings().first()
        if not verify:
            return {"messages": [AIMessage(content=f"MRR with ID {mrr_id} not found...")]}
        if action == "approve_one":
            db.execute(text("""UPDATE mrr_matrequisitionheader
                SET APPROVAL_STATUS='APPROVED', APPROVAL_DATE=NOW(),
                    ERP_APPROVAL_STATUS='PENDING'
                WHERE MATREQUISITIONID=:id AND APPROVAL_STATUS='PENDING'
            """), {"id": mrr_id})
            db.commit()
            return {"messages": [AIMessage(content=f"Approved {mrr_no}. It has been forwarded to ERP for final approval.")]}
        else:
            db.execute(text("""UPDATE mrr_matrequisitionheader
                SET APPROVAL_STATUS='REJECTED', APPROVAL_DATE=NOW()
                WHERE MATREQUISITIONID=:id AND APPROVAL_STATUS='PENDING'
            """), {"id": mrr_id})
            db.commit()
            return {"messages": [AIMessage(content=f"Rejected {mrr_no}.")]}
    except Exception as e:
        db.rollback()
        return {"messages": [AIMessage(content=f"Error processing approval: {e}")]}
    finally:
        db.close()
elif cmd["action"] == "approve_all":
    db = SessionLocal()
    try:
        result = db.execute(text("""UPDATE mrr_matrequisitionheader
            SET APPROVAL_STATUS='APPROVED', APPROVAL_DATE=NOW(),
                ERP_APPROVAL_STATUS='PENDING'
            WHERE APPROVAL_STATUS='PENDING'
        """))
        db.commit()
        rowcount = result.rowcount
        if rowcount == 0:
            return {"messages": [AIMessage(content="There are no pending MRRs to approve.")]}
        return {"messages": [AIMessage(content=f"Approved {rowcount} pending MRRs. They have been forwarded to ERP for final approval.")]}
    except Exception as e:
        db.rollback()
        return {"messages": [AIMessage(content=f"Error processing approve all: {e}")]}
    finally:
        db.close()
# Falls through to existing list-display for "list" action
