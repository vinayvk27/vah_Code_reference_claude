  """
  Form Spec Registry
  ==================
  Maps form_id strings to the tool functions that handle their submission.
  Tools add forms to this registry; chat_controller looks up by form_id.
  """
  
  from typing import Callable, Dict, Any
  
  # form_id -> {"handler": callable, "collection": str, "required_persona": str}
  FORM_REGISTRY: Dict[str, Dict[str, Any]] = {}
  
  
  def register_form(form_id: str, handler: Callable, collection: str, required_persona: str):
      """
      Register a form's submission handler.
      
      Args:
          form_id: unique form identifier (e.g., "hrms_apply_leave")
          handler: callable that takes (form_data: dict, user_context: dict) -> str
          collection: collection that owns this form (e.g., "HRMS")
          required_persona: persona required to submit this form (e.g., "reviewer")
      """
      FORM_REGISTRY[form_id] = {
          "handler": handler,
          "collection": collection,
          "required_persona": required_persona,
      }
  
  
  def get_form_handler(form_id: str) -> Dict[str, Any]:
      """Returns the registered form info, or None if not found."""
      return FORM_REGISTRY.get(form_id)
  
  
  def list_forms() -> Dict[str, Dict[str, Any]]:
      """Debug: list all registered forms."""
      return dict(FORM_REGISTRY)

