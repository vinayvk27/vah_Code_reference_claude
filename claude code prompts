## NEW: `_repair_classifier_json` function (lines 200–236)

```python
def _repair_classifier_json(raw_text: str):
    """
    Attempt to repair common LLM JSON malformations.
    Returns dict if successful, None otherwise.
    """
    if not raw_text:
        return None

    # Strip markdown fences
    text = raw_text.strip()
    if text.startswith("```"):
        text = re.sub(r'^```(?:json)?\s*', '', text)
        text = re.sub(r'\s*```\s*$', '', text)

    # Extract just the JSON object
    first_brace = text.find('{')
    last_brace = text.rfind('}')
    if first_brace == -1 or last_brace == -1 or last_brace < first_brace:
        return None
    text = text[first_brace:last_brace + 1]

    # Fix duplicate keys: "X": "X": "value"  ->  "X": "value"
    text = re.sub(r'"(\w+)":\s*"\1"\s*:', r'"\1":', text)

    # Fix double-value-for-one-key: "X": "A", "B" (keep first value)
    text = re.sub(
        r'"(\w+)":\s*"([^"]+)",\s*"([^"]+)"(\s*[,}])',
        r'"\1": "\2"\4',
        text
    )

    try:
        return json.loads(text)
    except json.JSONDecodeError:
        return None
```

