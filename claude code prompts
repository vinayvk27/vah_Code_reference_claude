from app.dao.database import SessionLocal
from sqlalchemy import text

session = SessionLocal()
row = session.execute(text("SELECT ITEMID, ITEMREVISIONID, UOM, QOH, PRICE, DESCRIPTION FROM com_search WHERE DP_PART_NO = 'DP-RM-CSY-22632' AND WAREHOUSE = '1' LIMIT 1")).first()
print("ROW:", row)
print("QOH:", repr(row.QOH) if row else "no row")
print("PRICE:", repr(row.PRICE) if row else "no row")
session.close()