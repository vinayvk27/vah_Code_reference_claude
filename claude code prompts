for i, row in enumerate(data_rows, start=1):
    item_name = item_names[i - 1]
    qty = quantities[i - 1]
    return_date = row_return_dates[i - 1]

    # Per-line resolution (new):
    res = mariadb_queries.resolve_item_from_partno(item_name)
    if res is None:
        errors.append(f"Item '{item_name}' not found.")
        continue  # skip this line

    item_id = res["item_id"]
    item_revision_id = res["item_revision_id"]
    uom_name = res["uom_name"]
    qoh = res["qoh"]

    # Get numeric UOMID and LPP from SCMITEMS:
    uom_id = mariadb_queries.get_item_uomid(item_id)
    if uom_id is None:
        warnings.append(f"UOMID not found for item '{item_name}'; using 0.")
        uom_id = 0

    lpp_rate = mariadb_queries.get_item_lpp(item_id)
    if lpp_rate is None or lpp_rate == 0:
        warnings.append(f"LPP unavailable for '{item_name}'; cost calculated as 0.")
        lpp_rate = 0.0

    item_cost = lpp_rate * (qty or 0)
    total_cost += item_cost

    line = {
        "item_id": item_id,
        "item_name": item_name,
        "item_revision_id": item_revision_id,
        "uom_id": uom_id,
        "uom_name": uom_name,
        "requisition_qty": qty,
        "lpp_rate": float(lpp_rate),
        "item_cost": round(item_cost, 2),
        "available_quantity": qoh if qoh is not None else "unknown",
        "return_date": return_date.isoformat() if return_date else None,
    }
    lines.append(line)
```

