def creator_needs_file_node(state: MaterialRequisitionState) -> dict:
    """
    Terminal node: emitted when a creator tries to create an MRR
    without uploading an Excel file.  The form_flow path is
    currently broken for this case, so we short-circuit with a
    friendly message instead.
    """
    print(f"[DIAG-MRR] creator_needs_file_node entered.", flush=True)
    msg = (
        "To create a material requisition, please upload an Excel file with these columns: "
        "Project Number, Requisition Type, Need By Date, Description, Comments, "
        "Item Name, Requested Quantity, Return Date.\n\n"
        "Once uploaded, type 'process this mrr' and I'll handle the rest."
    )
    return {
        "messages": [AIMessage(content=msg)],
        "execution_log": state.get("execution_log", []) + [
            "Creator needs file: no uploaded_files; redirected to instructions."
        ]
    }
