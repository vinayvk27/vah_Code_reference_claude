INSERT INTO dpah_role_agent_access (role_id, group_id, agent_id, granted_by, granted_at)
SELECT 7, 1, agent_id, 'system', NOW()
FROM dpah_agents
WHERE agent_name IN ('HRMS_LEAVE_DATA_REVIEWER', 'HRMS_SALARYDATA_REVIEWER')
  AND NOT EXISTS (
    SELECT 1 FROM dpah_role_agent_access r
    WHERE r.role_id = 7 AND r.group_id = 1 AND r.agent_id = dpah_agents.agent_id
  );