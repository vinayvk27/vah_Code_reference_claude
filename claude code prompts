import re

def _normalize(message: str) -> str:
    """Lowercase, strip leading/trailing whitespace, collapse internal whitespace."""
    if not message:
        return ""
    text = message.lower().strip()
    # Replace common punctuation with spaces so word-boundary matches work
    text = re.sub(r"[,.;:!?'\"()\\[\\]{}]+", " ", text)
    text = re.sub(r"\\s+", " ", text)
    return text


# Keyword lists — ordered by priority (more specific first).

OUT_OF_DOMAIN_KEYWORDS = [
    "weather", "joke", "salary", "leave", "payslip",
    "hello", "hi there", "good morning", "good evening",
    "who are you", "what can you do", "help me",
]

ISSUER_KEYWORDS = [
    "issue stock", "issue material", "issue items",
    "stock issue", "release stock", "release to floor",
    "ready for issue", "items to issue", "pending issue",
]

ERP_APPROVER_KEYWORDS = [
    "erp approve", "erp approval", "erp pending",
    "show erp approvals", "show erp pending", "erp queue",
    "approve from erp", "final approval", "final approve",
    "ready for erp", "release to erp",
]

APPROVER_KEYWORDS = [
    "approve all", "approve pending",
    "show pending approvals", "show pending approval",
    "show approvals", "pending approvals", "approval queue",
    "reject", "approve mrr", "approve requisition",
    "approve ", "decline ",
    # Note: bare "approve" is risky; matched only when followed by id or noun
]

CREATOR_KEYWORDS = [
    "create mrr", "create requisition",
    "new mrr", "new requisition",
    "raise mrr", "raise requisition",
    "submit mrr", "submit requisition",
    "upload mrr", "process mrr",
    "process this mrr", "process this excel",
    "process this file", "upload material requisition",
    "process file", "import this",
]


def classify_mrr_intent(user_message: str) -> <SAME_PYDANTIC_MODEL_AS_BEFORE>:
    """
    Keyword-based intent classifier for MRR.
    No LLM call — deterministic.
    """
    text = _normalize(user_message)

    if not text:
        return _build_out_of_domain("Empty message")

    # Step 1: Out-of-domain check (so unrelated requests are rejected).
    for kw in OUT_OF_DOMAIN_KEYWORDS:
        if kw in text:
            return _build_out_of_domain(f"Matched out-of-domain keyword: {kw}")

    # Step 2: ERP approver (most specific).
    for kw in ERP_APPROVER_KEYWORDS:
        if kw in text:
            return _build_in_domain(
                collection="mrr_general",
                persona="erp_approver",
                confidence="HIGH",
                reasoning=f"Matched ERP approver keyword: {kw}",
            )

    # Step 3: Issuer.
    for kw in ISSUER_KEYWORDS:
        if kw in text:
            return _build_in_domain(
                collection="mrr_general",
                persona="issuer",
                confidence="HIGH",
                reasoning=f"Matched issuer keyword: {kw}",
            )

    # Step 4: Approver (manager).
    for kw in APPROVER_KEYWORDS:
        if kw in text:
            return _build_in_domain(
                collection="mrr_general",
                persona="approver",
                confidence="HIGH",
                reasoning=f"Matched approver keyword: {kw}",
            )

    # Step 5: Creator.
    for kw in CREATOR_KEYWORDS:
        if kw in text:
            return _build_in_domain(
                collection="mrr_general",
                persona="creator",
                confidence="HIGH",
                reasoning=f"Matched creator keyword: {kw}",
            )

    # Step 6: Default — assume creator (low confidence) for any
    # MRR-context message that didn't match other personas. The
    # permission check downstream will handle whether the user
    # actually has creator access.
    return _build_in_domain(
        collection="mrr_general",
        persona="creator",
        confidence="LOW",
        reasoning="No keyword matched; defaulting to creator (lowest-privilege).",
    )


def _build_in_domain(collection: str, persona: str, confidence: str, reasoning: str):
    """Build the Pydantic classification object for an IN_DOMAIN match."""
    # Use the exact Pydantic class name and fields that the existing
    # classify function returned. Inspect the current intent.py and
    # match exactly.
    return <PydanticModelName>(
        domain="IN_DOMAIN",
        collection=collection,
        persona=persona,
        confidence=confidence,
        reasoning=reasoning,
    )


def _build_out_of_domain(reasoning: str):
    return <PydanticModelName>(
        domain="OUT_OF_DOMAIN",
        collection="",
        persona="",
        confidence="HIGH",
        reasoning=reasoning,
    )

