## Part C — permission_check_node Before/After

### Before (3 separate hardcoded if-blocks):
```python
from app.workflows.material_workflow.approvers import (
    is_manager_approver, is_erp_approver, is_issuer
)

if selected_agent_role == "approver":
    if not is_manager_approver(emp_no):
        return {"has_permission": False, "denial_message": "Manager approval is restricted to the COO and CTO..."}
    return {"has_permission": True, ...}

if selected_agent_role == "erp_approver":
    if not is_erp_approver(emp_no):
        return {"has_permission": False, "denial_message": "ERP approval is restricted to the ERP HOD..."}
    return {"has_permission": True, ...}

if selected_agent_role == "issuer":
    if not is_issuer(emp_no):
        return {"has_permission": False, "denial_message": "The store issuance feature is not yet active."}
    return {"has_permission": True, ...}
```

### After (unified Gate 2 DB check):
```python
if selected_agent_role in ("approver", "erp_approver", "issuer"):
    collection_suffix = selected_collection.upper().replace("MRR_", "")
    expected_agent_name = f"MRR_{collection_suffix}_{selected_agent_role.upper()}"

    db = SessionLocal()
    try:
        from app.models.db_schema import Agent

        agent_row = db.query(Agent).filter(
            Agent.agent_name == expected_agent_name,
            Agent.is_active == 1
        ).first()

        if not agent_row:
            return {"has_permission": False, "denial_message": f"The {selected_agent_role} role for {selected_collection} is unavailable.", ...}

        agent_or_none = AuthController.check_agent_access(
            emp_no=emp_no,
            group_idx=group_idx,
            role_ids=role_ids,
            agent_id=agent_row.agent_id,
            db=db
        )

        if agent_or_none is None:
            return {"has_permission": False, "denial_message": f"You don't have {selected_agent_role.lower()} permissions for this module.", ...}

        return {"has_permission": True, "denial_message": None, ...}
    finally:
        db.close()
```

This is the same pattern already used for `creator` and `pl_approver`. All 5 roles now share the same DB-driven Gate 2 check.

