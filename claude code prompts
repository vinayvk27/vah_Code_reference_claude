    CreatedDate = Column(Date)

class HrLeaveRequest(Base):
    __tablename__ = "hr_leave_requests_demo"
    RequestIdx = Column(Integer, primary_key=True, autoincrement=True)
    Resource = Column(Integer, nullable=False)
    LeaveTypeIdx = Column(Integer, nullable=False)
    FromDate = Column(Date, nullable=False)
    ToDate = Column(Date, nullable=False)
    NumDays = Column(Integer, nullable=False)
    Reason = Column(String(500))
    IsApproved = Column(Integer, nullable=True)
    ApprovedBy = Column(Integer, nullable=True)
    ApprovedDate = Column(Date, nullable=True)
    ApproverRemarks = Column(String(500))
    CreatedDate = Column(Date)

class HrPayslip(Base):
    __tablename__ = "hr_payslips_demo"
    PayslipIdx = Column(Integer, primary_key=True, autoincrement=True)
    Resource = Column(Integer, nullable=False)
    PayMonth = Column(String(7), nullable=False)
    Basic = Column(Float)
    Allowances = Column(Float)
    Deductions = Column(Float)
    NetPay = Column(Float)
    CreatedBy = Column(String(10))
    CreatedDate = Column(Date)

