def parse_intent_node(state: MaterialRequisitionState) -> dict:
    """
    Node 1: Classify user intent using LLM classifier.
    Returns domain, collection, persona, confidence, and reasoning.
    """
    print(f"[DIAG-MRR] parse_intent_node entered. emp_no={state.get('emp_no')}, pending_mrr_data_present={state.get('pending_mrr_data') is not None}, message_count={len(state.get('messages', []))}", flush=True)
    messages = state.get("messages", [])

    # Find the last user message
    last_user_message = ""
    for msg in reversed(messages):
        if isinstance(msg, HumanMessage):
            last_user_message = str(msg.content)
            break

    if not last_user_message:
        return {
            "parsed_intent": "OUT_OF_DOMAIN",
            "selected_collection": "",
            "selected_agent_role": "",
            "classifier_confidence": "LOW",
            "append_soft_correction": False,
            "execution_log": state.get("execution_log", []) + ["No user message found."]
        }

    # Short-circuit: if the message is a form_submit JSON payload,
    # bypass the keyword classifier and route straight to creator.
    # The form_submit handler will validate the payload.
    form_submit_payload = _parse_form_submit_message(last_user_message)
    if form_submit_payload is not None:
        return {
            "parsed_intent": "IN_DOMAIN",
            "selected_collection": "mrr_general",
            "selected_agent_role": "creator",
            "classifier_confidence": "HIGH",
            "append_soft_correction": False,
            "execution_log": state.get("execution_log", []) + [
                "Form submit detected; bypassing keyword classifier."
            ]
        }

    from app.workflows.material_workflow.intent import classify_mrr_intent
    classification = classify_mrr_intent(last_user_message)

    append_soft_correction = (
        classification.domain == "IN_DOMAIN"
        and classification.confidence in ("MEDIUM", "LOW")
    )

    return {
        "parsed_intent": classification.domain,
        "selected_collection": classification.collection,
        "selected_agent_role": classification.persona.lower() if classification.persona else "",
        "classifier_confidence": classification.confidence,
        "append_soft_correction": append_soft_correction,
        "execution_log": state.get("execution_log", []) + [
            f"Intent classified: domain={classification.domain}, "
            f"collection={classification.collection}, "
            f"persona={classification.persona}, "
            f"confidence={classification.confidence}, "
            f"reasoning={classification.reasoning}"
        ]
    }


def permission_check_node(state: MaterialRequisitionState) -> dict:
    """
    Node 2: Check user permissions.
    OUT_OF_DOMAIN requests short-circuit with a denial message,
    EXCEPT when pending_mrr_data exists — then we bypass and route
    to creator so confirm/cancel can be handled.
    For IN_DOMAIN CREATOR persona, looks up agent in DB and checks Gate 2.
    For APPROVER, ERP_APPROVER, ISSUER personas, authority is by emp_no
    (hardcoded in approvers.py), not by role/group mapping.
    """
    print(f"[DIAG-MRR] permission_check_node entered. parsed_intent={state.get('parsed_intent')}, persona={state.get('selected_agent_role')}, collection={state.get('selected_collection')}", flush=True)

    from app.controllers.auth_controller import AuthController
    from app.workflows.material_workflow.approvers import (
        is_manager_approver, is_erp_approver, is_issuer
    )

    parsed_intent = state.get("parsed_intent", "")
    selected_agent_role = state.get("selected_agent_role", "")
    selected_collection = state.get("selected_collection", "")
    emp_no = state.get("emp_no", "")
    group_idx = state.get("group_idx", 0)
    role_ids = state.get("role_ids", [])

    execution_log = state.get("execution_log", [])

    # If user has a pending MRR submission, bypass OUT_OF_DOMAIN classification.
    # Their message is presumed to be confirm/cancel context for the pending op.
    pending = state.get("pending_mrr_data")
    if parsed_intent == "OUT_OF_DOMAIN" and pending:
        execution_log.append("Out-of-domain bypassed because pending_mrr_data exists; treating as creator path.")
        return {
            "has_permission": True,
            "denial_message": None,
            "selected_agent_role": "creator",
            "selected_collection": "mrr_general",
            "execution_log": execution_log
        }

    # OUT_OF_DOMAIN short-circuits (no pending data)
    if parsed_intent == "OUT_OF_DOMAIN":
        execution_log.append("Out-of-domain request; routing to blocked node.")
        return {
            "has_permission": False,
            "denial_message": (
                "I can only help with MRR tasks like creating material "
                "requisitions, approving requests, and issuing stock. "
                "Could you rephrase your request?"
            ),
            "execution_log": execution_log
        }

    # IN_DOMAIN: validate classifier output
    if not selected_collection or not selected_agent_role:
        execution_log.append("Classifier returned incomplete result; denying.")
        return {
            "has_permission": False,
            "denial_message": (
                "I wasn't able to understand your request. "
                "Could you rephrase it?"
            ),
            "execution_log": execution_log
        }

    # APPROVER, ERP_APPROVER, ISSUER: bypass Gate 2 DB check.
    # Authority for these is by emp_no, not by role/group mapping.
    if selected_agent_role == "approver":
        if not is_manager_approver(emp_no):
            execution_log.append(
                f"Approver denied: emp_no {emp_no} not in MANAGER_APPROVERS list."
            )
            return {
                "has_permission": False,
                "denial_message": (
                    "Manager approval is restricted to the COO and CTO. "
                    "If you believe this is an error, contact your administrator."
                ),
                "execution_log": execution_log
            }
        execution_log.append(
            f"Approver granted (by approvers.py list): emp_no {emp_no}"
        )
        return {
            "has_permission": True,
            "denial_message": None,
            "execution_log": execution_log
        }

    if selected_agent_role == "erp_approver":
        if not is_erp_approver(emp_no):
            execution_log.append(
                f"ERP approver denied: emp_no {emp_no} not in ERP_APPROVERS list."
            )
            return {
                "has_permission": False,
                "denial_message": (
                    "ERP approval is restricted to the ERP HOD. "
                    "If you believe this is an error, contact your administrator."
                ),
                "execution_log": execution_log
            }
        execution_log.append(
            f"ERP approver granted (by approvers.py list): emp_no {emp_no}"
        )
        return {
            "has_permission": True,
            "denial_message": None,
            "execution_log": execution_log
        }

    if selected_agent_role == "issuer":
        if not is_issuer(emp_no):
            execution_log.append(
                f"Issuer denied: emp_no {emp_no} not in ISSUERS list."
            )
            return {
                "has_permission": False,
                "denial_message": (
                    "The store issuance feature is not yet active."
                ),
                "execution_log": execution_log
            }
        execution_log.append(
            f"Issuer granted (by approvers.py list): emp_no {emp_no}"
        )
        return {
            "has_permission": True,
            "denial_message": None,
            "execution_log": execution_log
        }

    # CREATOR persona: standard Gate 2 DB check.
    # Build expected_agent_name: {MODULE}_{COLLECTION_SUFFIX}_{PERSONA}
    collection_suffix = selected_collection.upper().replace("MRR_", "")
    expected_agent_name = f"MRR_{collection_suffix}_{selected_agent_role.upper()}"

    db = SessionLocal()
    try:
        from app.models.db_schema import Agent
        agent_row = db.query(Agent).filter(
            Agent.agent_name == expected_agent_name,
            Agent.is_active == 1
        ).first()

        if not agent_row:
            execution_log.append(f"Agent {expected_agent_name} not found in DB.")
            return {
                "has_permission": False,
                "denial_message": (
                    f"The {selected_agent_role} role for {selected_collection} "
                    f"is not available."
                ),
                "execution_log": execution_log
            }

        agent_or_none = AuthController.check_agent_access(
            emp_no=emp_no,
            group_idx=group_idx,
            role_ids=role_ids,
            agent_id=agent_row.agent_id,
            db=db
        )

        if agent_or_none is None:
            execution_log.append(
                f"Permission DENIED: user lacks {expected_agent_name}."
            )
            return {
                "has_permission": False,
                "denial_message": (
                    f"You don't have {selected_agent_role.lower()} access to "
                    f"{selected_collection.replace('_', ' ')}. "
                    f"Please contact your administrator if you need this permission."
                ),
                "execution_log": execution_log
            }

        execution_log.append(f"Permission GRANTED: {expected_agent_name}")
        return {
            "has_permission": True,
            "denial_message": None,
            "execution_log": execution_log
        }
    finally:
        db.close()


def permission_blocked_node(state: MaterialRequisitionState) -> dict:
    """Handle permission-denied scenarios."""
    print(f"[DIAG-MRR] permission_blocked_node entered. denial_message={state.get('denial_message')!r}", flush=True)
    denial_message = state.get("denial_message")

    if denial_message:
        response_text = denial_message
    else:
        response_text = (
            "I can only help with MRR tasks like creating material "
            "requisitions, approving requests, and issuing stock. "
            "Could you rephrase your request?"
        )

    return {
        "messages": [AIMessage(content=response_text)],
        "execution_log": state.get("execution_log", []) + ["Permission blocked"]
    }


