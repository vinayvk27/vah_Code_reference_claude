-- 1. Grant all role IDs (Junior/Mid/Senior) across all groups with MRR module access
--    the ability to invoke MRR_GENERAL_CREATOR.
INSERT IGNORE INTO dpah_role_agent_access (role_id, group_id, agent_id, granted_by)
SELECT roles.role_id, groups.group_idx, a.agent_id, 'system'
FROM dpah_agents a
CROSS JOIN (SELECT 7 AS role_id UNION SELECT 8 UNION SELECT 9) roles
CROSS JOIN (
    SELECT DISTINCT group_idx
    FROM dpah_module_usergroups
    WHERE module_id = (SELECT module_id FROM dpah_modules WHERE module_name = 'MRR')
) groups
WHERE a.agent_name = 'MRR_GENERAL_CREATOR';


-- 2. Verify all required MRR agents exist (this is a SELECT only, no insert).
SELECT agent_id, agent_name, department, is_active
FROM dpah_agents
WHERE agent_name LIKE 'MRR_%'
ORDER BY agent_id;
-- Expected: at least MRR_GENERAL_CREATOR, plus VERIFIER, MANAGER_APPROVER, ERP_APPROVER
-- if Task 4.4 seed has been run.
