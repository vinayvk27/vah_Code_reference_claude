"""
HRMS Intent Classification
==========================
LLM-driven classifier with keyword-fallback for HRMS workflow routing.

The classifier returns an HRMSIntentClassification with:
  - domain: "IN_DOMAIN" or "OUT_OF_DOMAIN"
  - collection: "hrms_leave_data", "hrms_salarydata", or ""
  - persona: "CREATOR", "REVIEWER", "APPROVER", or ""
  - confidence: "HIGH", "MEDIUM", or "LOW"
  - reasoning: short explanation

Uses PydanticOutputParser for structured output, which works with any LLM
provider that can produce JSON-formatted text. This is more portable than
relying on provider-native structured-output APIs (which our internal LLM
does not fully implement).
"""

from pydantic import BaseModel, Field
from typing import Literal
from langchain_core.output_parsers import PydanticOutputParser
from langchain_core.prompts import PromptTemplate

from app.core.llm import get_llm_non_streaming
from app.workflows.hrms_workflow.prompts import (
    KEYWORD_TO_PERSONA,
    DEFAULT_PERSONA,
    QUERY_KEYWORDS,
)

# =============================================================================
# MODULE DOMAIN DESCRIPTION
# =============================================================================

MODULE_DOMAIN_DESCRIPTION = """The HRMS (Human Resource Management System) module handles leave management and payslip operations.
Available collections:
  - hrms_leave_data: define leave types, check leave balance, submit leave requests, approve/reject leave requests.
  - hrms_salarydata: generate payslips, view own payslip, view any employee's payslip.
Available personas: CREATOR (creates leave types or payslips), REVIEWER (reviews own data, submits leave requests), APPROVER (approves leave requests, views any payslip)."""

# =============================================================================
# PYDANTIC MODEL
# =============================================================================


class HRMSIntentClassification(BaseModel):
    """Structured output for HRMS intent classification."""

    domain: Literal["IN_DOMAIN", "OUT_OF_DOMAIN"] = Field(
        description='Whether the user message falls within HRMS scope.'
    )
    collection: str = Field(
        description='Which HRMS collection the request targets: "hrms_leave_data", "hrms_salarydata", or empty if out of domain.'
    )
    persona: str = Field(
        description='Which persona the request targets: "CREATOR", "REVIEWER", "APPROVER", or empty if out of domain.'
    )
    confidence: Literal["HIGH", "MEDIUM", "LOW"] = Field(
        description='Confidence level in the classification.'
    )
    reasoning: str = Field(
        description='One-sentence explanation of the classification.'
    )


# =============================================================================
# PARSER & PROMPT TEMPLATE (module-level — built once at import time)
# =============================================================================

_parser = PydanticOutputParser(pydantic_object=HRMSIntentClassification)

_prompt_template = PromptTemplate(
    template=(
        "{module_description}\n\n"
        "Classify the following user message into a structured response.\n\n"
        "{format_instructions}\n\n"
        "User message: {user_message}\n"
    ),
    input_variables=["user_message"],
    partial_variables={
        "module_description": MODULE_DOMAIN_DESCRIPTION,
        "format_instructions": _parser.get_format_instructions(),
    },
)


# =============================================================================
# LLM CLASSIFIER
# =============================================================================


def classify_hrms_intent(user_message: str) -> HRMSIntentClassification:
    """Classify the user's intent using the LLM with PydanticOutputParser."""
    llm = get_llm_non_streaming()

    try:
        prompt_value = _prompt_template.invoke({"user_message": user_message})
        llm_response = llm.invoke(prompt_value)
        # llm_response is an AIMessage; the JSON is in .content
        raw_text = getattr(llm_response, "content", "") or ""
        parsed = _parser.parse(raw_text)
        return parsed
    except Exception as e:
        import traceback
        traceback.print_exc()
        return keyword_fallback(user_message)


# =============================================================================
# KEYWORD FALLBACK
# =============================================================================


def keyword_fallback(user_message: str) -> HRMSIntentClassification:
    """
    Keyword-based fallback classifier when LLM is unavailable.
    Returns LOW confidence and assumes in-domain.

    Priority: APPROVER > CREATOR > REVIEWER (default).
    Default collection: "hrms_leave_data".
    """
    msg_lower = user_message.lower()

    # Build keyword lists from KEYWORD_TO_PERSONA (priority order: APPROVER > CREATOR > REVIEWER)
    priority = ["approver", "creator", "reviewer"]

    for target_persona in priority:
        for kw, persona in KEYWORD_TO_PERSONA.items():
            if persona == target_persona and kw in msg_lower:
                return HRMSIntentClassification(
                    domain="IN_DOMAIN",
                    collection="hrms_leave_data",
                    persona=persona.upper(),
                    confidence="LOW",
                    reasoning="Keyword fallback used; LLM classifier unavailable.",
                )

    # QUERY_KEYWORDS — route to REVIEWER for HRMS
    for kw in QUERY_KEYWORDS:
        if kw in msg_lower:
            return HRMSIntentClassification(
                domain="IN_DOMAIN",
                collection="hrms_leave_data",
                persona="REVIEWER",
                confidence="LOW",
                reasoning="Keyword fallback used; LLM classifier unavailable.",
            )

    # No match — default to reviewer
    return HRMSIntentClassification(
        domain="IN_DOMAIN",
        collection="hrms_leave_data",
        persona=DEFAULT_PERSONA.upper(),
        confidence="LOW",
        reasoning="Keyword fallback used; LLM classifier unavailable.",
    )
```

