"""
Analytics Workflow Nodes
All node functions for the analytics LangGraph.
Each function takes AnalyticsState and returns updated AnalyticsState.
"""

import json
import re
import logging
from typing import Literal

from langchain_core.messages import HumanMessage, AIMessage, SystemMessage
from sqlalchemy import text

# --- Ensure these import paths match your actual project structure ---
from app.dao.database import SessionLocal
from app.workflows.analytics_workflow.state import AnalyticsState
from app.core.llm import get_llm, get_llm_non_streaming
from app.workflows.analytics_workflow.schema_registry import (
    COLLECTION_TABLE_MAP,
    build_schema_description,
)
from app.workflows.analytics_workflow.sql_validator import validate_generated_sql

logger = logging.getLogger(__name__)

# ─── Helpers ──────────────────────────────────────────────────────────────────

def _get_last_user_message(state: AnalyticsState) -> str:
    for msg in reversed(state.get("messages", [])):
        if isinstance(msg, HumanMessage):
            return msg.content or ""
    return ""

def _rows_to_table(rows: list) -> dict:
    """Convert list of dicts to {columns, rows} format for frontend."""
    if not rows:
        return {"columns": [], "rows": []}
    columns = list(rows[0].keys())
    table_rows = [[str(row.get(col, "")) for col in columns] for row in rows]
    return {"columns": columns, "rows": table_rows}


# ─── Node 1: Permission Check ─────────────────────────────────────────────────

def analytics_permission_check_node(state: AnalyticsState) -> AnalyticsState:
    print(f"[DIAG-ANALYTICS] permission_check_node entered. user_id={state.get('user_id')}, collection={state.get('selected_collection')}, available_agents={state.get('collection_agents')}", flush=True)
    
    collection = state.get("selected_collection", "")
    collection_agents = state.get("collection_agents", {})
    user_personas = collection_agents.get(collection, [])

    if not user_personas:
        state["has_permission"] = False
        state["denial_message"] = (
            f"You don't have access to {collection} analytics. "
            f"Your current analytics access: "
            f"{[k for k in collection_agents if k.endswith('_ANALYTICS')]}"
        )
        print(f"[DIAG-ANALYTICS] permission_check_node -> BLOCKED (No personas found for {collection})", flush=True)
        return state

    # Use the first available persona if not explicitly set
    if not state.get("selected_agent_role") or state.get("selected_agent_role") not in user_personas:
        state["selected_agent_role"] = user_personas[0]

    state["has_permission"] = True
    print(f"[DIAG-ANALYTICS] permission_check_node -> GRANTED as '{state['selected_agent_role']}'", flush=True)
    return state


# ─── Node 2: Permission Blocked ───────────────────────────────────────────────

def analytics_permission_blocked_node(state: AnalyticsState) -> AnalyticsState:
    print(f"[DIAG-ANALYTICS] permission_blocked_node entered.", flush=True)
    denial = state.get("denial_message") or "You don't have permission for this analytics query."
    msgs = list(state.get("messages", []))
    msgs.append(AIMessage(content=denial))
    state["messages"] = msgs
    return state


# ─── Node 3: Intent Classifier ────────────────────────────────────────────────

def analytics_intent_classifier_node(state: AnalyticsState) -> AnalyticsState:
    msg_count = len(state.get("messages", []))
    print(f"[DIAG-ANALYTICS] intent_classifier_node entered. message_count={msg_count}, role={state.get('selected_agent_role')}", flush=True)
    
    user_question = _get_last_user_message(state)
    persona = state.get("selected_agent_role", "reviewer")
    collection = state.get("selected_collection", "")

    prompt = f"""Classify this analytics question from a user with persona='{persona}' in module='{collection}'.

User question: "{user_question}"

Classification rules:
- SQL_DATA: Needs numbers, counts, sums, aggregations, or comparison data to display as chart or table.
- SQL_INSIGHT: Needs trend analysis, explanation, or text insight derived from database data.
- RAG: Needs policy documents, company procedures, or static knowledge not in the database.
- DENY: The question is clearly outside the user's permitted data scope or is a harmful/write operation.

Return exactly one word: SQL_DATA, SQL_INSIGHT, RAG, or DENY"""

    try:
        # ⚠️ Use NON-STREAMING so the classification doesn't leak to the frontend UI
        llm = get_llm_non_streaming()
        response = llm.invoke([HumanMessage(content=prompt)])
        intent = (response.content or "").strip().upper()
        print(f"[DIAG-ANALYTICS] LLM returned raw response: '{intent}'", flush=True)
    except Exception as e:
        print(f"[DIAG-ANALYTICS] ❌ LLM CONNECTION ERROR: {e}", flush=True)
        intent = "ERROR"

    # ⚠️ Removed the silent fallback! If the LLM returns garbage, it will now crash gracefully 
    # so you can actually debug your prompts and test RAG routing.
    valid_intents = {"SQL_DATA", "SQL_INSIGHT", "RAG", "DENY"}
    if intent not in valid_intents:
        print(f"[DIAG-ANALYTICS] ❌ Invalid intent received: '{intent}'. Forcing ERROR route.", flush=True)
        state["intent_type"] = "ERROR"
        state["sql_error"] = f"Intent classifier failed. LLM responded with: {intent}"
    else:
        state["intent_type"] = intent

    return state


# ─── Node 4: SQL Generator (With Advanced Rules) ──────────────────────────────

def analytics_sql_generator_node(state: AnalyticsState) -> AnalyticsState:
    print(f"[DIAG-ANALYTICS] sql_generator_node entered.", flush=True)
    
    user_question = _get_last_user_message(state)
    collection = state.get("selected_collection", "")
    persona = state.get("selected_agent_role", "reviewer")
    emp_id = state.get("user_id", "")

    schema_block = build_schema_description(collection, persona, emp_id)
    module_name = COLLECTION_TABLE_MAP.get(collection, {}).get("module_display_name", collection)

    prompt = f"""You are an Expert SQL Data Analyst for {module_name}.
User: {state.get('user_name', 'Employee')} (emp_id: {emp_id}, role: {persona})

Available database tables (MariaDB):
{schema_block}

STRICT SQL GENERATION RULES:
1. Write ONLY a SELECT statement. No INSERT, UPDATE, DELETE, DROP, or ALTER.
2. ACCESS RULES: You MUST apply the ACCESS RULE shown for each table in your WHERE clause exactly as written.
3. ALIASING: ALWAYS prefix EVERY column name with its table alias (e.g., w.Resource, t.TaskIdx) to prevent ambiguous column errors.
4. DATE FILTERS: DO NOT filter by current month/year (like MONTH(NOW())) UNLESS the user explicitly asks for a timeframe ("this month", "today", "2026"). If no timeframe is requested, query all historical data.
5. JOINS: Use INNER JOIN when data must exist in both tables, and LEFT JOIN if you need to retain records that might be missing relational data.
6. AGGREGATIONS: If you use SUM() or COUNT(), ensure all non-aggregated columns are in the GROUP BY clause.
7. TIME MATH: For worklogs, TimeSpentInSec / 3600.0 = hours. Round to 2 decimal places using ROUND().
8. SEARCH: Use LOWER() and LIKE '%term%' for case-insensitive text searching.
9. CANNOT ANSWER: If the question absolutely cannot be answered using the tables provided, return exactly: CANNOT_ANSWER
10. OUTPUT: Return ONLY the raw SQL query string. No explanation, no markdown blocks, no backticks.

User question: "{user_question}"
"""
    if state.get("sql_error") and state.get("retry_count", 0) > 0:
        prompt += f"\nPREVIOUS ATTEMPT FAILED VALIDATION:\n{state['sql_error']}\n\nPlease fix the SQL query and return ONLY the corrected SQL.\n"

    prompt += "\nSQL:"

    # ⚠️ Use NON-STREAMING so the raw SQL string doesn't leak into the frontend UI stream
    llm = get_llm_non_streaming()
    response = llm.invoke([HumanMessage(content=prompt)])
    generated = (response.content or "").strip()

    generated = re.sub(r'^```sql\s*', '', generated, flags=re.IGNORECASE)
    generated = re.sub(r'^```\s*', '', generated)
    generated = re.sub(r'\s*```$', '', generated)
    generated = generated.strip()

    if generated.upper() == "CANNOT_ANSWER" or not generated:
        state["sql_error"] = "I cannot answer this question with the available data."
        state["generated_sql"] = None
    else:
        print(f"[DIAG-ANALYTICS] sql_generator_node -> Generated SQL: {generated}", flush=True)
        state["generated_sql"] = generated

    return state


# ─── Node 5: SQL Validator ────────────────────────────────────────────────────

def analytics_sql_validator_node(state: AnalyticsState) -> AnalyticsState:
    print(f"[DIAG-ANALYTICS] sql_validator_node entered.", flush=True)
    if state.get("sql_error") and not state.get("generated_sql"):
        return state  # Errored out in generator (CANNOT_ANSWER)

    collection = state.get("selected_collection", "")
    allowed_tables = list(COLLECTION_TABLE_MAP.get(collection, {}).get("tables", {}).keys())

    is_valid, error_msg = validate_generated_sql(
        sql=state["generated_sql"],
        allowed_tables=allowed_tables
    )

    if not is_valid:
        print(f"[DIAG-ANALYTICS] sql_validator_node -> FAILED: {error_msg}", flush=True)
        state["sql_error"] = f"Query validation failed: {error_msg}"
        state["retry_count"] = state.get("retry_count", 0) + 1
    else:
        print(f"[DIAG-ANALYTICS] sql_validator_node -> PASSED", flush=True)
        state["sql_error"] = None # Clear errors on success

    return state


# ─── Node 6: SQL Executor ─────────────────────────────────────────────────────

def analytics_sql_executor_node(state: AnalyticsState) -> AnalyticsState:
    print(f"[DIAG-ANALYTICS] sql_executor_node entered.", flush=True)
    if state.get("sql_error") or not state.get("generated_sql"):
        return state

    sql = state["generated_sql"]
    db = SessionLocal()
    try:
        result = db.execute(text(sql))
        columns = list(result.keys())
        rows = [dict(zip(columns, row)) for row in result.fetchmany(10000)]
        state["sql_result"] = rows
        print(f"[DIAG-ANALYTICS] sql_executor_node -> Executed successfully, {len(rows)} rows returned.", flush=True)
        if not rows:
            state["sql_error"] = "The query returned no results for your question."
    except Exception as e:
        logger.error(f"Analytics SQL execution error: {e}")
        print(f"[DIAG-ANALYTICS] sql_executor_node -> DB EXECUTION ERROR: {e}", flush=True)
        state["sql_error"] = (
            "There was a problem running your query. "
            "Try rephrasing your question or being more specific."
        )
    finally:
        db.close()

    return state


# ─── Node 7: Output Formatter ─────────────────────────────────────────────────

def analytics_output_formatter_node(state: AnalyticsState) -> AnalyticsState:
    print(f"[DIAG-ANALYTICS] output_formatter_node entered. intent={state.get('intent_type')}", flush=True)
    intent = state.get("intent_type", "SQL_DATA")

    # Handle RAG path
    if intent == "RAG":
        print(f"[DIAG-ANALYTICS] output_formatter_node -> Formatting RAG fallback response.", flush=True)
        state["output_type"] = "text"
        state["text_response"] = (
            "Document-based insights are not available in the current version. "
            "I can help you analyze your operational data — try asking for counts, "
            "trends, summaries, or specific metrics from your records."
        )
        return state

    # Handle SQL errors
    if state.get("sql_error"):
        print(f"[DIAG-ANALYTICS] output_formatter_node -> Formatting SQL Error message.", flush=True)
        state["output_type"] = "text"
        state["text_response"] = state["sql_error"]
        return state

    sql_result = state.get("sql_result", [])
    user_question = _get_last_user_message(state)
    llm = get_llm_non_streaming()

    # Detect chart intent
    chart_keywords = {
        "bar", "pie", "line", "chart", "graph", "plot",
        "visualize", "visualization", "show me", "display"
    }
    question_lower = user_question.lower()
    wants_chart = any(kw in question_lower for kw in chart_keywords)

    # SQL_INSIGHT path — always text
    if intent == "SQL_INSIGHT":
        print(f"[DIAG-ANALYTICS] output_formatter_node -> Generating Insight Text...", flush=True)
        data_sample = json.dumps(sql_result[:200], default=str)
        insight_prompt = f"""The user asked: "{user_question}"

Here is the data retrieved from the database:
{data_sample}

Provide a clear, concise analysis based on this data.
Focus on trends, patterns, and meaningful observations.
Write in plain English. Maximum 3 paragraphs.
Do not mention SQL or database internals."""

        response = llm.invoke([HumanMessage(content=insight_prompt)])
        state["output_type"] = "text"
        state["text_response"] = response.content or ""
        return state

    # SQL_DATA path — chart or table
    if wants_chart:
        print(f"[DIAG-ANALYTICS] output_formatter_node -> Generating ECharts JSON...", flush=True)
        data_sample = json.dumps(sql_result[:100], default=str)
        chart_prompt = f"""The user asked: "{user_question}"

SQL query returned this data:
{data_sample}

Generate a valid ECharts option object (JSON) that best visualizes this data.
Choose the most appropriate chart type: bar, line, or pie based on the data structure.
Include proper titles, axis labels, and legends.

REQUIREMENTS:
- Return ONLY the JSON object. No explanation, no markdown, no backticks.
- The JSON must be valid and parseable by JavaScript JSON.parse().
- Use ECharts v5 syntax.
- Keep it simple and readable.

ECharts option JSON:"""

        llm_json = get_llm_non_streaming() 
        response = llm_json.invoke([HumanMessage(content=chart_prompt)])
        raw = (response.content or "").strip()
        raw = re.sub(r'^```json\s*', '', raw, flags=re.IGNORECASE)
        raw = re.sub(r'^```\s*', '', raw)
        raw = re.sub(r'\s*```$', '', raw)

        try:
            chart_spec = json.loads(raw.strip())
            state["output_type"] = "chart"
            state["chart_spec"] = chart_spec
            print(f"[DIAG-ANALYTICS] output_formatter_node -> Chart JSON parsed successfully.", flush=True)
        except json.JSONDecodeError:
            print(f"[DIAG-ANALYTICS] output_formatter_node -> Failed to parse Chart JSON. Falling back to table.", flush=True)
            state["output_type"] = "table"
            state["table_data"] = _rows_to_table(sql_result)
    else:
        print(f"[DIAG-ANALYTICS] output_formatter_node -> Outputting Table Data.", flush=True)
        state["output_type"] = "table"
        state["table_data"] = _rows_to_table(sql_result)

    return state


# ─── Node 8: Error Handler ────────────────────────────────────────────────────

def analytics_error_node(state: AnalyticsState) -> AnalyticsState:
    print(f"[DIAG-ANALYTICS] error_node entered. error={state.get('sql_error')}", flush=True)
    error = state.get("sql_error") or "Something went wrong. Please try again."
    msgs = list(state.get("messages", []))
    msgs.append(AIMessage(content=error))
    state["messages"] = msgs
    state["output_type"] = "text"
    state["text_response"] = error
    return state


# ─── Router Functions (used by graph conditional edges) ───────────────────────

def permission_router(state: AnalyticsState) -> Literal["proceed", "blocked"]:
    return "proceed" if state.get("has_permission") else "blocked"

def intent_router(state: AnalyticsState) -> Literal["SQL_DATA", "SQL_INSIGHT", "RAG", "DENY"]:
    return state.get("intent_type", "SQL_DATA")

def validation_router(state: AnalyticsState) -> Literal["valid", "error", "retry"]:
    if state.get("sql_error"):
        # If we failed validation but haven't maxed out retries, try again
        if state.get("retry_count", 0) <= 1:
            return "retry"
        return "error"
    return "valid"

def execution_router(state: AnalyticsState) -> Literal["success", "error"]:
    return "error" if state.get("sql_error") else "success"

