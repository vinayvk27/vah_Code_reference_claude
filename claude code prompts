async def reviewer_agent_node(state: RMSState) -> dict:
    """
    Node 3b: Reviewer (Filler) Agent — fully procedural (no LLM).
    Two sub-actions, both scoped to the logged-in user's emp_no:
      - VIEW tasks (default)
      - LOG hours (when message has hour-logging signals)
    """
    print(
        f"[DIAG-RMS] reviewer_agent_node entered. emp_no={state.get('emp_no')}, "
        f"collection={state.get('selected_collection')!r}, "
        f"last_msg={_last_user_msg_short(state)}",
        flush=True
    )

    messages = state.get("messages", [])
    last_user_message = ""
    for msg in reversed(messages):
        if isinstance(msg, HumanMessage):
            last_user_message = str(getattr(msg, "content", "") or "")
            break

    current_emp_no = state.get("emp_no", state.get("user_id", ""))
    execution_log = state.get("execution_log", [])

    # Decide sub-action: LOG HOURS vs VIEW TASKS
    import re
    is_log = bool(
        re.search(r'\blog\b', last_user_message, re.IGNORECASE)
        or re.search(r'\d+(?:\.\d+)?\s*(?:hours|hour|hrs|hr)\b', last_user_message, re.IGNORECASE)
        or re.search(r'\bfill\b', last_user_message, re.IGNORECASE)
    )

    # -------- LOG HOURS PATH --------
    if is_log:
        fields = _extract_worklog_fields(last_user_message)
        if fields["errors"]:
            lines = ["I couldn't log the hours. Please fix and resend in one message:"]
            for err in fields["errors"]:
                lines.append(f"- {err}")
            lines.append("")
            lines.append(
                'Example: log 8 hours on task 22 for 2026-05-26 with remark "design work"'
            )
            full_text = "\n".join(lines)
            execution_log.append("Reviewer: log-hours validation errors")
            print(f"[DIAG-RMS] reviewer_agent_node returning (log validation errors).", flush=True)
            return {"messages": [AIMessage(content=full_text)], "execution_log": execution_log}

        # Insert worklog via timesheet_store.add_worklog
        try:
            db = SessionLocal()
            try:
                result = timesheet_store.add_worklog(
                    db=db,
                    worklog_idx=fields["worklog_idx"],
                    resource_id=int(current_emp_no),
                    task_date=fields["task_date"],
                    hours=fields["hours"],
                    remarks=fields["remarks"],
                )
                wl_id = result.get("worklog_id")
                full_text = (
                    f"Logged {fields['hours']} hours against task {fields['worklog_idx']} "
                    f"on {fields['task_date']} (Worklog ID: {wl_id}). "
                    f"Status: PENDING approval."
                )
                execution_log.append(f"Reviewer: worklog created id={wl_id}")
            except Exception as e:
                db.rollback()
                full_text = f"Could not log hours due to a database error: {e}"
                execution_log.append(f"Reviewer: worklog insert failed: {e}")
            finally:
                db.close()
        except Exception as e:
            full_text = f"Could not log hours due to a database error: {e}"
            execution_log.append(f"Reviewer: session error: {e}")

        print(f"[DIAG-RMS] reviewer_agent_node returning (logged hours).", flush=True)
        return {"messages": [AIMessage(content=full_text)], "execution_log": execution_log}

    # -------- VIEW TASKS PATH --------
    try:
        db = SessionLocal()
        try:
            tasks = timesheet_store.list_tasks_for_resource(db, int(current_emp_no))
        finally:
            db.close()
    except Exception as e:
        return {
            "messages": [AIMessage(content=f"Could not fetch your tasks due to a database error: {e}")],
            "execution_log": execution_log + [f"Reviewer: list error {e}"],
        }

    if not tasks:
        full_text = "You have no tasks assigned at the moment."
    else:
        lines = ["### Your Assigned Tasks", ""]
        lines.append("| Task ID | Project | Product | Task Idx | Activity | Start | End | Planned Hrs |")
        lines.append("|---|---|---|---|---|---|---|---|")
        for t in tasks:
            lines.append(
                f"| {t.get('task_id')} | {t.get('project_id')} | {t.get('product_id')} "
                f"| {t.get('task_idx')} | {t.get('activity_idx')} | {t.get('start_date')} "
                f"| {t.get('end_date')} | {t.get('plan_hours')} |"
            )
        lines.append("")
        lines.append('To log hours: log 8 hours on task <Task ID> for <YYYY-MM-DD> with remark "your note"')
        full_text = "\n".join(lines)

    execution_log.append(f"Reviewer: listed {len(tasks)} tasks for {current_emp_no}")
    print(f"[DIAG-RMS] reviewer_agent_node returning (listed tasks).", flush=True)
    return {"messages": [AIMessage(content=full_text)], "execution_log": execution_log}
