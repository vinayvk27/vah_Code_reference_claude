def approver_agent_node(state: MaterialRequisitionState) -> dict:
    """Fetches pending requests for manager approval (CTO/COO).

    MRR-specific node — does direct DB query, no LLM streaming.
    Registered in graph.py under names 'mrr_approver_agent' and
    'mrr_approver_agent_node' to avoid collision with RMS/HRMS.

    Supports approval commands:
      - "approve MRR/<id>/26-27" or "approve <id>" or "approve requisition <id>"
      - "approve all" / "approve all pending"
      - "reject <id>"
    """
    print(f"[DIAG-MRR] approver_agent_node entered. emp_no={state.get('emp_no')}", flush=True)
    emp_no = state.get("emp_no", "")

    from app.workflows.material_workflow.approvers import is_manager_approver
    if not is_manager_approver(emp_no):
        return {
            "messages": [AIMessage(content="Manager approval is restricted to the COO and CTO. Please contact your administrator if you believe this is an error.")],
            "execution_log": state.get("execution_log", []) + ["Non-approver blocked from manager approval"]
        }

    # --- Inspect user's last message for approval commands ---
    last_user_msg = _get_last_user_message(state.get("messages", []))
    cmd = _parse_approval_command(last_user_msg)

    if cmd["action"] in ("approve_one", "reject_one"):
        mrr_id = cmd["mrr_id"]
        action = cmd["action"]
        db = SessionLocal()
        try:
            # Verify the MRR exists and is in the correct pending state
            verify = db.execute(text("""
                SELECT MATREQUISITIONID, MATREQUISITIONNO, APPROVAL_STATUS
                FROM mrr_matrequisitionheader
                WHERE MATREQUISITIONID = :id
                  AND APPROVAL_STATUS = 'PENDING'
            """), {"id": mrr_id}).mappings().first()

            if not verify:
                return {
                    "messages": [AIMessage(content=f"MRR with ID {mrr_id} not found in pending state. It may already be approved/rejected or doesn't exist.")],
                    "execution_log": state.get("execution_log", []) + [f"Approver: MRR {mrr_id} not found in pending state."]
                }

            if action == "approve_one":
                result = db.execute(text("""
                    UPDATE mrr_matrequisitionheader
                    SET APPROVAL_STATUS = 'APPROVED',
                        APPROVAL_DATE = NOW(),
                        ERP_APPROVAL_STATUS = 'PENDING'
                    WHERE MATREQUISITIONID = :id
                      AND APPROVAL_STATUS = 'PENDING'
                """), {"id": mrr_id})
                db.commit()
                mrr_no = verify['MATREQUISITIONNO'] or f"MRR/{mrr_id}/26-27"
                if action == "approve_one":
                    resp = add_reasoning(
                        f"Approved {mrr_no}. It has been forwarded to ERP for final approval.",
                        context=f"Manager {emp_no} approved MRR {mrr_id}; forwarded to ERP."
                    )
                    execution_log_entry = f"Approver: approved MRR {mrr_id}."
                else:
                    resp = add_reasoning(
                        f"Rejected {mrr_no}.",
                        context=f"Manager {emp_no} rejected MRR {mrr_id}."
                    )
                    execution_log_entry = f"Approver: rejected MRR {mrr_id}."
                return {
                    "messages": [AIMessage(content=resp)],
                    "execution_log": state.get("execution_log", []) + [execution_log_entry]
                }

        except Exception as e:
            db.rollback()
            import traceback
            traceback.print_exc()
            return {
                "messages": [AIMessage(content=f"Error processing approval: {str(e)}")],
                "execution_log": state.get("execution_log", []) + [f"Approver: exception {e}"]
            }
        finally:
            db.close()

    elif cmd["action"] == "approve_all":
        db = SessionLocal()
        try:
            result = db.execute(text("""
                UPDATE mrr_matrequisitionheader
                SET APPROVAL_STATUS = 'APPROVED',
                    APPROVAL_DATE = NOW(),
                    ERP_APPROVAL_STATUS = 'PENDING'
                WHERE APPROVAL_STATUS = 'PENDING'
            """))
            db.commit()
            rowcount = result.rowcount
            if rowcount == 0:
                return {
                    "messages": [AIMessage(content="There are no pending MRRs to approve.")],
                    "execution_log": state.get("execution_log", []) + ["Approver: approve all — nothing pending."]
                }
            resp = add_reasoning(
                f"Approved {rowcount} pending MRRs. They have been forwarded to ERP for final approval.",
                context=f"Manager {emp_no} approved {rowcount} pending MRRs in bulk."
            )
            return {
                "messages": [AIMessage(content=resp)],
                "execution_log": state.get("execution_log", []) + [f"Approver: approved all ({rowcount} MRRs)."]
            }

        except Exception as e:
            db.rollback()
            import traceback
            traceback.print_exc()
            return {
                "messages": [AIMessage(content=f"Error processing approve all: {str(e)}")],
                "execution_log": state.get("execution_log", []) + [f"Approver: exception {e}"]
            }
        finally:
            db.close()

    # --- No command matched (or action is "list") — show pending list ---
    db = SessionLocal()
    try:
        query = text("""
            SELECT MATREQUISITIONID, MATREQUISITIONNO, REQUESTORID, REQUISITIONDATE,
                   TOTAL_COST, APPROVAL_STATUS, STATUS
            FROM mrr_matrequisitionheader
            WHERE APPROVAL_STATUS = 'PENDING'
            ORDER BY REQUISITIONDATE ASC
        """)
        results = db.execute(query).mappings().all()

        if not results:
            return {
                "messages": [AIMessage(content="You have no pending manager approvals at this time.")],
                "execution_log": state.get("execution_log", []) + ["Approver: no pending requests."]
            }

        response_text = "### Pending Manager Approvals\n\n"
        response_text += "| Req ID | MRR No | Requestor | Total Cost | Status | Date |\n"
        response_text += "|---|---|---|---|---|---|\n"

        for r in results:
            date_str = r['REQUISITIONDATE'].strftime('%Y-%m-%d') if r['REQUISITIONDATE'] else 'N/A'
            response_text += f"| {r['MATREQUISITIONID']} | {r['MATREQUISITIONNO']} | {r['REQUESTORID']} | \u20b9{r['TOTAL_COST']} | {r['APPROVAL_STATUS']} | {date_str} |\n"

        response_text += "\n*To approve a request, tell me: 'Approve requisition MRR/<id>/26-27'*"

        return {
            "messages": [AIMessage(content=response_text)],
            "execution_log": state.get("execution_log", []) + [f"Approver: returned {len(results)} pending requests."]
        }

    except Exception as e:
        import traceback
        traceback.print_exc()
        return {
            "messages": [AIMessage(content=f"Error fetching pending requests: {str(e)}")],
            "execution_log": state.get("execution_log", []) + [f"Approver: exception {e}"]
        }
    finally:
        db.close()


