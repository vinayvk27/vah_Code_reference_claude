  def tool_show_leave_request_form(user_context: dict, prefill: dict = None) -> str:
      """
      Emit a leave request form spec for the chat to render.
      Filler persona only.
      
      Args:
          user_context: user info
          prefill: optional dict with pre-filled values (e.g., {"from_date": "2026-06-15"})
      
      Returns: a special <<FORM>>...<<ENDFORM>> wrapped JSON string
      """
      from app.forms.emit import build_form_emit
      from app.services import hrms_store
      
      persona = (user_context or {}).get("persona")
      if persona != "reviewer":
          raise PermissionError("tool_show_leave_request_form requires reviewer persona")
      
      resource_id = int(user_context["user_id"])
      prefill = prefill or {}
      
      # Fetch leave balance to populate the dropdown with remaining days
      db = SessionLocal()
      try:
          balances = hrms_store.compute_leave_balance(db, resource_id)
      except Exception:
          balances = []
      finally:
          db.close()
      
      # Build leave type options with balance hints
      leave_options = []
      for b in balances:
          leave_options.append({
              "value": b["leave_type_id"],
              "label": f"{b['leave_type_name']} ({b['remaining_days']} of {b['max_days']} left)"
          })
      
      # If no leave types defined yet, fall back to a placeholder
      if not leave_options:
          leave_options = [{"value": 0, "label": "(no leave types defined — contact HR)"}]
      
      form_spec = {
          "version": 1,
          "form_id": "hrms_apply_leave",
          "title": "Apply for Leave",
          "description": "Submit a new leave request for approval.",
          "submit_label": "Submit Request",
          "cancel_label": "Cancel",
          "fields": [
              {
                  "name": "leave_type_id",
                  "label": "Leave Type",
                  "type": "select",
                  "required": True,
                  "options": leave_options,
                  "default": prefill.get("leave_type_id") or leave_options[0]["value"],
              },
              {
                  "name": "from_date",
                  "label": "From Date",
                  "type": "date",
                  "required": True,
                  "default": prefill.get("from_date") or "",
              },
              {
                  "name": "to_date",
                  "label": "To Date",
                  "type": "date",
                  "required": True,
                  "default": prefill.get("to_date") or "",
              },
              {
                  "name": "reason",
                  "label": "Reason",
                  "type": "textarea",
                  "required": True,
                  "max_length": 500,
                  "placeholder": "Brief explanation",
                  "default": prefill.get("reason") or "",
              },
          ],
      }
      
      return build_form_emit(form_spec)

