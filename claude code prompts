class EnterpriseLLM(LLM):
    """Custom LangChain LLM wrapper for your specific API endpoint."""
    
    # Required for LangChain compatibility
    @property
    def _llm_type(self) -> str:
        return "custom_enterprise_llm"

    def _call(self, prompt: str, stop: Optional[List[str]] = None, **kwargs: Any) -> str:
        url = f"{config['API']['URL']}/chat/completions"
        headers = {
            "Authorization": f"Bearer {config['API']['KEY']}",
            "Content-Type": "application/json"
        }
        payload = {
            "model": config['API']['MODEL'],
            "messages": [{"role": "user", "content": prompt}],
            "temperature": 0
        }

        try:
            response = requests.post(url, headers=headers, json=payload, timeout=20)
            response.raise_for_status()
            return response.json()['choices'][0]['message']['content']
        except Exception as e:
            logger.error(f"LLM Connection Error: {e}")
            return "ERROR: Connection failed."

    @property
    def _identifying_params(self) -> Dict[str, Any]:
        return {"model_name": config['API']['MODEL']}
class ApproverAgent:
    def __init__(self):
        self.llm = EnterpriseLLM()

    def get_decision(self, item, amount):
        limit = config['BUSINESS_RULES']['MAX_APPROVAL_LIMIT']
        # Professional LangChain Prompting
        prompt = f"""
        You are a SCM Approval Agent. 
        Analyze the following Purchase Requisition:
        - ITEM: {item}
        - AMOUNT: {amount}
        - APPROVAL LIMIT: {limit}
        
        If AMOUNT <= {limit}, suggest APPROVED.
        Otherwise, suggest REJECTED.
        
        Format: DECISION: [STATUS] | REASON: [EXPLANATION]
        """
        return self.llm.invoke(prompt)
    
    def get_react_agent(self, df):
        """Creates a ReAct agent with strict output constraints."""
        
        def validate_and_approve_tool(input_text):
            from agents.reviewer_agent import ReviewerAgent
            result = ReviewerAgent.validate(df)
            if result["status"] == "FAIL":
                return f"STOP. Validation FAILED: {result['reason']}"
            
            # Perform the approval loop
            final_summaries = []
            for _, row in df.iterrows():
                decision = self.get_decision(row['ITEM'], row['AMOUNT'])
                final_summaries.append(f"PRQ {row['PRQ_NO']}: {decision}")
            
            return "Observation: SUCCESS. Processing complete. Decisions: " + " | ".join(final_summaries)

        tools = [
            Tool(
                name="PRQ_Process_Chain",
                func=validate_and_approve_tool,
                # WE TELL THE AGENT THE DATA IS ALREADY THERE:
                description="Use this tool to process the PRQs currently loaded in the system. Input can be any string (e.g., 'start'), as the tool handles the internal data."
            )
        ]

        # STRICT PROMPTING: We separate the instructions to prevent the double-output error.
        prefix = """You are a strict SCM Assistant.
        You MUST follow this format:
        1. Thought: Consider the request.
        2. Action: Use the PRQ_Process_Chain tool.
        3. Observation: Wait for the tool output.
        4. Final Answer: Summarize the Observation results.
        
        DO NOT provide a Final Answer until you have used a tool."""

        suffix = """Begin!
        Question: {input}
        Thought: {agent_scratchpad}"""

        return initialize_agent(
            tools=tools,
            llm=self.llm,
            agent=AgentType.ZERO_SHOT_REACT_DESCRIPTION,
            verbose=True,
            handle_parsing_errors=True,
            agent_kwargs={
                'prefix': prefix,
                'suffix': suffix
            }
        )
