## NEW approver_agent_node (full)

```python
def approver_agent_node(state: MaterialRequisitionState) -> dict:
    """Fetches pending requests for manager approval (CTO/COO).

    MRR-specific node — does direct DB query, no LLM streaming.
    Registered in graph.py under names 'mrr_approver_agent' and
    'mrr_approver_agent_node' to avoid collision with RMS/HRMS.
    """
    print(f"[DIAG-MRR] approver_agent_node entered. emp_no={state.get('emp_no')}")
    emp_no = state.get("emp_no", "")

    from app.workflows.material_workflow.approvers import is_manager_approver
    if not is_manager_approver(emp_no):
        return {
            "messages": [AIMessage(content="Manager approval is restricted to the COO and CTO. Please contact your administrator if you believe this is an error.")],
            "execution_log": state.get("execution_log", []) + ["Non-approver blocked from manager approval"]
        }

    db = SessionLocal()
    try:
        query = text("""
            SELECT MATREQUISITIONID, MATREQUISITIONNO, REQUESTORID, REQUISITIONDATE,
                   TOTAL_COST, APPROVAL_STATUS, STATUS
            FROM mrr_matrequisitionheader
            WHERE APPROVAL_STATUS = 'PENDING'
            ORDER BY REQUISITIONDATE ASC
        """)
        results = db.execute(query).mappings().all()

        if not results:
            return {
                "messages": [AIMessage(content="You have no pending manager approvals at this time.")],
                "execution_log": state.get("execution_log", []) + ["Approver: no pending requests."]
            }

        response_text = "### Pending Manager Approvals\n\n"
        response_text += "| Req ID | MRR No | Requestor | Total Cost | Status | Date |\n"
        response_text += "|---|---|---|---|---|---|\n"

        for r in results:
            date_str = r['REQUISITIONDATE'].strftime('%Y-%m-%d') if r['REQUISITIONDATE'] else 'N/A'
            response_text += f"| {r['MATREQUISITIONID']} | {r['MATREQUISITIONNO']} | {r['REQUESTORID']} | \u20b9{r['TOTAL_COST']} | {r['APPROVAL_STATUS']} | {date_str} |\n"

        response_text += "\n*To approve a request, tell me: 'Approve requisition MRR/<id>/26-27'*"

        return {
            "messages": [AIMessage(content=response_text)],
            "execution_log": state.get("execution_log", []) + [f"Approver: returned {len(results)} pending requests."]
        }

    except Exception as e:
        import traceback
        traceback.print_exc()
        return {
            "messages": [AIMessage(content=f"Error fetching pending requests: {str(e)}")],
            "execution_log": state.get("execution_log", []) + [f"Approver: exception {e}"]
        }
    finally:
        db.close()
```

### Key changes:
- `TOTALCOST` → `TOTAL_COST` in SQL SELECT
- RowMapping attribute access (`r.MATREQUISITIONID`) → dict-style (`r['MATREQUISITIONID']`)
- MRR year suffix `25-26` → `26-27`
- Added `execution_log` to all return paths
- Added `traceback.print_exc()` in exception handler
- Added docstring

