"""
SCM Approver ReAct Agent (Modern LangChain)
=============================================
A ReAct agent that reviews pending MRRs for all three approval stages
(PL/PM, Manager, ERP Approver). It dynamically selects the correct DAO
based on the user's persona, reads the AI Verifier's reasoning, and
provides SCM-aware summaries with urgency/value alerts.
Uses the Modern ReAct pattern (create_react_agent + AgentExecutor).
"""

import json
from datetime import datetime, timedelta

from langchain.agents import create_react_agent, AgentExecutor
from langchain_core.prompts import PromptTemplate
from langchain_core.tools import Tool
from sqlalchemy import text

from app.core.llm import get_llm_non_streaming
from app.dao.database import SessionLocal
from app.dao.mrr_dao import MRRDao
from app.workflows.shared.reasoning_addon import add_reasoning


def _build_approver_tools(emp_no: str, persona: str):
    """Build LangChain Tool wrappers for the approver ReAct agent.

    Persona mapping:
      pl_pm / pl_approver -> fetches PL/PM stage (PL_APPROVAL_STATUS = 'PENDING')
      approver            -> fetches Manager stage (STATUS = 'PENDING_MANAGER')
      erp_approver        -> fetches ERP stage (STATUS = 'PENDING_ERP')
    """

    def list_pending_requests(_x=None):
        """Fetch pending MRRs for the current persona's approval stage.

        Accepts and ignores a dummy argument (LangChain may pass "{}" or "").
        Returns a pure string for LangChain, or an error string.
        """
        print(f"[TOOL DEBUG] List_Pending_Approvals triggered | persona={persona} | emp_no={emp_no}", flush=True)
        db = SessionLocal()
        try:
            # --- Safe persona routing ---
            print(f"[TOOL DEBUG] Routing persona={persona}...", flush=True)
            if persona in ("pl_pm", "pl_approver"):
                print("[TOOL DEBUG] -> PL/PM DAO path", flush=True)
                results = MRRDao.get_pending_mrrs_for_pl_pm(db, emp_no)
            elif persona == "erp_approver":
                print("[TOOL DEBUG] -> ERP DAO path", flush=True)
                results = MRRDao.get_pending_mrrs_for_erp(db, emp_no)
            else:
                print("[TOOL DEBUG] -> Manager DAO path (default)", flush=True)
                results = MRRDao.get_pending_mrrs_for_manager(db, emp_no)

            count = len(results) if results else 0
            print(f"[TOOL DEBUG] DB fetch complete. Found {count} records.", flush=True)

            if not results:
                return "Observation: No pending approvals found for your role."

            # --- Enrich each row with safe urgency / value flags ---
            enriched = []
            now = datetime.now()

            for r in results:
                row = dict(r)

                # Safe date check
                need_by = row.get("NEEDBYDATE")
                row["is_urgent"] = False
                row["needby_str"] = "N/A"
                if need_by is not None:
                    if isinstance(need_by, datetime):
                        try:
                            delta = need_by - now
                            row["is_urgent"] = delta.days <= 7
                            row["needby_str"] = need_by.strftime("%Y-%m-%d")
                        except Exception:
                            row["is_urgent"] = False
                            row["needby_str"] = "N/A"
                    else:
                        # DB might return a string like "2025-06-20 14:30:00"
                        parsed = None
                        for fmt in ("%Y-%m-%d %H:%M:%S", "%Y-%m-%d"):
                            try:
                                parsed = datetime.strptime(str(need_by), fmt)
                                break
                            except (ValueError, TypeError):
                                continue
                        if parsed is not None:
                            try:
                                delta = parsed - now
                                row["is_urgent"] = delta.days <= 7
                                row["needby_str"] = parsed.strftime("%Y-%m-%d")
                            except Exception:
                                pass

                # Safe cost check
                cost = row.get("TOTAL_COST")
                if cost is not None:
                    try:
                        row["is_high_value"] = float(cost) > 2000
                    except (ValueError, TypeError):
                        row["is_high_value"] = False
                else:
                    row["is_high_value"] = False

                enriched.append(row)

            # CRITICAL: LangChain tools MUST return a string, not a list/dict
            final_string = json.dumps(enriched, indent=2, default=str)
            print(f"[TOOL DEBUG] Returning {len(enriched)} enriched records as JSON string.", flush=True)
            return f"Observation: Here are the pending approvals:\n{final_string}"
        except Exception as e:
            print(f"[TOOL DEBUG] Error in List_Pending_Approvals: {e}", flush=True)
            import traceback
            traceback.print_exc()
            return f"Observation: Failed to fetch pending approvals. Error: {str(e)}"
        finally:
            db.close()

    def approve_mrr(mrr_id: int) -> str:
        """Approve a specific pending MRR at the current stage."""
        db = SessionLocal()
        try:
            if persona == "pl_pm":
                verify = db.execute(text("""
                    SELECT MATREQUISITIONNO FROM mrr_matrequisitionheader
                    WHERE MATREQUISITIONID = :id AND PL_APPROVAL_STATUS = 'PENDING'
                """), {"id": mrr_id}).mappings().first()
                if not verify:
                    return f"MRR {mrr_id} not pending PL/PM approval."
                db.execute(text("""
                    UPDATE mrr_matrequisitionheader
                    SET PL_APPROVAL_STATUS = 'APPROVED', PL_APPROVAL_DATE = NOW()
                    WHERE MATREQUISITIONID = :id AND PL_APPROVAL_STATUS = 'PENDING'
                """), {"id": mrr_id})
                db.commit()
                mrr_no = verify["MATREQUISITIONNO"] or f"MRR/{mrr_id}"
                return add_reasoning(
                    f"PL/PM approved {mrr_no}. It is now being auto-verified.",
                    context=f"PL/PM {emp_no} approved MRR {mrr_id}."
                )

            elif persona == "erp_approver":
                verify = db.execute(text("""
                    SELECT MATREQUISITIONNO FROM mrr_matrequisitionheader
                    WHERE MATREQUISITIONID = :id AND ERP_APPROVAL_STATUS = 'PENDING' AND APPROVAL_STATUS = 'APPROVED'
                """), {"id": mrr_id}).mappings().first()
                if not verify:
                    return f"MRR {mrr_id} not pending ERP approval."
                db.execute(text("""
                    UPDATE mrr_matrequisitionheader
                    SET ERP_APPROVAL_STATUS = 'APPROVED', ERP_APPROVAL_DATE = NOW(), STATUS = 'RELEASED'
                    WHERE MATREQUISITIONID = :id AND ERP_APPROVAL_STATUS = 'PENDING' AND APPROVAL_STATUS = 'APPROVED'
                """), {"id": mrr_id})
                db.commit()
                mrr_no = verify["MATREQUISITIONNO"] or f"MRR/{mrr_id}"
                return add_reasoning(
                    f"ERP-approved {mrr_no}. Released to store for issuance.",
                    context=f"ERP {emp_no} approved MRR {mrr_id}."
                )

            else:
                # Manager stage
                verify = db.execute(text("""
                    SELECT MATREQUISITIONNO FROM mrr_matrequisitionheader
                    WHERE MATREQUISITIONID = :id AND APPROVAL_STATUS = 'PENDING'
                """), {"id": mrr_id}).mappings().first()
                if not verify:
                    return f"MRR {mrr_id} not pending manager approval."
                db.execute(text("""
                    UPDATE mrr_matrequisitionheader
                    SET APPROVAL_STATUS = 'APPROVED', APPROVAL_DATE = NOW(),
                        ERP_APPROVAL_STATUS = 'PENDING', STATUS = 'PENDING_ERP'
                    WHERE MATREQUISITIONID = :id AND APPROVAL_STATUS = 'PENDING'
                """), {"id": mrr_id})
                db.commit()
                mrr_no = verify["MATREQUISITIONNO"] or f"MRR/{mrr_id}"
                return add_reasoning(
                    f"Approved {mrr_no}. Forwarded to ERP for final approval.",
                    context=f"Manager {emp_no} approved MRR {mrr_id}."
                )
        except Exception as e:
            db.rollback()
            return f"Error approving MRR {mrr_id}: {e}"
        finally:
            db.close()

    def reject_mrr(mrr_id: int) -> str:
        """Reject a specific pending MRR at the current stage."""
        db = SessionLocal()
        try:
            if persona == "pl_pm":
                verify = db.execute(text("""
                    SELECT MATREQUISITIONNO FROM mrr_matrequisitionheader
                    WHERE MATREQUISITIONID = :id AND PL_APPROVAL_STATUS = 'PENDING'
                """), {"id": mrr_id}).mappings().first()
                if not verify:
                    return f"MRR {mrr_id} not pending PL/PM approval."
                db.execute(text("""
                    UPDATE mrr_matrequisitionheader
                    SET PL_APPROVAL_STATUS = 'REJECTED', PL_APPROVAL_DATE = NOW(), STATUS = 'REJECTED'
                    WHERE MATREQUISITIONID = :id AND PL_APPROVAL_STATUS = 'PENDING'
                """), {"id": mrr_id})
                db.commit()
                mrr_no = verify["MATREQUISITIONNO"] or f"MRR/{mrr_id}"
                return add_reasoning(
                    f"PL/PM rejected {mrr_no}.",
                    context=f"PL/PM {emp_no} rejected MRR {mrr_id}."
                )
            elif persona == "erp_approver":
                verify = db.execute(text("""
                    SELECT MATREQUISITIONNO FROM mrr_matrequisitionheader
                    WHERE MATREQUISITIONID = :id AND ERP_APPROVAL_STATUS = 'PENDING'
                """), {"id": mrr_id}).mappings().first()
                if not verify:
                    return f"MRR {mrr_id} not pending ERP approval."
                db.execute(text("""
                    UPDATE mrr_matrequisitionheader
                    SET ERP_APPROVAL_STATUS = 'REJECTED', ERP_APPROVAL_DATE = NOW()
                    WHERE MATREQUISITIONID = :id AND ERP_APPROVAL_STATUS = 'PENDING'
                """), {"id": mrr_id})
                db.commit()
                mrr_no = verify["MATREQUISITIONNO"] or f"MRR/{mrr_id}"
                return add_reasoning(
                    f"ERP-rejected {mrr_no}.",
                    context=f"ERP {emp_no} rejected MRR {mrr_id}."
                )
            else:
                verify = db.execute(text("""
                    SELECT MATREQUISITIONNO FROM mrr_matrequisitionheader
                    WHERE MATREQUISITIONID = :id AND APPROVAL_STATUS = 'PENDING'
                """), {"id": mrr_id}).mappings().first()
                if not verify:
                    return f"MRR {mrr_id} not pending manager approval."
                db.execute(text("""
                    UPDATE mrr_matrequisitionheader
                    SET APPROVAL_STATUS = 'REJECTED', APPROVAL_DATE = NOW()
                    WHERE MATREQUISITIONID = :id AND APPROVAL_STATUS = 'PENDING'
                """), {"id": mrr_id})
                db.commit()
                mrr_no = verify["MATREQUISITIONNO"] or f"MRR/{mrr_id}"
                return add_reasoning(
                    f"Rejected {mrr_no}.",
                    context=f"Manager {emp_no} rejected MRR {mrr_id}."
                )
        except Exception as e:
            db.rollback()
            return f"Error rejecting MRR {mrr_id}: {e}"
        finally:
            db.close()

    return [
        Tool(
            name="List_Pending_Approvals",
            func=lambda *args, **kwargs: list_pending_requests(*args, **kwargs),
            description=(
                "Fetch all MRRs pending your approval at this stage. "
                "Includes MATREQUISITIONID, MATREQUISITIONNO, TOTAL_COST, "
                "NEEDBYDATE, AI_VERIFICATION_REMARK, is_urgent, is_high_value. "
                "Does not require any input — pass empty string or {}."
            ),
        ),
        Tool(
            name="Approve_MRR",
            func=lambda *args, **kwargs: approve_mrr(int(args[0]) if args else 0),
            description=(
                "Approve a specific pending MRR by its MATREQUISITIONID "
                "at the current approval stage."
            ),
        ),
        Tool(
            name="Reject_MRR",
            func=lambda *args, **kwargs: reject_mrr(int(args[0]) if args else 0),
            description=(
                "Reject a specific pending MRR by its MATREQUISITIONID "
                "at the current approval stage."
            ),
        ),
    ]


def run_approver_react_agent(user_input: str, emp_no: str, persona: str = "approver") -> str:
    """
    Run the Modern ReAct Approver agent for any approval stage.

    Parameters
    ----------
    user_input : str
        The user's message (e.g., "Show me pending approvals").
    emp_no : str
        The user's employee number.
    persona : str
        Approval stage persona: 'pl_pm', 'approver', or 'erp_approver'.

    Returns
    -------
    str
        The agent's Final Answer.
    """
    tools = _build_approver_tools(emp_no, persona)

    approver_react_template = """You are a highly intelligent SCM Assistant acting on behalf of the {persona} role.
You have access to the following tools:

{tools}

Format strictly:
Thought: Do I need to use a tool? Yes
Action: the action to take, should be exactly one of [{tool_names}]. DO NOT USE PARENTHESES. (e.g. Action: List_Pending_Approvals)
Action Input: input to the action
Observation: the result
... (Repeat as needed)
Thought: I now know the final answer
Final Answer: Your final response to the user.

CRITICAL SCM INSTRUCTIONS:
1. When fetching pending MRRs, you MUST read the 'AI_VERIFICATION_REMARK' and explain it from the perspective of a {persona}. (e.g., if you are ERP, focus on inventory/status; if PL/PM, focus on project needs; if Manager, focus on cost).
2. Look at the 'NEEDBYDATE'. If the date is within the next 7 days, highlight it as URGENT.
3. Look at 'TOTAL_COST'. If it is greater than 2000, highlight it as HIGH VALUE.
4. Present the pending items cleanly to the user and ask if they want to approve or reject them.

Begin!
Question: {input}
Thought: {agent_scratchpad}"""

    prompt = PromptTemplate.from_template(approver_react_template)

    llm = get_llm_non_streaming()

    agent = create_react_agent(llm, tools, prompt)
    agent_executor = AgentExecutor(agent=agent, tools=tools, verbose=True, handle_parsing_errors=True)

    try:
        response = agent_executor.invoke({
            "input": user_input,
            "persona": persona,
        })
        return response.get("output", "No response from agent.")
    except Exception as e:
        return f"Error running approver agent: {e}"





