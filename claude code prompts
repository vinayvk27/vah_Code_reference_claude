def _parse_form_submit_message(message: str) -> Optional[dict]:
    """
    If the message is a JSON object with action='form_submit', return
    the parsed dict {action, form_id, data}. Otherwise return None.
    Robust to whitespace/leading-trailing junk: must START with '{'
    and be valid JSON; otherwise return None silently.
    """
    s = (message or "").strip()
    if not s.startswith("{"):
        return None
    try:
        obj = json.loads(s)
    except Exception:
        return None
    if not isinstance(obj, dict):
        return None
    if obj.get("action") != "form_submit":
        return None
    return obj


def _lookup_project(db_session, project_code: str) -> Optional[dict]:
    """Resolve project code (e.g., 'YEA2719') to:
    {'project_id': int, 'description': str}.
    Returns None if not found."""
    row = db_session.execute(text("""
        SELECT PROJECTID, DESCRIPTION
        FROM posproject
        WHERE PROJECTNUMBER = :code
        LIMIT 1
    """), {"code": project_code}).mappings().first()
    if not row:
        return None
    return {
        "project_id": int(row["PROJECTID"]),
        "description": row["DESCRIPTION"] or ""
    }


def _lookup_latest_phase(db_session, project_id: int) -> Optional[int]:
    """Return the PROJECTPHASEID of the most recent phase for a
    project. Today projects have 1 phase, but ORDER BY ... DESC
    future-proofs for multi-phase."""
    row = db_session.execute(text("""
        SELECT PROJECTPHASEID
        FROM posprojectphases
        WHERE PROJECTID = :pid
        ORDER BY PROJECTPHASEID DESC
        LIMIT 1
    """), {"pid": project_id}).first()
    return int(row.PROJECTPHASEID) if row else None


def _parse_approval_command(message: str) -> dict:
    """
    Parses an approval command from the user's message.
    Returns dict with:
      'action': 'approve_one' | 'approve_all' | 'reject_one' | 'list'
      'mrr_id': int | None
    """
    msg = (message or "").lower().strip()

    if re.search(r'\bapprove\s+all\b', msg):
        return {"action": "approve_all", "mrr_id": None}

    match = re.search(
        r'\b(approve|reject)\s+(?:requisition\s+)?(?:mrr/)?(\d+)(?:/[\d\-]+)?\b',
        msg
    )
    if match:
        verb = match.group(1)
        mrr_id = int(match.group(2))
        action = "approve_one" if verb == "approve" else "reject_one"
        return {"action": action, "mrr_id": mrr_id}

    return {"action": "list", "mrr_id": None}


def _get_last_user_message(messages) -> str:
    """Extract the last HumanMessage content from the messages list."""
    for msg in reversed(messages):
        if isinstance(msg, HumanMessage):
            return str(msg.content)
    return ""


def _describe_assumed_action_mrr(persona: str, collection: str) -> str:
    """Describe the assumed action for soft-correction messages."""
    persona = (persona or "").lower()
    collection = (collection or "").lower()
    if persona == "creator":
        return "create a material requisition"
    elif persona == "approver":
        return "approve a pending requisition"
    elif persona == "erp_approver":
        return "approve at the ERP stage"
    elif persona == "issuer":
        return "issue stock for a requisition"
    return "do that"


