## FULL NEW _extract_worklog_fields HELPER

```python
def _extract_worklog_fields(message: str) -> dict:
    """
    Extract fields for logging hours from a user message via regex.
    Returns dict with worklog_idx, hours, task_date, remarks, and errors.
    """
    import re
    from datetime import datetime

    result = {
        "worklog_idx": None,
        "hours": None,
        "task_date": None,
        "remarks": None,
        "errors": [],
    }

    # worklog_idx: "task 22", "worklogidx 22", "worklog 22"
    m = re.search(r'(?:worklogidx|worklog|task)\s+(\d+)', message, re.IGNORECASE)
    if m:
        result["worklog_idx"] = int(m.group(1))

    # hours: "8 hours", "8 hrs", "8 hr"
    m = re.search(r'(\d+(?:\.\d+)?)\s*(?:hours|hour|hrs|hr)\b', message, re.IGNORECASE)
    if m:
        result["hours"] = float(m.group(1))

    # task_date: a YYYY-MM-DD date
    m = re.search(r'(\d{4}-\d{2}-\d{2})', message)
    if m:
        result["task_date"] = m.group(1)

    # remarks: 'remark "X"' / 'remarks "X"' / 'remark X' / 'with remark X'
    rm = re.search(r'remarks?\s+["\u201c\u2018\']([^"\u201d\u2019\']+)["\u201d\u2019\']', message, re.IGNORECASE)
    if rm:
        result["remarks"] = rm.group(1).strip()
    else:
        rm2 = re.search(r'remarks?\s+(.+?)\s*$', message, re.IGNORECASE)
        if rm2:
            result["remarks"] = rm2.group(1).strip()

    # ---- VALIDATION ----
    if result["worklog_idx"] is None:
        result["errors"].append("missing task id (e.g. 'task 22')")

    if result["hours"] is None:
        result["errors"].append("missing hours (e.g. '8 hours')")
    elif result["hours"] <= 0:
        result["errors"].append("hours must be positive")

    if result["task_date"] is None:
        result["errors"].append("missing date (e.g. '2026-05-26')")
    else:
        try:
            parsed = datetime.strptime(result["task_date"], "%Y-%m-%d")
            if parsed.month < 1 or parsed.month > 12:
                raise ValueError
        except ValueError:
            result["errors"].append(
                f"invalid date {result['task_date']} (use YYYY-MM-DD, month 01-12)"
            )

    if not result["remarks"]:
        result["errors"].append("missing remark (e.g. 'remark \"design work\"')")

    return result
