"""
Multi-model ReAct viability diagnostic.

Tests whether different LLMs can drive a LangChain ReAct agent
reliably. Uses fake in-memory tools. Prints detailed diagnostics
per model for a side-by-side comparison report.

Run: python investigate_react_multimodel.py
Edit MODELS_TO_TEST below to add the model identifiers you have.
"""

import sys
import json
import traceback
from typing import Optional

# ---- inspect these and import correctly ----
# from app.core.llm import ...   (figure out the right constructor)
# from app.core.config import ... (for base_url / api_key if needed)

from langchain.agents import AgentExecutor, create_react_agent
from langchain_core.tools import tool
from langchain_core.prompts import PromptTemplate
from langchain_core.callbacks import BaseCallbackHandler


# ============================================================
# CONFIGURE MODELS HERE
# ============================================================
MODELS_TO_TEST = [
    "claude-opus-4-6",
    # "<another-model-id>",
    # "<another-model-id>",
]


# ============================================================
# Fake in-memory tools — with PRINT statements so we SEE invocation
# ============================================================
TOOL_CALL_LOG = []

@tool
def list_tasks_tool(resource_id: Optional[int] = None) -> str:
    """List tasks. Optionally filter by resource_id."""
    print(f"    >>> [REAL TOOL INVOKED] list_tasks_tool(resource_id={resource_id})")
    TOOL_CALL_LOG.append(("list_tasks_tool", {"resource_id": resource_id}))
    fake = [
        {"task_id": 1, "resource_id": 3010, "project_id": 100, "hours": 8},
        {"task_id": 2, "resource_id": 2291, "project_id": 200, "hours": 16},
    ]
    if resource_id is not None:
        fake = [t for t in fake if t["resource_id"] == resource_id]
    if not fake:
        return "No tasks found."
    return "; ".join(f"Task {t['task_id']} (res {t['resource_id']}, proj {t['project_id']}, {t['hours']}h)" for t in fake)


@tool
def create_task_tool(resource_id: int, project_id: int, hours: int) -> str:
    """Create a new task. Requires resource_id, project_id, hours."""
    print(f"    >>> [REAL TOOL INVOKED] create_task_tool(resource_id={resource_id}, project_id={project_id}, hours={hours})")
    TOOL_CALL_LOG.append(("create_task_tool", {"resource_id": resource_id, "project_id": project_id, "hours": hours}))
    return f"Created task for resource {resource_id}, project {project_id}, {hours}h."


# ============================================================
# Callback handler to capture RAW LLM output
# ============================================================
class RawOutputCapture(BaseCallbackHandler):
    def __init__(self):
        self.raw_outputs = []

    def on_llm_end(self, response, **kwargs):
        try:
            for gen_list in response.generations:
                for gen in gen_list:
                    self.raw_outputs.append(gen.text)
        except Exception:
            pass


REACT_PROMPT = PromptTemplate.from_template("""Answer the following questions as best you can. You have access to the following tools:

{tools}

Use the following format:

Question: the input question you must answer
Thought: you should always think about what to do
Action: the action to take, should be one of [{tool_names}]
Action Input: the input to the action
Observation: the result of the action
... (this Thought/Action/Action Input/Observation can repeat N times)
Thought: I now know the final answer
Final Answer: the final answer to the original input question

Begin!

Question: {input}
Thought:{agent_scratchpad}""")


def build_llm_for_model(model_name: str):
    """
    Build an LLM instance for the given model name, using the same
    endpoint/credentials the app uses. INSPECT app/core/llm.py and
    app/core/config.py to fill this in correctly.
    """
