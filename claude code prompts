import sys
import traceback
from typing import Optional

# Import the real LLM the app uses
from app.core.llm import get_llm

# LangChain agent imports
from langchain.agents import AgentExecutor, create_react_agent
from langchain_core.tools import tool
from langchain_core.prompts import PromptTemplate


# ---- Fake in-memory data store (so we test the agent, not the DB) ----
FAKE_TASKS = [
    {"task_id": 1, "resource_id": 3010, "project_id": 100, "hours": 8},
    {"task_id": 2, "resource_id": 2291, "project_id": 200, "hours": 16},
]


@tool
def list_tasks_tool(resource_id: Optional[int] = None) -> str:
    \"\"\"List tasks. Optionally filter by resource_id. Returns a text summary of tasks.\"\"\"
    if resource_id is not None:
        rows = [t for t in FAKE_TASKS if t["resource_id"] == resource_id]
    else:
        rows = FAKE_TASKS
    if not rows:
        return "No tasks found."
    return "\\n".join(
        f"Task {t['task_id']}: resource={t['resource_id']}, project={t['project_id']}, hours={t['hours']}"
        for t in rows
    )


@tool
def create_task_tool(resource_id: int, project_id: int, hours: int) -> str:
    \"\"\"Create a new task. Requires resource_id, project_id, and hours. Returns confirmation.\"\"\"
    new_id = max(t["task_id"] for t in FAKE_TASKS) + 1 if FAKE_TASKS else 1
    FAKE_TASKS.append({
        "task_id": new_id, "resource_id": resource_id,
        "project_id": project_id, "hours": hours
    })
    return f"Created task {new_id} for resource {resource_id} on project {project_id} with {hours} hours."


# ---- Standard ReAct prompt (from LangChain hub, inlined) ----
REACT_PROMPT = PromptTemplate.from_template(\"\"\"Answer the following questions as best you can. You have access to the following tools:

{tools}

Use the following format:

Question: the input question you must answer
Thought: you should always think about what to do
Action: the action to take, should be one of [{tool_names}]
Action Input: the input to the action
Observation: the result of the action
... (this Thought/Action/Action Input/Observation can repeat N times)
Thought: I now know the final answer
Final Answer: the final answer to the original input question

Begin!

Question: {input}
Thought:{agent_scratchpad}\"\"\")


def run_test(test_name: str, query: str):
    print("=" * 70)
    print(f"TEST: {test_name}")
    print(f"QUERY: {query}")
    print("-" * 70)
    try:
        llm = get_llm()
        tools = [list_tasks_tool, create_task_tool]
        agent = create_react_agent(llm, tools, REACT_PROMPT)
        executor = AgentExecutor(
            agent=agent,
            tools=tools,
            verbose=True,            # prints the Thought/Action loop
            handle_parsing_errors=True,  # don't crash on bad format
            max_iterations=5,        # prevent infinite loops
        )
        result = executor.invoke({"input": query})
        print("-" * 70)
        print(f"RESULT: {result.get('output')}")
        print(f"TEST {test_name}: COMPLETED")
    except Exception as e:
        print(f"TEST {test_name}: FAILED with exception:")
        traceback.print_exc()
    print("=" * 70)
    print()


if __name__ == "__main__":
    print("\\n\\nReAct Agent Viability Test — using internal LLM\\n\\n")

    run_test("1_list_all", "Show me all tasks.")
    run_test("2_list_filtered", "Show me tasks for resource 3010.")
    run_test("3_create", "Create a task for resource 5000 on project 300 with 12 hours.")
    run_test("4_create_then_list", "Create a task for resource 6000 on project 400 with 4 hours, then show all tasks.")
    run_test("5_ambiguous", "I want to add some work.")

    print("\\n\\nInvestigation complete. Review the output above.\\n")
    print("KEY QUESTIONS:")
    print("1. Did the agent emit proper 'Action:' / 'Action Input:' format?")
    print("2. Did tools actually get invoked (look for tool output in observations)?")
    print("3. Were there parsing errors ('Could not parse LLM output')?")
    print("4. Did any test hit max_iterations (infinite loop)?")
    print("5. Did the final answers make sense?")

