-- Add CTO emp 5 as Senior (role 9)
INSERT IGNORE INTO dpah_user_roles (emp_id, role_id, assigned_by)
VALUES ('5', 9, 'system');

-- Map MRR module (5) to CTO's group_idx 30
INSERT IGNORE INTO dpah_module_usergroups (module_id, group_idx, is_active, assigned_by)
VALUES (5, 30, 1, 'system');

-- Grant CTO (Senior, group 30) access to manager approver agent
INSERT IGNORE INTO dpah_role_agent_access (role_id, group_id, agent_id, granted_by)
SELECT 9, 30, a.agent_id, 'system'
FROM dpah_agents a
WHERE a.agent_name = 'MRR_GENERAL_MANAGER_APPROVER';

-- Verify
SELECT raa.role_id, raa.group_id, a.agent_name
FROM dpah_role_agent_access raa
JOIN dpah_agents a ON a.agent_id = raa.agent_id
WHERE raa.group_id = 30 AND a.agent_name LIKE 'MRR_%';

