def _extract_task_fields(message: str, current_emp_no: str) -> dict:
    """
    Extract the 8 task fields from a user message using regex.
    Returns a dict with all fields as int|float|str|None and an "errors" list.
    """
    import re
    from datetime import datetime

    result = {
        "resource_id": None,
        "project_id": None,
        "product_id": None,
        "task_idx": None,
        "activity_idx": None,
        "start_date": None,
        "end_date": None,
        "plan_hrs": None,
        "errors": [],
    }

    # resource_id: "for myself" / "for me" -> current_emp_no, else numeric capture
    if re.search(r'\bfor\s+(myself|me)\b', message, re.IGNORECASE):
        result["resource_id"] = int(current_emp_no)
    else:
        m = re.search(r'(?:emp|employee|resource|for)\s+(\d+)', message, re.IGNORECASE)
        if m:
            result["resource_id"] = int(m.group(1))

    # project_id
    m = re.search(r'proj(?:ect)?\s*(?:id)?\s+(\d+)', message, re.IGNORECASE)
    if m:
        result["project_id"] = int(m.group(1))

    # product_id
    m = re.search(r'prod(?:uct)?\s*(?:id)?\s+(\d+)', message, re.IGNORECASE)
    if m:
        result["product_id"] = int(m.group(1))

    # task_idx
    m = re.search(r'\btask\s*(?:index|idx)?\s+(\d+)', message, re.IGNORECASE)
    if m:
        result["task_idx"] = int(m.group(1))

    # activity_idx
    m = re.search(r'\bactivity\s*(?:index|idx)?\s+(\d+)', message, re.IGNORECASE)
    if m:
        result["activity_idx"] = int(m.group(1))

    # dates: "from YYYY-MM-DD to YYYY-MM-DD"
    dm = re.search(r'from\s+(\d{4}-\d{2}-\d{2})\s+to\s+(\d{4}-\d{2}-\d{2})', message, re.IGNORECASE)
    if dm:
        result["start_date"] = dm.group(1)
        result["end_date"] = dm.group(2)

    # plan_hrs: "<number> hours/hr/hrs/hour"
    m = re.search(r'(\d+(?:\.\d+)?)\s*(?:hours|hour|hrs|hr)\b', message, re.IGNORECASE)
    if m:
        result["plan_hrs"] = float(m.group(1))

    # ---- VALIDATION ----
    int_fields = {
        "resource_id": result["resource_id"],
        "project_id": result["project_id"],
        "product_id": result["product_id"],
        "task_idx": result["task_idx"],
        "activity_idx": result["activity_idx"],
    }
    for field_name, value in int_fields.items():
        if value is None:
            result["errors"].append(f"missing {field_name}")

    # Date validation
    if result["start_date"] is None or result["end_date"] is None:
        if result["start_date"] is None:
            result["errors"].append("missing start date")
        if result["end_date"] is None:
            result["errors"].append("missing end date")
    else:
        valid_dates = True
        for date_str in [result["start_date"], result["end_date"]]:
            try:
                parsed = datetime.strptime(date_str, "%Y-%m-%d")
                if parsed.month < 1 or parsed.month > 12:
                    raise ValueError
            except ValueError:
                result["errors"].append(f"invalid date {date_str} (use YYYY-MM-DD, month 01-12)")
                valid_dates = False

        if valid_dates:
            sd = datetime.strptime(result["start_date"], "%Y-%m-%d")
            ed = datetime.strptime(result["end_date"], "%Y-%m-%d")
            if ed < sd:
                result["errors"].append("end date is before start date")

    # plan_hrs validation
    if result["plan_hrs"] is None:
        result["errors"].append("missing planned hours")
    else:
        if result["plan_hrs"] <= 0:
            result["errors"].append("planned hours must be positive")

    return result


async def creator_agent_node(state: RMSState) -> dict:
    """
    Node 3a: Creator Agent — fully procedural (no LLM).

    Extracts 8 fields from the last user message via regex, validates them,
    then either returns a helpful error message or inserts the task
    directly into the database via timesheet_store.create_task.

    Mirrors the MRR evaluate_and_route procedural pattern.
    """
    print(
        f"[DIAG-RMS] creator_agent_node entered. "
        f"emp_no={state.get('emp_no')}, "
        f"collection={state.get('selected_collection')!r}, "
        f"last_msg={_last_user_msg_short(state)}",
        flush=True
    )

    messages = state.get("messages", [])

    # Step 1: Get last user message
    last_user_message = ""
    for msg in reversed(messages):
        if isinstance(msg, HumanMessage):
            last_user_message = str(getattr(msg, "content", "") or "")
            break

    # Step 2: Get emp_no from state
    current_emp_no = state.get("emp_no", state.get("user_id", ""))

    # Step 3: Extract fields via regex
    fields = _extract_task_fields(last_user_message, current_emp_no)

    execution_log = state.get("execution_log", [])
    execution_log.append("Creator agent: regex field extraction")

    # Step 4: Response logic
    if fields["errors"]:
        error_lines = ["I couldn't create the task. Please fix and resend in one message:"]
        for err in fields["errors"]:
            error_lines.append(f"- {err}")
        error_lines.append("")
        error_lines.append(
            "Example: create a task for emp 3010, project 100, product 10, "
            "task index 1, activity 1, from 2026-05-26 to 2026-05-28, planned 8 hours"
        )
        full_text = "\n".join(error_lines)

        print(
            f"[DIAG-RMS] creator_agent_node returning validation errors. "
            f"error_count={len(fields['errors'])}",
            flush=True
        )

        return {
            "messages": [AIMessage(content=full_text)],
            "execution_log": execution_log,
        }

    # No errors — proceed to DB insert
    try:
        db = SessionLocal()
        try:
            result = timesheet_store.create_task(
                db=db,
                resource_id=fields["resource_id"],
                project_id=fields["project_id"],
                product_id=fields["product_id"],
                task_idx=fields["task_idx"],
                activity_idx=fields["activity_idx"],
                start_date=fields["start_date"],
                end_date=fields["end_date"],
                plan_hrs=fields["plan_hrs"],
                created_by=current_emp_no,
            )
            task_id = result.get("task_id")
            full_text = (
                f"Task created successfully (Task ID: {task_id}) "
                f"for employee {fields['resource_id']}, "
                f"project {fields['project_id']}, "
                f"from {fields['start_date']} to {fields['end_date']}, "
                f"{fields['plan_hrs']} planned hours."
            )
            execution_log.append(f"Task created: id={task_id}")
        except Exception as e:
            db.rollback()
            full_text = f"Could not create the task due to a database error: {e}"
            execution_log.append(f"Task creation failed: {e}")
        finally:
            db.close()
    except Exception as e:
        full_text = f"Could not create the task due to a database error: {e}"
        execution_log.append(f"Session creation failed: {e}")

    print(
        f"[DIAG-RMS] creator_agent_node returning. "
        f"full_text_len={len(full_text)}",
        flush=True
    )

    return {
        "messages": [AIMessage(content=full_text)],
        "execution_log": execution_log,
    }
