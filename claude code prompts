@staticmethod
    async def parse_uploaded_file(filename: str, content: bytes) -> dict:
        filename_lower = filename.lower()
        if filename_lower.endswith('.csv'):
            file_type = 'csv'
        elif filename_lower.endswith(('.xlsx', '.xls')):
            file_type = 'excel'
        else:
            raise ValueError(f"Unsupported file type: {filename}. Only CSV and Excel files are supported.")

        if file_type == 'csv':
            return ChatController._parse_csv(filename, content)
        else:
            return await ChatController._parse_excel(filename, content)
