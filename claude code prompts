"""
MRR Helper Utilities
=====================
Small utility functions specific to MRR number generation and financial year.
"""

from datetime import datetime

from app.services import mariadb_queries


def current_financial_year() -> str:
    """
    Returns the current Indian financial year as a string like "25-26".
    Indian FY runs April 1 to March 31.
    """
    now = datetime.now()
    if now.month >= 4:
        fy_start = now.year
    else:
        fy_start = now.year - 1
    return f"{str(fy_start)[2:]}-{str(fy_start + 1)[2:]}"


def build_mrr_number(seq: int, fy: str) -> str:
    """Returns f'DPE/MRR/{seq}/{fy}'."""
    return f"DPE/MRR/{seq}/{fy}"


def next_mrr_number() -> tuple:
    """
    Combines current FY and next sequence number.
    Returns (next_seq, mrr_number_string).
    Example: (1, "DPE/MRR/1/26-27") if FY just rolled over.
    """
    fy = current_financial_year()
    last_seq = mariadb_queries.get_max_mrr_sequence_for_fy(fy)
    next_seq = last_seq + 1
    return (next_seq, build_mrr_number(next_seq, fy))
