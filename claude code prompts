SELECT cs.DP_PART_NO, cs.ITEMID, cs.UOM, cs.QOH,
       si.LPP_VALUE_UNITPRICE_INR, si.UNITOFMEASUREID
FROM com_search cs
JOIN SCMITEMS si ON si.ITEMID = cs.ITEMID AND si.WAREHOUSEID = 1
WHERE cs.WAREHOUSE = '1'
  AND si.LPP_VALUE_UNITPRICE_INR IS NOT NULL
  AND si.LPP_VALUE_UNITPRICE_INR > 0
LIMIT 10;

