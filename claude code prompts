def build_schema_description(collection: str, persona: str, emp_id: str, dept: str) -> str:
    """
    Build the schema description string to inject into the LLM prompt.
    Resolves persona filters with actual user emp_id and dept at runtime.
    Never called with RBAC system tables.
    """
    if collection not in COLLECTION_TABLE_MAP:
        return f"No schema available for collection: {collection}"

    config = COLLECTION_TABLE_MAP[collection]
    filters = config["persona_filters"].get(persona, {})
    blocks = []

    for table_name, table_info in config["tables"].items():
        raw_filter = filters.get(table_name)

        if raw_filter:
            resolved = raw_filter.format(emp_id=emp_id, dept=dept)
            access_rule = f"ACCESS RULE: You MUST include WHERE {resolved} in every query on this table."
        else:
            access_rule = "ACCESS RULE: No row restriction. You may query all rows in this table."

        col_lines = "\n".join(
            f"    {col}: {desc}"
            for col, desc in table_info["columns"].items()
        )

        blocks.append(
            f"TABLE: {table_name}\n"
            f"Purpose: {table_info['purpose']}\n"
            f"Columns:\n{col_lines}\n"
            f"{access_rule}"
        )

    return "\n\n---\n\n".join(blocks)
4.3 SQL Validator (analytics_workflow/sql_validator.py)
python
import re
from typing import Tuple
from app.workflows.analytics_workflow.schema_registry import COLLECTION_TABLE_MAP

FORBIDDEN_KEYWORDS = {
    "INSERT", "UPDATE", "DELETE", "DROP", "ALTER",
    "TRUNCATE", "EXEC", "EXECUTE", "CALL", "CREATE",
    "GRANT", "REVOKE", "REPLACE", "MERGE",
}

def validate_sql(
    sql: str,
    collection: str,
    persona: str,
    emp_id: str,
) -> Tuple[bool, str]:
    """
    Validate LLM-generated SQL before execution.
    Returns (is_valid: bool, error_message: str).
    Empty error_message means valid.
    """
    if not sql or not sql.strip():
        return False, "Empty SQL generated."

    sql_upper = sql.upper().strip()

    # Rule 1: Must start with SELECT
    if not sql_upper.startswith("SELECT"):
        return False, "Only SELECT queries are permitted."

    # Rule 2: No forbidden keywords anywhere in the query
    for keyword in FORBIDDEN_KEYWORDS:
        pattern = r'\b' + keyword + r'\b'
        if re.search(pattern, sql_upper):
            return False, f"Forbidden keyword detected: {keyword}"

    # Rule 3: Only allowed tables referenced
    allowed_tables = set(
        COLLECTION_TABLE_MAP.get(collection, {}).get("tables", {}).keys()
    )
    # Extract table names from FROM and JOIN clauses (simple regex approach)
    table_references = re.findall(
        r'\bFROM\s+(\w+)|\bJOIN\s+(\w+)', sql_upper
    )
    referenced = {t for pair in table_references for t in pair if t}
    disallowed = referenced - {t.upper() for t in allowed_tables}
    if disallowed:
        return False, f"Query references unauthorized tables: {disallowed}"

    # Rule 4: Reviewer persona must have filter for restricted tables
    if persona == "reviewer":
        filters = COLLECTION_TABLE_MAP.get(collection, {}).get(
            "persona_filters", {}
        ).get("reviewer", {})
        for table, filter_rule in filters.items():
            if filter_rule and table.upper() in referenced:
                # Check emp_id appears in the SQL (simple presence check)
                if emp_id not in sql:
                    return False, (
                        f"Query on {table} must include the user access filter. "
                        f"Expected filter contains emp_id={emp_id}."
                    )

    return True, ""
