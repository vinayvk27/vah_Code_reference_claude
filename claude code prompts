STEP 1 — New endpoint: validate-handoff
==============================================================================
In the agentic dashboard's Python backend, add a new route:

  POST /api/v1/auth/validate-handoff
  Body: { "token": str }

  Implementation:
  
  import jwt  # same library DPAH uses
  import os
  from datetime import datetime, timedelta
  
  SHARED_JWT_SECRET = os.getenv("JWT_SECRET")  # MUST match DPAH's secret
  JWT_ALGORITHM = "HS256"                        # MUST match DPAH's algorithm
  
  @router.post("/validate-handoff")
  def validate_handoff(payload: HandoffRequest):
      try:
          # Decode and verify the 60-second handoff token
          decoded = jwt.decode(
              payload.token,
              SHARED_JWT_SECRET,
              algorithms=[JWT_ALGORITHM]
          )
          
          # Reject if it's not a handoff token
          if decoded.get("type") != "handoff":
              return {"valid": False, "reason": "Not a handoff token"}
          
          # Issue a new full-duration token for this session
          new_payload = {
              "sub": decoded["sub"],
              "name": decoded.get("name", ""),
              "email": decoded.get("email", ""),
              "dept": decoded.get("dept", ""),
              "roles": decoded.get("roles", []),
              "collection_agents": decoded.get("collection_agents", {}),
              "exp": datetime.utcnow() + timedelta(hours=8),
              "iat": datetime.utcnow(),
          }
          
          new_token = jwt.encode(new_payload, SHARED_JWT_SECRET, algorithm=JWT_ALGORITHM)
          
          # Build user_profile shape that the frontend expects
          user_profile = {
              "emp_no": decoded["sub"],
              "name": decoded.get("name", ""),
              "email": decoded.get("email", ""),
              "dept": decoded.get("dept", ""),
              "roles": decoded.get("roles", []),
          }
          
          return {
              "valid": True,
              "access_token": new_token,
              "user_profile": user_profile,
          }
      
      except jwt.ExpiredSignatureError:
          return {"valid": False, "reason": "Handoff token expired"}
      except jwt.InvalidTokenError:
          return {"valid": False, "reason": "Invalid token"}

  Create a Pydantic model for the request body:
