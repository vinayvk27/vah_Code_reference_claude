import pandas as pd
from app.services.mrr_validator import validate_and_resolve_mrr_excel
from app.models.dto_schemas import CurrentUser

df = pd.read_excel("test_mrr.xlsx")
data = df.to_dict(orient="records")

user = CurrentUser(
    emp_no="1065",
    name="Arun Test",
    email="test@dp.local",
    hierarchy="ENG/SDG",
    group_idx=1,
    role_ids=[7],
    role_names=["Junior"],
    dept="SDG"
)

result = validate_and_resolve_mrr_excel(data, user)
print("VALID:", result["valid"])
print("ERRORS:", result.get("errors"))
print("WARNINGS:", result.get("warnings"))
if result["valid"]:
    print("\nHEADER:")
    for k, v in result["header"].items():
        print(f"  {k}: {v}")
    print(f"\nLINES ({len(result['lines'])}):")
    for line in result["lines"]:
        print(f"  {line}")
    print(f"\nSUMMARY:\n{result['summary_for_user']}")