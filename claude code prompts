"""
MRR Intent Classification
=========================
Deterministic keyword-based classifier for MRR workflow routing.

No LLM call — fast, reliable, reproducible.

The classifier returns an MRRIntentClassification with:
  - domain: "IN_DOMAIN" or "OUT_OF_DOMAIN"
  - collection: "mrr_general"
  - persona: "CREATOR", "APPROVER", "ERP_APPROVER", "ISSUER", or ""
  - confidence: "HIGH", "MEDIUM", or "LOW"
  - reasoning: short explanation

Uses Pydantic for structured output.
"""

import re

from pydantic import BaseModel, Field
from typing import Literal

# =============================================================================
# MODULE DOMAIN DESCRIPTION
# =============================================================================

MODULE_DOMAIN_DESCRIPTION = """The MRR (Material Requisition Request) module handles material/stock requisitions in the SCM domain.
Available collections:
  - mrr_general: create material requisitions, view pending approvals, approve at manager stage, approve at ERP stage, issue stock (nominal).
Available personas:
  - CREATOR: creates new material requisitions, requests items by quantity.
  - APPROVER: CTO/COO who approve manager-stage requisitions.
  - ERP_APPROVER: ERP HOD who approves at ERP stage.
  - ISSUER: store issuer who handles stock issuance (nominal, not functionally implemented)."""

# =============================================================================
# KEYWORDS — ordered by priority (more specific first)
# =============================================================================

OUT_OF_DOMAIN_KEYWORDS = [
    "weather", "joke", "salary", "leave", "payslip",
    "hello", "hi there", "good morning", "good evening",
    "who are you", "what can you do", "help me",
]

ISSUER_KEYWORDS = [
    "issue stock", "issue material", "issue items",
    "stock issue", "release stock", "release to floor",
    "ready for issue", "items to issue", "pending issue",
]

ERP_APPROVER_KEYWORDS = [
    "erp approve", "erp approval", "erp pending",
    "show erp approvals", "show erp pending", "erp queue",
    "approve from erp", "final approval", "final approve",
    "ready for erp", "release to erp",
]

APPROVER_KEYWORDS = [
    "approve all", "approve pending",
    "show pending approvals", "show pending approval",
    "show approvals", "pending approvals", "approval queue",
    "reject", "approve mrr", "approve requisition",
    "approve ", "decline ",
]

CREATOR_KEYWORDS = [
    "create mrr", "create requisition",
    "new mrr", "new requisition",
    "raise mrr", "raise requisition",
    "submit mrr", "submit requisition",
    "upload mrr", "process mrr",
    "process this mrr", "process this excel",
    "process this file", "upload material requisition",
    "process file", "import this",
]

# =============================================================================
# PYDANTIC MODEL
# =============================================================================


class MRRIntentClassification(BaseModel):
    """Structured output for MRR intent classification."""

    domain: Literal["IN_DOMAIN", "OUT_OF_DOMAIN"] = Field(
        description='Whether the user message falls within MRR scope.'
    )
    collection: str = Field(
        description='Which MRR collection the request targets: "mrr_general" or empty if out of domain.'
    )
    persona: str = Field(
        description='Which persona the request targets: "CREATOR", "APPROVER", "ERP_APPROVER", "ISSUER", or empty if out of domain.'
    )
    confidence: Literal["HIGH", "MEDIUM", "LOW"] = Field(
        description='Confidence level in the classification.'
    )
    reasoning: str = Field(
        description='One-sentence explanation of the classification.'
    )


# =============================================================================
# CLASSIFIER
# =============================================================================


def _normalize(message: str) -> str:
    """Lowercase, strip leading/trailing whitespace, collapse internal whitespace."""
    if not message:
        return ""
    text = message.lower().strip()
    # Replace common punctuation with spaces so word-boundary matches work
    text = re.sub(r"[,.;:!?'\"()\\[\\]{}]+", " ", text)
    text = re.sub(r"\s+", " ", text)
    return text


def _build_in_domain(collection: str, persona: str, confidence: str, reasoning: str) -> MRRIntentClassification:
    """Build the Pydantic classification object for an IN_DOMAIN match."""
    return MRRIntentClassification(
        domain="IN_DOMAIN",
        collection=collection,
        persona=persona,
        confidence=confidence,
        reasoning=reasoning,
    )


def _build_out_of_domain(reasoning: str) -> MRRIntentClassification:
    return MRRIntentClassification(
        domain="OUT_OF_DOMAIN",
        collection="",
        persona="",
        confidence="HIGH",
        reasoning=reasoning,
    )


def classify_mrr_intent(user_message: str) -> MRRIntentClassification:
    """
    Keyword-based intent classifier for MRR.
    No LLM call — deterministic.
    """
    text = _normalize(user_message)

    if not text:
        return _build_out_of_domain("Empty message")

    # Step 1: Out-of-domain check (so unrelated requests are rejected).
    for kw in OUT_OF_DOMAIN_KEYWORDS:
        if kw in text:
            return _build_out_of_domain(f"Matched out-of-domain keyword: {kw}")

    # Step 2: ERP approver (most specific).
    for kw in ERP_APPROVER_KEYWORDS:
        if kw in text:
            return _build_in_domain(
                collection="mrr_general",
                persona="erp_approver",
                confidence="HIGH",
                reasoning=f"Matched ERP approver keyword: {kw}",
            )

    # Step 3: Issuer.
    for kw in ISSUER_KEYWORDS:
        if kw in text:
            return _build_in_domain(
                collection="mrr_general",
                persona="issuer",
                confidence="HIGH",
                reasoning=f"Matched issuer keyword: {kw}",
            )

    # Step 4: Approver (manager).
    for kw in APPROVER_KEYWORDS:
        if kw in text:
            return _build_in_domain(
                collection="mrr_general",
                persona="approver",
                confidence="HIGH",
                reasoning=f"Matched approver keyword: {kw}",
            )

    # Step 5: Creator.
    for kw in CREATOR_KEYWORDS:
        if kw in text:
            return _build_in_domain(
                collection="mrr_general",
                persona="creator",
                confidence="HIGH",
                reasoning=f"Matched creator keyword: {kw}",
            )

    # Step 6: No keyword matched — treat as out-of-domain.
    # Creator action requires explicit phrasing per CREATOR_KEYWORDS.
    return _build_out_of_domain(
        "No MRR-related keyword matched. Treating as out-of-domain."
    )
