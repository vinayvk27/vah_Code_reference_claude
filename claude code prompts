"""
Optional LLM reasoning addon for procedural workflow outputs.

Takes the deterministic confirmation text and appends a short
explanatory sentence. On any failure, returns the original text
unchanged.
"""

from app.core.config import settings


def add_reasoning(original_message: str, context: str) -> str:
    """
    Optionally append a short LLM-generated reasoning sentence to a
    deterministic success message. ALWAYS returns a string. If the
    feature is disabled or the LLM call fails, returns the original
    message unchanged.

    Args:
        original_message: the deterministic procedural output. This
            is what the user MUST see; the LLM only adds context.
        context: a brief description of what the procedural step did,
            used to prompt the LLM. Plain text, no formatting needed.

    Returns:
        original_message [+ "\n\n" + reasoning sentence] on success.
        original_message unchanged on disable/failure.
    """
    if not getattr(settings, "ENABLE_REASONING_ADDON", False):
        return original_message

    try:
        from app.core.llm import get_llm
        llm = get_llm()

        prompt = (
            "You are explaining a workflow action briefly to a user.\n"
            "The system has ALREADY completed the action and produced "
            "the confirmation below. Your job is to add ONE short, "
            "friendly sentence (max 25 words) that explains what just "
            "happened or what to expect next. Do NOT repeat the "
            "confirmation. Do NOT add bullet points, markdown, or "
            "headers. Plain prose, one sentence.\n\n"
            f"Action context: {context}\n\n"
            f"System confirmation:\n{original_message}\n\n"
            "Your one-sentence addition:"
        )

        # Use synchronous invoke; this is called from sync paths.
        # If get_llm() returns a streaming-only LLM, the invoke method
        # should still work (LangChain ChatOpenAI supports both).
        response = llm.invoke(prompt)
        reasoning = getattr(response, "content", "") or ""
        reasoning = reasoning.strip()

        if not reasoning:
            return original_message

        # Strip any leading/trailing quotes, code fences, list bullets
        for prefix in ("- ", "* ", "> ", "\"", "'"):
            if reasoning.startswith(prefix):
                reasoning = reasoning[len(prefix):].strip()
        for suffix in ("\"", "'"):
            if reasoning.endswith(suffix):
                reasoning = reasoning[:-1].strip()

        return f"{original_message}\n\n{reasoning}"

    except Exception as e:
        # Silent fallback — log to stderr for diagnostics but never
        # propagate the failure to the user.
        try:
            print(f"[REASONING-ADDON] Failed; returning original. err={e}", flush=True)
        except Exception:
            pass
        return original_message


