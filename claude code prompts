        'shadow-lg shadow-black/5 dark:shadow-black/20',
        'backdrop-blur-sm',
        sz.p,
      ].join(' ')}
      style={{ minWidth: 280, maxWidth: 560, resize: 'horizontal', overflow: 'auto' }}
    >
      {/* ── Title Bar ── */}
      <div className="flex items-center gap-2.5 mb-4 pb-3 border-b border-slate-100 dark:border-slate-700/60">
        <div className="w-1 h-5 rounded-full bg-blue-500 shrink-0" />
