STEP 3 — Build preview message helper
───────────────────────────────────────────────────────────────────

In nodes.py, add a helper that builds the "Review Before Submit"
preview message from a pending_mrr_data dict. This is the same
format the Excel path currently uses.

def _build_mrr_preview_message(pending: dict) -> str:
    \"""Build the 'Review Before Submit' preview from pending_mrr_data.\"""
    header = pending.get("header", {})
    lines = pending.get("lines", [])

    lines_text = []
    for line in lines:
        item_part = (
            f"    {line.get('item_code', line.get('item_id', 'N/A'))} "
            f"— UOM: {line.get('uom', 'N/A')}\n"
            f"    Qty: {line.get('requisition_qty')} "
            f"| Available: {line.get('available_qty', 'N/A')}\n"
            f"    Unit Cost (LPP): {line.get('unit_price', 'N/A')} "
            f"| Subtotal: {line.get('item_cost', 'N/A')}"
        )
        if line.get('return_date'):
            item_part += f"\n    Return by: {line.get('return_date')}"
        lines_text.append(item_part)

    items_block = "\n\n".join(lines_text)

    preview = (
        f"**Material Requisition — Review Before Submit**\n\n"
        f"MRR Number: {header.get('mrr_no', 'N/A')}\n"
        f"Requestor: emp {header.get('requestor_id', 'N/A')}\n"
        f"Department: {header.get('department', 'N/A')}\n"
        f"Project: {header.get('project_code', header.get('project_id', 'N/A'))}"
        f" — {header.get('description', '')}\n"
        f"Phase: {header.get('phase_name', header.get('project_phase_id', 'N/A'))}\n"
        f"Requisition Type: {header.get('req_transaction_type', 'N/A')}\n"
        f"Need by: {header.get('need_by_date', 'N/A')}\n"
        f"Comments: {header.get('comments', '')}\n\n"
        f"**Line Items:**\n\n{items_block}\n\n"
        f"**Total Cost: {header.get('total_cost', 0):,.2f}**\n\n"
        f"Type **confirm** to submit or **cancel** to discard."
    )
    return preview

NOTE: The field names in pending_mrr_data must match what the Excel
handler and form submit handler store. Inspect the existing
excel_handler_node to see exact field names used in pending_mrr_data
dict, and align this helper to match. If field names differ between
