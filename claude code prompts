#MySQL Tables
#Request Creation table
CREATE TABLE `dpintranet`.`mrr_matrequisitionheader` (
    `MATREQUISITIONID` BIGINT,
    `MATREQUISITIONNO` VARCHAR(40),
    `WAREHOUSEID` BIGINT,
    `REQUISITIONTYPE` VARCHAR(50),
    `REQUESTORID` BIGINT,
    `REQUISITIONDATE` DATETIME,
    `DEPARTMENTID` BIGINT,
    `NEEDBYDATE` DATETIME,
    `WHOCOLUMN` VARCHAR(100),
    `STATUS` VARCHAR(50),
    `PROJECTID` BIGINT,
    `PROJECTPHASEID` BIGINT,
    `REQTRANSACTIONTYPE` VARCHAR(50),
    `SUPPLIERID` BIGINT,
    `SUPPLIERSITEID` BIGINT,
    `DESCRIPTION` VARCHAR(250),
    `COMMENTS` VARCHAR(250),
    `VERIFICATION_STATUS` VARCHAR(50),
    `VERIFICATION_DATE` DATETIME,
    `APPROVAL_STATUS` VARCHAR(50),
    `APPROVAL_DATE` DATETIME,
    `ERP_APPROVAL_STATUS` VARCHAR(50),
    `ERP_APPROVAL_DATE` DATETIME,
    PRIMARY KEY (`MATREQUISITIONID`)
);

