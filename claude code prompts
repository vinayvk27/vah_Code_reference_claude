        return 0
    finally:
        if session:
            session.close()


def get_max_mrr_sequence_for_fy(fy_string: str) -> int:
    session = None
    try:
        session = SessionLocal()
        pattern = f"DPE/MRR/%/{fy_string}"
        rows = session.execute(
            text("SELECT MATREQUISITIONNO FROM mrr_matrequisitionheader WHERE MATREQUISITIONNO LIKE :pattern"),
            {"pattern": pattern},
        ).fetchall()

        max_seq = 0
        for r in rows:
            no = r.MATREQUISITIONNO
            if no and isinstance(no, str):
                parts = no.split("/")
                if len(parts) >= 3:
                    try:
                        seq = int(parts[2])
                        if seq > max_seq:
                            max_seq = seq
                    except (ValueError, TypeError):
                        pass

        return max_seq
    except Exception as e:
        logger.warning("get_max_mrr_sequence_for_fy failed for FY '%s': %s", fy_string, e)
        return 0
    finally:
        if session:
            session.close()


def get_existing_mrr_numbers_count() -> int:
    session = None
    try:
        session = SessionLocal()
        row = session.execute(
            text("SELECT COUNT(*) as cnt FROM mrr_matrequisitionheader")
        ).first()
        return int(row.cnt) if row else 0
    except Exception as e:
        logger.warning("get_existing_mrr_numbers_count failed: %s", e)
        return 0
    finally:
        if session:
            session.close()
