SELECT cs.DP_PART_NO, cs.ITEMID, cs.UOM, cs.QOH,
       si.LPP_VALUE_UNITPRICE_INR, si.UNITOFMEASUREID
FROM com_search cs
JOIN SCMITEMS si ON si.ITEMID = cs.ITEMID AND si.WAREHOUSEID = 1
WHERE cs.WAREHOUSE = '1'
  AND si.LPP_VALUE_UNITPRICE_INR IS NOT NULL
  AND si.LPP_VALUE_UNITPRICE_INR > 0
LIMIT 10;

SELECT projectid, projectnumber, projectdescription
FROM posproject
LIMIT 5;

SELECT pp.projectphaseid, pp.phasename
FROM posprojectphases pp
JOIN posproject p ON p.projectid = pp.projectid
WHERE p.projectnumber = '<one of the project numbers from step 2>'
LIMIT 5;