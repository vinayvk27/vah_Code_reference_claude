#Request's Line Item Detail table
CREATE TABLE `dpintranet`.`mrr_matrequisitionlines` (
    `MATREQUISITIONLINEID` BIGINT,
    `MATREQUISITIONID` BIGINT,
    `ITEMID` BIGINT,
    `ITEMREVISIONID` BIGINT,
    `UOMID` BIGINT,
    `REQUISITIONQTY` DECIMAL(15, 4),
    `ISSUEQTY` DECIMAL(15, 4),
    `WHOCOLUMN` VARCHAR(100),
    `RETURNQUANTITY` DECIMAL(15, 4),
    `STATUS` VARCHAR(25),
    `CLOSEREASON` VARCHAR(4000),
    `ITEMCOST` DECIMAL(15, 4),
    PRIMARY KEY (`MATREQUISITIONLINEID`),
    CONSTRAINT `FKEY_MATREQUISITIONID` FOREIGN KEY (`MATREQUISITIONID`) 
        REFERENCES `dpintranet`.`mrr_matrequisitionheader` (`MATREQUISITIONID`)
);

