import { useState, useRef, useCallback, useEffect } from 'react';
import { Plus, Trash2, AlertCircle, Loader2, ChevronDown, CheckCircle2, Minimize2, Maximize2 } from 'lucide-react';

export default function FormRenderer({ formSpec, formErrors = null, isSubmitting = false, onSubmit, onCancel }) {

  // --- 1. INITIALIZE DYNAMIC STATE ---
  const [formData, setFormData] = useState(() => {
    const initial = {};

    formSpec.fields?.forEach(f => {
      if (f.type === 'items_table') {
        const emptyRow = {};
        f.columns.forEach(c => emptyRow[c.name] = '');
        initial[f.name] = Array.from({ length: f.min_rows || 1 }, () => ({ ...emptyRow }));
      } else if (f.type === 'radio') {
        initial[f.name] = f.default ?? '';
      } else {
        initial[f.name] = f.type === 'checkbox' ? false : '';
      }
    });

    return initial;
  });

  // --- 2. CHANGE HANDLERS ---
  const handleFieldChange = (name, value) => {
    setFormData(prev => ({ ...prev, [name]: value }));
  };

  const handleItemChange = (tableName, rowIndex, colName, value) => {
    setFormData(prev => {
      const updatedTable = [...prev[tableName]];
      updatedTable[rowIndex] = { ...updatedTable[rowIndex], [colName]: value };
      return { ...prev, [tableName]: updatedTable };
    });
  };

  // --- 3. ROW MANAGEMENT ---
  const addRow = (tableName, columns) => {
    const newRow = {};
    columns.forEach(c => newRow[c.name] = '');
    setFormData(prev => ({ ...prev, [tableName]: [...prev[tableName], newRow] }));
  };

  const removeRow = (tableName, rowIndex) => {
    setFormData(prev => ({
      ...prev,
      [tableName]: prev[tableName].filter((_, i) => i !== rowIndex)
    }));
  };

  // --- 4. SUBMIT & CLEANUP ---
  const handleSubmit = (e) => {
    e.preventDefault();

    const cleanedData = JSON.parse(JSON.stringify(formData));

    formSpec.fields?.forEach(field => {
      if (field.type === 'items_table') {
        cleanedData[field.name] = cleanedData[field.name].map(row => {
          const cleanRow = { ...row };
          field.columns.forEach(col => {
            if (col.conditional) {
              const parentVal = formData[col.conditional.field];
              if (parentVal !== col.conditional.value) {
                delete cleanRow[col.name];
              }
            }
          });
          return cleanRow;
        });
      }
    });

    onSubmit(cleanedData, formSpec.form_id);
  };

  // --- 5. HELPER: FIELD EVALUATION ---
  const isColVisible = (col) => {
    if (!col.conditional) return true;
    return formData[col.conditional.field] === col.conditional.value;
  };

  const getError = (path) => {
    return formErrors && formErrors[path] ? formErrors[path] : null;
  };

  // --- 6. AUTOCOMPLETE / TYPEAHEAD ---
  const [debouncedProjectQuery, setDebouncedProjectQuery] = useState('');
  const [debouncedItemQuery, setDebouncedItemQuery] = useState('');
  const projectTimerRef = useRef(null);
  const itemTimerRef = useRef(null);
  const projectInputRef = useRef(null);
  const itemInputRef = useRef(null);

  useEffect(() => {
    const handler = (e) => {
      if (projectInputRef.current && !projectInputRef.current.contains(e.target)) {
        setIsProjectOpen(false);
      }
      if (itemInputRef.current && !itemInputRef.current.contains(e.target)) {
        setIsItemOpen(false);
      }
    };
    document.addEventListener('mousedown', handler);
    return () => document.removeEventListener('mousedown', handler);
  }, []);

  const [isProjectOpen, setIsProjectOpen] = useState(false);
  const [projectSuggestions, setProjectSuggestions] = useState([]);
  const [projectLoading, setProjectLoading] = useState(false);

  const [isItemOpen, setIsItemOpen] = useState(false);
  const [itemSuggestions, setItemSuggestions] = useState([]);
  const [itemLoading, setItemLoading] = useState(false);

  // --- 7. RESIZE + COLLAPSE ---
  const [isExpanded, setIsExpanded] = useState(false);

  // --- 8. TABLE DROPDOWN POSITION (fixed to escape overflow clipping) ---
  const [itemDropdownPos, setItemDropdownPos] = useState(null);

  useEffect(() => {
    if (!debouncedProjectQuery || debouncedProjectQuery.length < 2) {
      setProjectSuggestions([]);
      return;
    }
    setProjectLoading(true);
    const controller = new AbortController();
    fetch(`/api/v1/mrr/search/projects?q=${encodeURIComponent(debouncedProjectQuery)}`, {
      headers: { Authorization: `Bearer ${localStorage.getItem('access_token')}` },
      signal: controller.signal,
    })
      .then((r) => r.json())
      .then((data) => {
        setProjectSuggestions(data.status === 'success' ? data.data : []);
      })
      .catch(() => {})
      .finally(() => setProjectLoading(false));
    return () => controller.abort();
  }, [debouncedProjectQuery]);

  useEffect(() => {
    if (!debouncedItemQuery || debouncedItemQuery.length < 2) {
      setItemSuggestions([]);
      return;
    }
    setItemLoading(true);
    const controller = new AbortController();
    fetch(`/api/v1/mrr/search/items?q=${encodeURIComponent(debouncedItemQuery)}`, {
      headers: { Authorization: `Bearer ${localStorage.getItem('access_token')}` },
      signal: controller.signal,
    })
      .then((r) => r.json())
      .then((data) => {
        setItemSuggestions(data.status === 'success' ? data.data : []);
      })
      .catch(() => {})
      .finally(() => setItemLoading(false));
    return () => controller.abort();
  }, [debouncedItemQuery]);

  const selectProject = useCallback((project) => {
    setFormData((prev) => ({ ...prev, project_id: project.project_id }));
    setIsProjectOpen(false);
    setProjectSuggestions([]);
    setDebouncedProjectQuery('');
  }, []);

  const handleProjectInputChange = useCallback((e) => {
    const val = e.target.value;
    setFormData((prev) => ({ ...prev, project_id: val }));
    clearTimeout(projectTimerRef.current);
    projectTimerRef.current = setTimeout(() => setDebouncedProjectQuery(val), 300);
  }, []);

  const selectItem = useCallback((item) => {
    const { tableName, rowIndex } = activeItemRowRef.current;
    if (!tableName || rowIndex == null) return;
    setFormData((prev) => {
      const updated = [...prev[tableName]];
      updated[rowIndex] = { ...updated[rowIndex], item_name: item.item_code };
      return { ...prev, [tableName]: updated };
    });
    setIsItemOpen(false);
    setItemSuggestions([]);
    setDebouncedItemQuery('');
  }, []);

  const handleItemInputChange = useCallback((tableName, rowIndex, e) => {
    const val = e.target.value;
    setFormData((prev) => {
      const updated = [...prev[tableName]];
      updated[rowIndex] = { ...updated[rowIndex], item_name: val };
      return { ...prev, [tableName]: updated };
    });
    activeItemRowRef.current = { tableName, rowIndex };
    clearTimeout(itemTimerRef.current);
    itemTimerRef.current = setTimeout(() => setDebouncedItemQuery(val), 300);
  }, []);

  const activeItemRowRef = useRef({ tableName: null, rowIndex: null });

  // --- Premium input base styles (reusable constant) ---
  const inputBase = "w-full px-3 py-2 text-[13px] font-medium rounded-lg border bg-white dark:bg-slate-800/80 text-slate-800 dark:text-slate-100 border-slate-200 dark:border-slate-700 placeholder-slate-400 dark:placeholder-slate-500 outline-none transition-all duration-150 focus:bg-white dark:focus:bg-slate-700/60 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/15";
  const labelClass = "block text-[11px] font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-1";
  const errorText = "mt-1 text-[11px] font-medium text-red-400 flex items-center gap-1.5";

  // --- RENDER ---
  return (
    <div className="w-full rounded-2xl border
      border-slate-200 dark:border-slate-700/80
      bg-white dark:bg-slate-800/80
      shadow-lg shadow-black/5 dark:shadow-black/20
      backdrop-blur-sm my-2"
      style={{ resize: 'horizontal', overflow: 'hidden', minWidth: '280px', maxWidth: '680px', overflowX: 'hidden' }}
    >

      {/* Title Bar with accent stripe */}
      <div className="flex items-center gap-2.5 mb-4 pb-3
        border-b border-slate-100 dark:border-slate-700/60">
        <div className="w-1 h-5 rounded-full bg-blue-500 shrink-0" />
        <div>
          <h3 className={`${isExpanded ? 'text-base' : 'text-sm'} font-bold text-slate-800 dark:text-slate-100 leading-tight`}>
            {formSpec.title}
          </h3>
          {formSpec.description && (
            <p className="text-[11px] text-slate-500 dark:text-slate-400 mt-0.5">
              {formSpec.description}
            </p>
          )}
        </div>
        <button
          type="button"
          onClick={() => setIsExpanded(e => !e)}
          className="ml-auto p-1 rounded-md text-slate-400 dark:text-slate-500
            hover:text-slate-600 dark:hover:text-slate-300
            hover:bg-slate-100 dark:hover:bg-slate-700/50
            transition-colors"
          title={isExpanded ? 'Compact view' : 'Expand form'}
        >
          {isExpanded ? <Minimize2 size={13} /> : <Maximize2 size={13} />}
        </button>
      </div>

      {/* Global Error Banner */}
      {formErrors && Object.keys(formErrors).length > 0 && (
        <div className="bg-red-50 dark:bg-red-500/10 text-red-500 dark:text-red-400 border border-red-200 dark:border-red-500/20 px-2.5 py-1.5 rounded-lg flex items-center gap-1.5 text-xs font-medium mb-2.5">
          <AlertCircle size={12} />
          Form validation failed. Please correct the errors above.
        </div>
      )}

      {/* Submitted State */}
      {formSpec.status === 'submitted' && (
        <div className="flex items-center gap-2 px-3 py-2 rounded-lg
          bg-emerald-500/10 dark:bg-emerald-500/10
          border border-emerald-500/20 dark:border-emerald-500/20">
          <div className="w-5 h-5 rounded-full bg-emerald-500/20
            flex items-center justify-center shrink-0">
            <CheckCircle2 size={12} className="text-emerald-400" />
          </div>
          <div>
            <p className="text-[12px] font-semibold text-emerald-400">
              {formSpec.title} submitted
            </p>
            <p className="text-[11px] text-slate-500 dark:text-slate-400">
              Your request has been sent for review.
            </p>
          </div>
        </div>
      )}

      {/* Cancelled State */}
      {formSpec.status === 'cancelled' && (
        <p className="text-[11px] text-slate-400 dark:text-slate-500 italic px-1">
          Request cancelled.
        </p>
      )}

      {/* Form Body */}
      <form onSubmit={handleSubmit} className={`flex flex-col ${isExpanded ? 'gap-4' : 'gap-3'}`}>

        {/* Scalar Fields */}
        {formSpec.fields?.filter(f => f.type !== 'items_table').map((field, fieldIndex, fields) => {
          const error = getError(field.name);
          const hasError = !!error;

          const inputWithError = error
            ? `${inputBase} border-red-400 dark:border-red-500/70 focus:border-red-400 focus:ring-red-400/15`
            : inputBase;

          // Check if this field is part of a date range pair
          const isFromDate = /_from_date$/.test(field.name);
          const isToDate = /_to_date$/.test(field.name);
          const isStartField = /_start$/.test(field.name);
          const isEndField = /_end$/.test(field.name);
          const isInPair = isFromDate || isToDate || isStartField || isEndField;

          // Helper: required indicator (blue dot)
          const requiredDot = field.required ? (
            <span className="inline-block w-1 h-1 rounded-full bg-blue-500 ml-1 mb-0.5 align-middle" />
          ) : null;

          // --- Scalar field renderer inline ---
          const renderScalar = () => {
            // TEXT / NUMBER / DATE
            if (['text', 'number', 'date'].includes(field.type)) {
              // Project autocomplete
              if (field.name === 'project_id' && field.type === 'text') {
                return (
                  <div ref={projectInputRef} className="relative" onKeyDown={(e) => {
                    if (e.key === 'Escape') setIsProjectOpen(false);
                  }}>
                    <div className="relative">
                      <input
                        type="text"
                        value={formData.project_id}
                        onChange={handleProjectInputChange}
                        onFocus={() => setIsProjectOpen(true)}
                        placeholder={field.placeholder}
                        required={field.required}
                        disabled={isSubmitting}
                        autoComplete="off"
                        className={inputWithError}
                        style={{ color: 'inherit', backgroundColor: 'transparent' }}
                      />
                      <div className="absolute right-2 top-1/2 -translate-y-1/2 flex items-center gap-1 pointer-events-none">
                        {projectLoading && <Loader2 size={14} className="animate-spin text-slate-400" />}
                        {!projectLoading && projectSuggestions.length > 0 && <ChevronDown size={12} className="text-slate-400" />}
                      </div>
                    </div>
                    {isProjectOpen && projectSuggestions.length > 0 && (
                      <ul className="absolute z-[200] mt-1 w-full
                        bg-white dark:bg-slate-800
                        border border-slate-200 dark:border-slate-700
                        rounded-xl shadow-xl shadow-black/10 dark:shadow-black/40
                        max-h-60 overflow-auto
                        ring-1 ring-black/5 dark:ring-white/5">
                        {projectSuggestions.map((suggestion, idx) => (
                          <li
                            key={suggestion.value}
                            onMouseDown={(e) => { e.preventDefault(); selectProject(suggestion); }}
                            className="px-3 py-2.5 cursor-pointer transition-colors duration-100
                              text-[13px] font-medium text-slate-700 dark:text-slate-200
                              hover:bg-blue-50 dark:hover:bg-blue-500/10
                              hover:text-blue-700 dark:hover:text-blue-300
                              first:rounded-t-xl last:rounded-b-xl"
                          >
                            <div className="font-semibold text-slate-800 dark:text-slate-100">
                              {suggestion.label || suggestion.project_name}
                            </div>
                            {suggestion.description || suggestion.location ? (
                              <div className="text-[11px] text-slate-500 dark:text-slate-400 mt-0.5">
                                {suggestion.description || suggestion.location}
                              </div>
                            ) : null}
                          </li>
                        ))}
                      </ul>
                    )}
                    {isProjectOpen && !projectLoading && projectSuggestions.length === 0 && debouncedProjectQuery.length >= 2 && (
                      <div className="absolute z-[200] mt-1 w-full px-3 py-2.5
                        bg-white dark:bg-slate-800
                        border border-slate-200 dark:border-slate-700
                        rounded-xl shadow-xl text-[12px]
                        text-slate-500 dark:text-slate-400">
                        No results found
                      </div>
                    )}
                  </div>
                );
              }

              // Regular text/number/date
              return (
                <input
                  type={field.type}
                  value={formData[field.name] || ''}
                  onChange={(e) => handleFieldChange(field.name,
                    field.type === 'number' ? (e.target.value ? Number(e.target.value) : '') : e.target.value)}
                  placeholder={field.placeholder}
                  required={field.required}
                  disabled={isSubmitting}
                  className={inputWithError}
                />
              );
            }

            // TEXTAREA
            if (field.type === 'textarea') {
              return (
                <textarea
                  value={formData[field.name] || ''}
                  onChange={(e) => handleFieldChange(field.name, e.target.value)}
                  placeholder={field.placeholder}
                  required={field.required}
                  rows={3}
                  disabled={isSubmitting}
                  className={inputWithError}
                />
              );
            }

            // SELECT (with chevron)
            if (field.type === 'select') {
              return (
                <div className="relative">
                  <select
                    value={formData[field.name] || ''}
                    onChange={(e) => handleFieldChange(field.name, e.target.value)}
                    required={field.required}
                    disabled={isSubmitting}
                    className={`${inputWithError} appearance-none cursor-pointer`}
                  >
                    <option value="">{field.placeholder || `Select ${field.label}`}</option>
                    {(field.options || []).map(opt => (
                      <option key={opt.value} value={opt.value}>
                        {opt.label}
                      </option>
                    ))}
                  </select>
                  <ChevronDown size={14} className="absolute right-2.5 top-1/2 -translate-y-1/2
                    text-slate-400 pointer-events-none" />
                </div>
              );
            }

            // RADIO — Pill-style segmented control
            if (field.type === 'radio') {
              return (
                <div className="flex flex-wrap gap-2 pt-0.5">
                  {(field.options || []).map(opt => {
                    const isSelected = (formData[field.name] ?? field.default) === opt.value;
                    return (
                      <label
                        key={opt.value}
                        className={`
                          flex items-center gap-2 px-3 py-1.5 rounded-lg border cursor-pointer
                          text-[12px] font-medium transition-all duration-150 select-none
                          ${isSelected
                            ? 'bg-blue-600 border-blue-600 text-white shadow-sm shadow-blue-500/30'
                            : 'bg-slate-50 dark:bg-slate-700/30 border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:border-blue-400 dark:hover:border-blue-500'
                          }
                          ${hasError ? 'border-red-400' : ''}
                        `}
                      >
                        <input
                          type="radio"
                          name={field.name}
                          value={opt.value}
                          checked={isSelected}
                          onChange={() => handleFieldChange(field.name, opt.value)}
                          required={field.required}
                          disabled={isSubmitting}
                          className="sr-only"
                        />
                        {isSelected && (
                          <svg className="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="none">
                            <path d="M2 6l3 3 5-5" stroke="currentColor" strokeWidth="1.8"
                              strokeLinecap="round" strokeLinejoin="round" />
                          </svg>
                        )}
                        {opt.label}
                      </label>
                    );
                  })}
                </div>
              );
            }

            // CHECKBOX
            if (field.type === 'checkbox') {
              return (
                <label className="flex items-center gap-2 cursor-pointer">
                  <input
                    type="checkbox"
                    checked={formData[field.name] || false}
                    onChange={(e) => handleFieldChange(field.name, e.target.checked)}
                    disabled={isSubmitting}
                    className="rounded border-slate-300 dark:border-slate-600 text-blue-600 focus:ring-blue-500/20"
                  />
                  <span className="text-[13px] font-medium text-slate-600 dark:text-slate-300">
                    {field.label}
                  </span>
                </label>
              );
            }

            // Fallback: treat as text
            return (
              <input
                type="text"
                value={formData[field.name] || ''}
                onChange={(e) => handleFieldChange(field.name, e.target.value)}
                placeholder={field.placeholder}
                required={field.required}
                disabled={isSubmitting}
                className={inputWithError}
              />
            );
          };

          return (
            <div key={field.name}>
              {isInPair ? (
                <div className="grid grid-cols-2 gap-2">
                  <>
                    <label className={labelClass}>{field.label}{requiredDot}</label>
                    {renderScalar()}
                  </>
                  {(() => {
                    const pairField = fields[fieldIndex + 1];
                    if (!pairField) return null;
                    const pairError = getError(pairField.name);
                    const pairHasError = !!pairError;
                    const pairInputCls = pairError
                      ? `${inputBase} border-red-400 dark:border-red-500/70 focus:border-red-400 focus:ring-red-400/15`
                      : inputBase;

                    const pairRenderScalar = () => {
                      if (['text', 'number', 'date'].includes(pairField.type)) {
                        return (
                          <input
                            type={pairField.type}
                            value={formData[pairField.name] || ''}
                            onChange={(e) => handleFieldChange(pairField.name,
                              pairField.type === 'number' ? (e.target.value ? Number(e.target.value) : '') : e.target.value)}
                            placeholder={pairField.placeholder}
                            required={pairField.required}
                            disabled={isSubmitting}
                            className={pairInputCls}
                          />
                        );
                      }
                      if (pairField.type === 'textarea') {
                        return (
                          <textarea
                            value={formData[pairField.name] || ''}
                            onChange={(e) => handleFieldChange(pairField.name, e.target.value)}
                            placeholder={pairField.placeholder}
                            required={pairField.required}
                            rows={3}
                            disabled={isSubmitting}
                            className={pairInputCls}
                          />
                        );
                      }
                      if (pairField.type === 'select') {
                        return (
                          <div className="relative">
                            <select
                              value={formData[pairField.name] || ''}
                              onChange={(e) => handleFieldChange(pairField.name, e.target.value)}
                              required={pairField.required}
                              disabled={isSubmitting}
                              className={`${pairInputCls} appearance-none cursor-pointer`}
                            >
                              <option value="">{pairField.placeholder || `Select ${pairField.label}`}</option>
                              {(pairField.options || []).map(opt => (
                                <option key={opt.value} value={opt.value}>{opt.label}</option>
                              ))}
                            </select>
                            <ChevronDown size={14} className="absolute right-2.5 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none" />
                          </div>
                        );
                      }
                      if (pairField.type === 'radio') {
                        return (
                          <div className="flex flex-wrap gap-2 pt-0.5">
                            {(pairField.options || []).map(opt => {
                              const isSelected = (formData[pairField.name] ?? pairField.default) === opt.value;
                              return (
                                <label
                                  key={opt.value}
                                  className={`flex items-center gap-2 px-3 py-1.5 rounded-lg border cursor-pointer text-[12px] font-medium transition-all duration-150 select-none
                                    ${isSelected ? 'bg-blue-600 border-blue-600 text-white shadow-sm shadow-blue-500/30' : 'bg-slate-50 dark:bg-slate-700/30 border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:border-blue-400 dark:hover:border-blue-500'}
                                    ${pairHasError ? 'border-red-400' : ''}`}
                                >
                                  <input type="radio" name={pairField.name} value={opt.value} checked={isSelected}
                                    onChange={() => handleFieldChange(pairField.name, opt.value)}
                                    required={pairField.required} disabled={isSubmitting} className="sr-only" />
                                  {isSelected && (
                                    <svg className="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="none">
                                      <path d="M2 6l3 3 5-5" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round" />
                                    </svg>
                                  )}
                                  {opt.label}
                                </label>
                              );
                            })}
                          </div>
                        );
                      }
                      return (
                        <input
                          type={pairField.type}
                          value={formData[pairField.name] || ''}
                          onChange={(e) => handleFieldChange(pairField.name, e.target.value)}
                          placeholder={pairField.placeholder}
                          required={pairField.required}
                          disabled={isSubmitting}
                          className={pairInputCls}
                        />
                      );
                    };

                    const pairRequiredDot = pairField.required ? (
                      <span className="inline-block w-1 h-1 rounded-full bg-blue-500 ml-1 mb-0.5 align-middle" />
                    ) : null;

                    return (
                      <>
                        <label className={labelClass}>{pairField.label}{pairRequiredDot}</label>
                        {pairRenderScalar()}
                        {pairError && (
                          <p className="mt-1 text-[11px] font-medium text-red-400 flex items-center gap-1.5">
                            <AlertCircle size={11} className="shrink-0" />
                            {pairError}
                          </p>
                        )}
                      </>
                    );
                  })()}
                </div>
              ) : (
                <>
                  <label className={labelClass}>{field.label}{requiredDot}</label>
                  {renderScalar()}
                  {error && (
                    <p className={errorText}>
                      <AlertCircle size={11} className="shrink-0" />
                      {error}
                    </p>
                  )}
                </>
              )}
            </div>
          );
        })}

        {/* Dynamic Items Tables */}
        {formSpec.fields?.filter(f => f.type === 'items_table').map(tableField => (
          <div key={tableField.name} className="mt-1">
            <h4 className="text-[11px] font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-1.5">{tableField.label}</h4>

            <div className="overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-700" style={{ overflow: 'visible' }}>
              <table className="w-full text-xs" style={{ borderCollapse: 'separate', borderSpacing: 0, overflow: 'visible' }}>
                <thead className="bg-slate-50 dark:bg-slate-800/80 text-slate-600 dark:text-slate-300 border-b border-slate-200 dark:border-slate-700">
                  <tr>
                    {tableField.columns.filter(isColVisible).map(col => (
                      <th key={col.name} className="px-2 py-1.5 font-semibold whitespace-nowrap">
                        {col.label} {col.required && <span className="text-red-500">*</span>}
                      </th>
                    ))}
                    <th className="px-2 py-1.5 w-8 text-center"></th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-slate-100 dark:divide-slate-700/60">
                  {formData[tableField.name]?.map((row, rowIndex) => (
                    <tr key={rowIndex} className="bg-slate-50 dark:bg-slate-700/20 rounded-lg">
                      {tableField.columns.filter(isColVisible).map(col => {
                        const cellError = getError(`${tableField.name}.${rowIndex}.${col.name}`);
                        const cellInputBase = "w-full px-2 py-1 text-[13px] rounded border bg-white dark:bg-slate-800/80 border-slate-200 dark:border-slate-700 text-slate-800 dark:text-slate-200 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/20 transition-colors";

                        if (col.name === 'item_name' && col.type === 'text') {
                          const inputRef = useRef(null);
                          return (
                            <td key={col.name} className="px-2 py-1.5 align-top" style={{ overflow: 'visible', position: 'relative' }}>
                              <div ref={inputRef} className="relative" onKeyDown={(e) => {
                                if (e.key === 'Escape') { setIsItemOpen(false); setItemDropdownPos(null); }
                              }}>
                                <div className="relative">
                                  <input
                                    ref={inputRef}
                                    type="text"
                                    value={row.item_name || ''}
                                    onChange={(e) => handleItemInputChange(tableField.name, rowIndex, e)}
                                    onFocus={(e) => {
                                      activeItemRowRef.current = { tableName: tableField.name, rowIndex };
                                      setIsItemOpen(true);
                                      const rect = e.target.getBoundingClientRect();
                                      setItemDropdownPos({
                                        top: rect.bottom + window.scrollY,
                                        left: rect.left + window.scrollX,
                                        width: rect.width,
                                      });
                                    }}
                                    onBlur={() => {
                                      // Small delay to allow click on dropdown items
                                      setTimeout(() => setIsItemOpen(false), 200);
                                    }}
                                    placeholder={col.placeholder || ''}
                                    required={col.required}
                                    disabled={isSubmitting}
                                    autoComplete="off"
                                    className={`${cellInputBase} ${cellError ? 'border-red-500 ring-1 ring-red-500/20' : ''}`}
                                  />
                                  <div className="absolute right-1.5 top-1/2 -translate-y-1/2 flex items-center gap-1 pointer-events-none">
                                    {itemLoading && <Loader2 size={12} className="animate-spin text-slate-400" />}
                                    {!itemLoading && itemSuggestions.length > 0 && <ChevronDown size={10} className="text-slate-400" />}
                                  </div>
                                </div>
                                {isItemOpen && itemSuggestions.length > 0 && itemDropdownPos && (
                                  <ul
                                    className="z-[300] min-w-full rounded-xl shadow-xl shadow-black/10 dark:shadow-black/40
                                      bg-white dark:bg-slate-800
                                      border border-slate-200 dark:border-slate-700
                                      max-h-48 overflow-auto
                                      ring-1 ring-black/5 dark:ring-white/5"
                                    style={{ position: 'fixed', top: itemDropdownPos.top + 4, left: itemDropdownPos.left, width: Math.max(itemDropdownPos.width, 256) }}
                                  >
                                    {itemSuggestions.map((suggestion) => (
                                      <li
                                        key={suggestion.value}
                                        onMouseDown={(e) => { e.preventDefault(); selectItem(suggestion); setItemDropdownPos(null); }}
                                        className="px-3 py-2 cursor-pointer transition-colors duration-100
                                          text-[13px] text-slate-700 dark:text-slate-200
                                          hover:bg-blue-50 dark:hover:bg-blue-500/10
                                          hover:text-blue-700 dark:hover:text-blue-300
                                          first:rounded-t-xl last:rounded-b-xl"
                                      >
                                        <div className="font-semibold">{suggestion.label || suggestion.display_label}</div>
                                        {suggestion.description || (suggestion.item_name && suggestion.item_name !== suggestion.display_label) ? (
                                          <div className="text-[11px] text-slate-500 dark:text-slate-400 truncate">
                                            {suggestion.description || suggestion.item_name}
                                          </div>
                                        ) : null}
                                      </li>
                                    ))}
                                  </ul>
                                )}
                                {isItemOpen && !itemLoading && itemSuggestions.length === 0 && debouncedItemQuery.length >= 2 && (
                                  <div className="z-[300] px-3 py-2.5
                                    bg-white dark:bg-slate-800
                                    border border-slate-200 dark:border-slate-700
                                    rounded-xl shadow-xl text-[12px]
                                    text-slate-500 dark:text-slate-400"
                                    style={{ position: 'fixed', top: itemDropdownPos?.top + 4, left: itemDropdownPos?.left, width: Math.max(itemDropdownPos?.width, 256) }}
                                  >
                                    No results found
                                  </div>
                                )}
                              </div>
                              {cellError && (
                                <p className="mt-0.5 text-[11px] text-red-400 flex items-center gap-1 truncate" title={cellError}>
                                  <span>⚠</span>
                                  <span>{cellError}</span>
                                </p>
                              )}
                            </td>
                          );
                        }

                        return (
                          <td key={col.name} className="px-2 py-1.5 align-top">
                            <input
                              type={col.type}
                              value={row[col.name] || ''}
                              onChange={(e) => handleItemChange(tableField.name, rowIndex, col.name, e.target.value)}
                              required={col.required}
                              min={col.min}
                              disabled={isSubmitting}
                              className={`${cellInputBase} ${cellError ? 'border-red-500 ring-1 ring-red-500/20' : ''}`}
                            />
                            {cellError && (
                              <p className="mt-0.5 text-[11px] text-red-400 flex items-center gap-1 truncate" title={cellError}>
                                <span>⚠</span>
                                <span>{cellError}</span>
                              </p>
                            )}
                          </td>
                        );
                      })}

                      <td className="px-2 py-1.5 text-center align-top">
                        <button
                          type="button"
                          onClick={() => removeRow(tableField.name, rowIndex)}
                          disabled={isSubmitting || formData[tableField.name].length <= (tableField.min_rows || 1)}
                          className="p-1 text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 rounded transition-colors disabled:opacity-30 disabled:cursor-not-allowed mt-0.5"
                        >
                          <Trash2 size={14} />
                        </button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <button
              type="button"
              onClick={() => addRow(tableField.name, tableField.columns)}
              disabled={isSubmitting}
              className="w-full mt-2 py-1.5 rounded-lg border border-dashed
                border-slate-300 dark:border-slate-600 text-[11px] font-medium
                text-slate-500 hover:border-blue-400 hover:text-blue-400
                hover:bg-blue-500/5 transition-all duration-150
                flex items-center justify-center gap-1.5"
            >
              <Plus size={12} /> Add Row
            </button>
          </div>
        ))}

        {/* Footer Actions */}
        <div className="flex items-center justify-between mt-4 pt-3
          border-t border-slate-100 dark:border-slate-700/60">
          <button
            type="button"
            onClick={onCancel}
            disabled={isSubmitting}
            className="px-3 py-1.5 text-[12px] font-medium rounded-lg
              text-slate-500 dark:text-slate-400
              hover:bg-slate-100 dark:hover:bg-slate-700/40
              hover:text-slate-700 dark:hover:text-slate-200
              transition-all duration-150"
          >
            {formSpec.cancel_label || 'Cancel'}
          </button>

          <button
            type="submit"
            disabled={isSubmitting}
            className="px-5 py-1.5 text-[12px] font-semibold rounded-lg
              bg-blue-600 hover:bg-blue-500 active:bg-blue-700
              text-white shadow-sm shadow-blue-500/20
              disabled:opacity-40 disabled:cursor-not-allowed
              transition-all duration-150"
          >
            {isSubmitting ? (
              <span className="flex items-center gap-1.5">
                <Loader2 size={11} className="animate-spin" />
                Submitting...
              </span>
            ) : (
              formSpec.submit_label || 'Submit'
            )}
          </button>
        </div>

      </form>
    </div>
  );
}
