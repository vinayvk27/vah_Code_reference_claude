async def approver_agent_node(state: RMSState) -> dict:
    """
    Node 3c: Approver Agent — fully procedural (no LLM).
    Lists pending worklogs, or approves/rejects a worklog by id.
    """
    print(
        f"[DIAG-RMS] approver_agent_node entered. emp_no={state.get('emp_no')}, "
        f"collection={state.get('selected_collection')!r}, "
        f"last_msg={_last_user_msg_short(state)}",
        flush=True
    )

    messages = state.get("messages", [])
    last_user_message = ""
    for msg in reversed(messages):
        if isinstance(msg, HumanMessage):
            last_user_message = str(getattr(msg, "content", "") or "")
            break

    current_emp_no = state.get("emp_no", state.get("user_id", ""))
    execution_log = state.get("execution_log", [])

    cmd = _parse_worklog_approval_command(last_user_message)

    # Detect "approve/reject" verb with no id -> ask for id
    import re
    has_verb = bool(re.search(r'\b(approve|reject)\b', last_user_message, re.IGNORECASE))
    if cmd["action"] == "list" and has_verb:
        return {
            "messages": [AIMessage(content=(
                "Which worklog would you like to approve or reject? "
                "Please specify the worklog id, e.g. 'approve worklog 5'."
            ))],
            "execution_log": execution_log + ["Approver: verb without id."]
        }

    # -------- APPROVE / REJECT PATH --------
    if cmd["action"] in ("approve", "reject"):
        wl_id = cmd["worklog_id"]
        decision = "APPROVED" if cmd["action"] == "approve" else "REJECTED"
        try:
            db = SessionLocal()
            try:
                # Use the existing store function.
                result = timesheet_store.approve_worklog(
                    db=db,
                    worklog_log_idx=wl_id,
                    approver_id=int(current_emp_no),
                    decision=decision,
                    remarks="",  # approver remark optional for now
                )
                if isinstance(result, dict) and result.get("error"):
                    full_text = f"Could not {cmd['action']} worklog {wl_id}: {result['error']}"
                    execution_log.append(f"Approver: {result['error']}")
                else:
                    full_text = (
                        f"Worklog {wl_id} has been {decision.lower()}."
                    )
                    execution_log.append(f"Approver: worklog {wl_id} {decision}.")
            except Exception as e:
                db.rollback()
                full_text = f"Could not {cmd['action']} worklog {wl_id} due to a database error: {e}"
                execution_log.append(f"Approver: exception {e}")
            finally:
                db.close()
        except Exception as e:
            full_text = f"Database error: {e}"
            execution_log.append(f"Approver: session error {e}")

        print(f"[DIAG-RMS] approver_agent_node returning (decision).", flush=True)
        return {"messages": [AIMessage(content=full_text)], "execution_log": execution_log}

    # -------- LIST PENDING PATH --------
    try:
        db = SessionLocal()
        try:
            # is_approved=None means PENDING (IsApproved IS NULL)
            pending = timesheet_store.list_worklogs(db, resource_id=None, is_approved="PENDING")
        finally:
            db.close()
    except Exception as e:
        return {
            "messages": [AIMessage(content=f"Could not fetch pending worklogs due to a database error: {e}")],
            "execution_log": execution_log + [f"Approver: list error {e}"]
        }

    if not pending:
        full_text = "There are no worklogs pending your approval at this time."
    else:
        lines = ["### Worklogs Pending Approval", ""]
        lines.append("| Worklog ID | Task ID | Employee | Date | Hours | Remark |")
        lines.append("|---|---|---|---|---|---|")
        for w in pending:
            lines.append(
                f"| {w.get('worklog_id')} | {w.get('task_id')} | {w.get('resource_id')} "
                f"| {w.get('task_date')} | {w.get('hours')} | {w.get('remarks')} |"
            )
        lines.append("")
        lines.append("To approve: approve worklog <Worklog ID>    |    To reject: reject worklog <Worklog ID>")
        full_text = "\n".join(lines)

    execution_log.append(f"Approver: listed {len(pending)} pending worklogs.")
    print(f"[DIAG-RMS] approver_agent_node returning (list).", flush=True)
    return {"messages": [AIMessage(content=full_text)], "execution_log": execution_log}

