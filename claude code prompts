"""
Timesheet Store - DB-backed service for RMS timesheet workflow.
Replaces the in-memory DataFrame with MariaDB queries.
"""

from datetime import date
from typing import Optional, List, Any, Dict
from sqlalchemy.orm import Session
from sqlalchemy import text

from app.models.db_schema import PpTaskAssignment, PpWorklog


def _format_date(d: Any) -> Optional[str]:
    """Convert date object to YYYY-MM-DD string."""
    if d is None:
        return None
    if isinstance(d, date):
        return d.strftime('%Y-%m-%d')
    return str(d)


def list_tasks_for_resource(db: Session, resource_id: int) -> List[Dict[str, Any]]:
    """
    List all tasks assigned to a specific resource.

    Args:
        db: Database session
        resource_id: The resource (employee) ID

    Returns:
        List of task dicts
    """
    results = db.query(PpTaskAssignment).filter(
        PpTaskAssignment.Resource == resource_id
    ).all()

    tasks = []
    for row in results:
        task = {
            "task_id": row.WorkLogIdx,
            "resource_id": row.Resource,
            "project_id": row.ProjectIdx,
            "product_id": row.ProductIdx,
            "task_idx": row.TaskIdx,
            "activity_idx": row.ActivityIdx,
            "start_date": _format_date(row.StartDate),
            "end_date": _format_date(row.EndDate),
            "plan_hours": row.PlanHrs,
            "is_completed": row.IsCompleted,
            "created_by": row.created_by,
            "created_date": _format_date(row.created_date),
            "task_name": f"Task #{row.TaskIdx}"  # Placeholder name
        }
        tasks.append(task)

    return tasks


