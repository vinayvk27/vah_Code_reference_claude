from typing import TypedDict, Optional, List, Dict, Any
from langchain_core.messages import BaseMessage

class AnalyticsState(TypedDict):
    # User identity (from JWT, injected by controller)
    user_id: str          # emp_id as string e.g. "3428"
    user_name: str
    user_dept: str

    # RBAC (from JWT)
    collection_agents: dict   # e.g. {"RMS_ANALYTICS": ["reviewer"]}
    selected_collection: str  # e.g. "RMS_ANALYTICS"
    selected_agent_role: str  # "reviewer" / "creator" / "approver"

    # Permission result
    has_permission: bool
    denial_message: Optional[str]

    # Conversation history
    messages: List[BaseMessage]

    # Intent classification result
    intent_type: Optional[str]  # "SQL_DATA" / "SQL_INSIGHT" / "RAG" / "DENY"

    # SQL execution
    generated_sql: Optional[str]
    sql_result: Optional[List[Dict]]
    sql_error: Optional[str]

    # Output
    output_type: Optional[str]    # "chart" / "table" / "text"
    chart_spec: Optional[Dict]    # ECharts option object
    table_data: Optional[Dict]    # {columns: [...], rows: [...]}
    text_response: Optional[str]
