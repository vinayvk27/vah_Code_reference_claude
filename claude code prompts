  """
  HRMS Workflow Tools
  ===================
  DB-backed tools for HRMS personas.
  This file currently has FILLER (reviewer) persona tools only.
  CREATOR and APPROVER tools will be added in subsequent tasks.
  """
  
  from typing import Optional
  from app.dao.database import SessionLocal
  from app.services import hrms_store
  
  
  def tool_list_my_leave_balance(user_context: dict) -> str:
      """
      List the user's leave balance per leave type.
      Filler persona only.
      """
      persona = (user_context or {}).get("persona")
      if persona != "reviewer":
          raise PermissionError("tool_list_my_leave_balance requires reviewer persona")
      
      resource_id = int(user_context["user_id"])
      db = SessionLocal()
      try:
          balances = hrms_store.compute_leave_balance(db, resource_id)
          if not balances:
              return "No leave types are defined yet."
          
          lines = ["Your leave balance:"]
          for b in balances:
              lines.append(f"  - {b['leave_type_name']}: {b['max_days']} max, {b['used_days']} used, {b['remaining_days']} remaining")
          return "\n".join(lines)
      except Exception as e:
          return f"Error fetching leave balance: {e}"
      finally:
          db.close()
  
  
  def tool_request_leave(leave_type_id: int, from_date: str, to_date: str, reason: str, user_context: dict) -> str:
      """
      Submit a leave request for the current user.
      Filler persona only.
      """
      persona = (user_context or {}).get("persona")
      if persona != "reviewer":
          raise PermissionError("tool_request_leave requires reviewer persona")
      
      resource_id = int(user_context["user_id"])
      
      # Validate dates
      from datetime import datetime
      try:
          from_dt = datetime.strptime(from_date, "%Y-%m-%d").date()
          to_dt = datetime.strptime(to_date, "%Y-%m-%d").date()
      except ValueError:
          return f"Invalid date format. Use YYYY-MM-DD. Got from_date={from_date}, to_date={to_date}"
      
      if from_dt > to_dt:
          return f"from_date ({from_date}) must be on or before to_date ({to_date})"
      
      if not reason or not reason.strip():
          return "Reason is required and cannot be empty."
      
      db = SessionLocal()
      try:
          result = hrms_store.create_leave_request(db, resource_id, leave_type_id, from_date, to_date, reason.strip())
          return (
              f"Leave request submitted: {result['num_days']} day(s) from {result['from_date']} to {result['to_date']}. "
              f"Status: PENDING. (Request ID: {result['request_id']})"
          )
      except Exception as e:
          return f"Error submitting leave request: {e}"
      finally:
          db.close()
  
  
  def tool_my_payslip(pay_month: str, user_context: dict) -> str:
      """
      View the user's payslip for a specific month.
      Filler persona only.
      """
      import re
      persona = (user_context or {}).get("persona")
      if persona != "reviewer":
          raise PermissionError("tool_my_payslip requires reviewer persona")
      
      if not re.match(r'^\d{4}-\d{2}$', pay_month):
          return f"Invalid pay_month format. Use YYYY-MM. Got: {pay_month}"
      
      resource_id = int(user_context["user_id"])
      db = SessionLocal()
      try:
          payslips = hrms_store.list_payslips(db, resource_id=resource_id, pay_month=pay_month)
          if not payslips:
              return f"No payslip found for {pay_month}."
          p = payslips[0]
          return (
              f"Payslip for {p['pay_month']}: "
              f"Basic = {p['basic']}, Allowances = {p['allowances']}, "
              f"Deductions = {p['deductions']}, Net Pay = {p['net_pay']}"
          )
      except Exception as e:
          return f"Error fetching payslip: {e}"
      finally:
          db.close()
  
  
  def tool_list_my_leave_requests(user_context: dict) -> str:
      """
      List all leave requests for the current user (any status).
      Filler persona only.
      """
      persona = (user_context or {}).get("persona")
      if persona != "reviewer":
          raise PermissionError("tool_list_my_leave_requests requires reviewer persona")
      
      resource_id = int(user_context["user_id"])
      db = SessionLocal()
      try:
          requests = hrms_store.list_leave_requests(db, resource_id=resource_id)
          if not requests:
              return "You have no leave requests yet."
          
          # Sort by created_date desc
          requests_sorted = sorted(requests, key=lambda r: r.get('created_date') or '', reverse=True)
          lines = [f"Your leave requests ({len(requests_sorted)} total):"]
          for r in requests_sorted:
              lines.append(
                  f"  - #{r['request_id']}: {r['leave_type_name']} | "
                  f"{r['from_date']} to {r['to_date']} ({r['num_days']}d) | "
                  f"Status: {r['status']} | Reason: {r['reason']}"
              )
          return "\n".join(lines)
      except Exception as e:
          return f"Error fetching your leave requests: {e}"
      finally:
          db.close()

