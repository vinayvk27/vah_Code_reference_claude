@router.get(
    "/tools/{tool_name}",
    summary="Execute UI tools for Generative UI widgets",
    description="Lightweight endpoint to fetch typeahead search results and dependent dropdown options without triggering a full LangGraph cycle."
)
async def execute_ui_tool(
    tool_name: str,
    q: Optional[str] = Query(None, description="Search keyword for autocomplete"),
    parent_id: Optional[int] = Query(None, description="Parent ID for dependent dropdowns"),
    db: Session = Depends(get_db),
    current_user: CurrentUser = Depends(get_current_user)
):
    try:
        if tool_name == "search_projects":
            if not q:
                return []
            result = search_projects.invoke({"keyword": q})
            return result

        elif tool_name == "get_project_phases":
            if not parent_id:
                return []
            result = get_project_phases.invoke({"project_id": parent_id})
            return result

        else:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail=f"Tool '{tool_name}' not found or not permitted for UI execution."
            )

    except Exception as e:
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Error executing UI tool '{tool_name}': {str(e)}"
        )


"""
Process-local permission cache. 5-minute TTL. Cache entries
expire naturally; there is no manual invalidation endpoint
in this task. Admin workstream (post Task 4) will add a
proper invalidation API.

Uses a plain Python dict + threading.Lock. If the app runs multiple
worker processes, each has its own cache — acceptable for current
scale (single-worker via uvicorn).
"""
import time
import threading
from typing import Any, Optional, Tuple

_cache: dict[str, Tuple[Any, float]] = {}
_lock = threading.Lock()


def cache_get(key: str) -> Optional[Any]:
    """Return cached value if present and not expired, else None."""
    with _lock:
        entry = _cache.get(key)
        if entry is None:
            return None
        value, expiry = entry
        if time.time() > expiry:
            del _cache[key]
            return None
        return value


def cache_set(key: str, value: Any, ttl_seconds: int = 300) -> None:
    """Store value with expiry timestamp."""
    expiry = time.time() + ttl_seconds
    with _lock:
        _cache[key] = (value, expiry)


def cache_clear() -> None:
    """Empties the cache."""
    with _lock:
        _cache.clear()
