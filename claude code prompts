def classify_rms_intent(user_message: str) -> RMSIntentClassification:
    llm = get_llm_non_streaming()
    try:
        prompt_value = _prompt_template.invoke({"user_message": user_message})
        llm_response = llm.invoke(prompt_value)
        raw_text = getattr(llm_response, "content", "") or ""

        # First attempt: standard parsing.
        try:
            return _parser.parse(raw_text)
        except Exception as first_error:
            # Second attempt: try to repair the JSON.
            print(f"[RMS-CLASSIFIER] First parse failed, attempting repair...", flush=True)
            repaired_dict = _repair_classifier_json(raw_text)
            if repaired_dict is not None:
                try:
                    parsed = RMSIntentClassification(**repaired_dict)
                    print(f"[RMS-CLASSIFIER] Repair succeeded. Classification: {parsed.persona} / {parsed.collection}", flush=True)
                    return parsed
                except Exception as second_error:
                    print(f"[RMS-CLASSIFIER] Repair attempt failed Pydantic validation: {second_error}", flush=True)

            # Both attempts failed; raise to trigger keyword fallback.
            raise first_error
    except Exception as e:
        print(f"[RMS-CLASSIFIER] Falling back to keyword matching: {e}", flush=True)
        import traceback
        traceback.print_exc()
        return keyword_fallback(user_message)

The _repair_classifier_json function:

def _repair_classifier_json(raw_text: str):
    """
    Attempt to repair common LLM JSON malformations.
    Returns dict if successful, None otherwise.
    """
    import json
    import re

    if not raw_text:
        return None

    # Strip markdown fences
    text = raw_text.strip()
    if text.startswith("```"):
        # Remove leading fence
        text = re.sub(r'^```(?:json)?\s*', '', text)
        # Remove trailing fence
        text = re.sub(r'\s*```\s*$', '', text)

    # Extract just the JSON object
    first_brace = text.find('{')
    last_brace = text.rfind('}')
    if first_brace == -1 or last_brace == -1 or last_brace < first_brace:
        return None
    text = text[first_brace:last_brace + 1]

    # Fix duplicate keys: "X": "X": "value"  ->  "X": "value"
    text = re.sub(r'"(\w+)":\s*"\1"\s*:', r'"\1":', text)

    # Fix double-value-for-one-key: "X": "A", "B" (where "B" should be dropped or merged)
    # Match a key:value followed by another quoted string that's not a key (i.e., not followed by colon).
    # Pattern: "key": "val1", "val2"(?= [,}])
    text = re.sub(
        r'"(\w+)":\s*"([^"]+)",\s*"([^"]+)"(\s*[,}])',
        r'"\1": "\2"\4',
        text
    )

    try:
        return json.loads(text)
    except json.JSONDecodeError:
        return None

