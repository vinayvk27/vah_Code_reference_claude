@router.get(
    "/tools/{tool_name}",
    summary="Execute UI tools for Generative UI widgets",
    description="Lightweight endpoint to fetch typeahead search results and dependent dropdown options without triggering a full LangGraph cycle."
)
async def execute_ui_tool(
    tool_name: str,
    q: Optional[str] = Query(None, description="Search keyword for autocomplete"),
    parent_id: Optional[int] = Query(None, description="Parent ID for dependent dropdowns"),
    db: Session = Depends(get_db),
    current_user: dict = Depends(get_current_user)
):
    try:
        if tool_name == "search_projects":
            if not q:
                return []
            result = search_projects.invoke({"keyword": q})
            return result

        elif tool_name == "get_project_phases":
            if not parent_id:
                return []
            result = get_project_phases.invoke({"project_id": parent_id})
            return result

        else:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail=f"Tool '{tool_name}' not found or not permitted for UI execution."
            )

    except Exception as e:
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Error executing UI tool '{tool_name}': {str(e)}"
        )
