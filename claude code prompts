  def _handle_apply_leave_form(form_data: dict, user_context: dict) -> str:
      """
      Submission handler for hrms_apply_leave form.
      Called by chat_controller when user submits the form.
      Returns a confirmation string to show in chat.
      """
      from app.forms.spec import validate_form_data
      
      # Re-validate (defense in depth)
      form_spec_for_validation = {
          "fields": [
              {"name": "leave_type_id", "type": "number", "required": True},
              {"name": "from_date", "type": "date", "required": True},
              {"name": "to_date", "type": "date", "required": True},
              {"name": "reason", "type": "text", "required": True, "max_length": 500},
          ]
      }
      err = validate_form_data(form_spec_for_validation, form_data)
      if err:
          return f"Form validation failed: {err}"
      
      try:
          leave_type_id = int(form_data["leave_type_id"])
          from_date = form_data["from_date"]
          to_date = form_data["to_date"]
          reason = form_data["reason"]
      except (KeyError, ValueError, TypeError) as e:
          return f"Invalid form data: {e}"
      
      # Override persona for the underlying tool call
      reviewer_context = dict(user_context)
      reviewer_context["persona"] = "reviewer"
      
      return tool_request_leave(leave_type_id, from_date, to_date, reason, reviewer_context)

