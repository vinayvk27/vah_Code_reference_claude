"""
MRR Welcome Endpoint Controller
================================
Returns pending requisitions, approvals, and ERP approvals for the authenticated user.
"""

from fastapi import Depends
from sqlalchemy import text

from app.dao.database import SessionLocal
from app.models.dto_schemas import CurrentUser
from app.workflows.material_workflow.approvers import is_manager_approver, is_erp_approver


async def get_mrr_welcome_payload(user: CurrentUser) -> dict:
    db = SessionLocal()
    try:
        payload = {
            "module": "MRR",
            "greeting": "Welcome to MRR!",
            "pending_for_user": [],
            "pending_approvals": [],
            "pending_erp_approvals": []
        }

        # User's own in-flight requisitions
        own = db.execute(text("""
            SELECT MATREQUISITIONNO, STATUS, APPROVAL_STATUS, ERP_APPROVAL_STATUS, REQUISITIONDATE
            FROM mrr_matrequisitionheader
            WHERE REQUESTORID = :emp AND (STATUS != 'RELEASED' AND STATUS != 'REJECTED')
            ORDER BY REQUISITIONDATE DESC LIMIT 5
        """), {"emp": user.emp_no}).fetchall()
        payload["pending_for_user"] = [
            {"no": r.MATREQUISITIONNO, "status": r.STATUS, "approval": r.APPROVAL_STATUS,
             "erp_approval": r.ERP_APPROVAL_STATUS, "date": str(r.REQUISITIONDATE)}
            for r in own
        ]

        # Manager queue
        if is_manager_approver(user.emp_no):
            mgr_pending = db.execute(text("""
                SELECT MATREQUISITIONNO, REQUESTORID, REQUISITIONDATE
                FROM mrr_matrequisitionheader WHERE APPROVAL_STATUS = 'PENDING'
                ORDER BY REQUISITIONDATE ASC LIMIT 20
            """)).fetchall()
            payload["pending_approvals"] = [
                {"no": r.MATREQUISITIONNO, "requestor": r.REQUESTORID, "date": str(r.REQUISITIONDATE)}
                for r in mgr_pending
            ]

        # ERP queue
        if is_erp_approver(user.emp_no):
            erp_pending = db.execute(text("""
                SELECT MATREQUISITIONNO, REQUESTORID, REQUISITIONDATE
                FROM mrr_matrequisitionheader
                WHERE APPROVAL_STATUS = 'APPROVED'
                  AND (ERP_APPROVAL_STATUS IS NULL OR ERP_APPROVAL_STATUS = 'PENDING')
                ORDER BY REQUISITIONDATE ASC LIMIT 20
            """)).fetchall()
            payload["pending_erp_approvals"] = [
                {"no": r.MATREQUISITIONNO, "requestor": r.REQUESTORID, "date": str(r.REQUISITIONDATE)}
                for r in erp_pending
            ]

        return payload
    finally:
        db.close()
