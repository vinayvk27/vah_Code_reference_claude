def _parse_rms_form_submit(message: str) -> Optional[dict]:
    """
    If the message is a JSON form_submit for rms_create_task_form,
    return the parsed dict. Otherwise return None.
    Mirrors MRR's _parse_form_submit_message but for RMS form_id.
    """
    import json as _json
    s = (message or "").strip()
    if not s.startswith("{"):
        return None
    try:
        obj = _json.loads(s)
    except Exception:
        return None
    if not isinstance(obj, dict):
        return None
    if obj.get("action") != "form_submit":
        return None
    if obj.get("form_id") != "rms_create_task_form":
        return None
    return obj

