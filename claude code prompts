def form_submit_handler_node(state: MaterialRequisitionState) -> dict:
    """
    Procedural handler for MRR form_submit. Validates fields, looks
    up items, inserts via the existing DB path used by Excel.
    Pure Python validation — no LLM involved in any structural decision.
    """
    print(f"[DIAG-MRR] form_submit_handler_node entered.", flush=True)

    last_msg = _get_last_user_message(state.get("messages", []))
    payload = _parse_form_submit_message(last_msg)
    if payload is None:
        return {
            "messages": [AIMessage(content="Form submission could not be processed.")],
            "execution_log": state.get("execution_log", []) + ["form_submit: payload missing"],
        }

    form_id = payload.get("form_id", "")
    data = payload.get("data") or {}
    user_id = state.get("emp_no") or state.get("user_id") or "system"
    user_dept = (state.get("user_info") or {}).get("dept", "EAG")
    execution_log = state.get("execution_log", [])

    # Inline item lookup — avoids the fragile get_item_details_from_db
    # chain (get_effective_item_availability -> legacy pending-qty SQL).
    # com_search has: DP_PART_NO, DESCRIPTION, PRICE, QOH, UOM, ITEMID,
    # ITEMREVISIONID. LPP_VALUE_UNITPRICE_INR lives in SCMITEMS, not here.
    def _lookup_item(db_session, keyword: str) -> Optional[dict]:
        row = db_session.execute(text("""
            SELECT DP_PART_NO              AS item_id,
                   DESCRIPTION              AS item_name,
                   PRICE                    AS unit_price_rs
            FROM com_search
            WHERE DP_PART_NO = :kw
              AND WAREHOUSE = '1'
            LIMIT 1
        """), {"kw": keyword}).mappings().first()
        return dict(row) if row else None

    if form_id != "mrr_create_form":
        return {
            "messages": [AIMessage(content=f"Unknown form_id: {form_id}.")],
            "execution_log": execution_log + [f"form_submit: unknown form_id {form_id}"],
        }

    # ---- VALIDATION (item/project lookups use a shared session) ----
    errors: Dict[str, str] = {}
    validated_items = []

    db = SessionLocal()
    try:
        project_id_raw = (data.get("project_id") or "").strip() if isinstance(data.get("project_id"), str) else data.get("project_id")
        if not project_id_raw:
            errors["project_id"] = "Project ID is required"
        else:
            # Resolve project code -> (project_id, description)
            resolved_proj = _lookup_project(db, project_id_raw)
            if resolved_proj is None:
                errors["project_id"] = (
                    f"Project '{project_id_raw}' not found. "
                    f"Please enter a valid project code."
                )
                resolved_proj = {}

        requisition_type = (data.get("requisition_type") or "").strip().upper() if isinstance(data.get("requisition_type"), str) else None
        if requisition_type not in ("RETURNABLE", "NON_RETURNABLE"):
            errors["requisition_type"] = "Requisition Type is required (Returnable or Non-Returnable)"

        need_by_date = (data.get("need_by_date") or "").strip() if isinstance(data.get("need_by_date"), str) else None
        if not need_by_date:
            errors["need_by_date"] = "Need By Date is required"
        else:
            try:
                datetime.strptime(need_by_date, "%Y-%m-%d")
            except Exception:
                errors["need_by_date"] = "Invalid date (use YYYY-MM-DD)"

        comments = data.get("comments") or ""
        if not isinstance(comments, str):
            comments = str(comments)

        # Items validation
        items_in = data.get("items")
        if not isinstance(items_in, list) or len(items_in) == 0:
            errors["items"] = "At least one item is required"
            items_in = []

        for idx, row in enumerate(items_in):
            if not isinstance(row, dict):
                errors[f"items.{idx}"] = "Invalid item row"
                continue

            item_name = (row.get("item_name") or "").strip() if isinstance(row.get("item_name"), str) else None
            qty_raw = row.get("qty")
            return_date = (row.get("return_date") or "").strip() if isinstance(row.get("return_date"), str) else None

            if not item_name:
                errors[f"items.{idx}.item_name"] = "Item name/code is required"
                continue

            try:
                qty = float(qty_raw)
                if qty <= 0:
                    errors[f"items.{idx}.qty"] = "Quantity must be > 0"
                    continue
            except Exception:
                errors[f"items.{idx}.qty"] = f"Invalid quantity ({qty_raw!r})"
                continue

            # Inline item lookup (avoids the legacy availability chain).
            item_data = _lookup_item(db, item_name)
            if not item_data:
                errors[f"items.{idx}.item_name"] = f"Item code '{item_name}' not found in catalog"
                continue

            if requisition_type == "RETURNABLE":
                if not return_date:
                    errors[f"items.{idx}.return_date"] = "Return Date is required for returnable items"
                    continue
                try:
                    datetime.strptime(return_date, "%Y-%m-%d")
                except Exception:
                    errors[f"items.{idx}.return_date"] = "Invalid return date (use YYYY-MM-DD)"
                    continue
            else:
                return_date = None

            validated_items.append({
                "item_id": item_data["item_id"],
                "item_name": item_data["item_name"],
                "unit_price_rs": float(item_data["unit_price_rs"] or 0),
                "qty": qty,
                "total": qty * float(item_data["unit_price_rs"] or 0),
                "return_date": return_date,
            })

        # Resolve project/phase for INSERT (not needed for error return)
        resolved_project_id = (resolved_proj or {}).get("project_id")
        resolved_description = (resolved_proj or {}).get("description", "")
        resolved_phase_id = None
        if resolved_project_id is not None:
            resolved_phase_id = _lookup_latest_phase(db, resolved_project_id)

        if errors:
            marker_payload = json.dumps({"form_id": form_id, "errors": errors})
            text_msg = (
                "I couldn't submit the form. Please fix the highlighted "
                "fields and try again."
            )
            full = text_msg + "\n\n[[FORM_ERRORS:" + marker_payload + "]]"
            execution_log.append(f"form_submit validation: {len(errors)} errors")
            return {
                "messages": [AIMessage(content=full)],
                "execution_log": execution_log,
            }

        # ---- DB INSERT ----
        # mrr_matrequisitionheader has no AUTO_INCREMENT, so we compute PK.
        total_cost = sum(it["total"] for it in validated_items)

        seq_row = db.execute(text(
            "SELECT IFNULL(MAX(MATREQUISITIONID), 0) + 1 AS next_id "
            "FROM mrr_matrequisitionheader"
        )).first()
        header_id = int(seq_row.next_id) if seq_row else 1
        mrr_no = f"MRR/{header_id}/25-26"

        # REQUESTORID is bigint; cast user_id to int.
        requestor_id = int(user_id) if str(user_id).isdigit() else 0

        db.execute(text("""
            INSERT INTO mrr_matrequisitionheader (
                MATREQUISITIONID, MATREQUISITIONNO, STATUS,
                VERIFICATION_STATUS, VERIFICATION_DATE,
                APPROVAL_STATUS, APPROVAL_DATE,
                ERP_APPROVAL_STATUS, ERP_APPROVAL_DATE,
                SUPPLIERID, SUPPLIERSITEID, REQTRANSACTIONTYPE, COMMENTS,
                DEPARTMENT, REQUESTORID, REQUISITIONDATE, TOTAL_COST,
                PROJECTID, PROJECTPHASEID, DESCRIPTION
            ) VALUES (
                :id, :mrrno, 'ENTERED', NULL, NULL,
                NULL, NULL,
                NULL, NULL,
                0, 0, :reqtype, :comments,
                :dept, :requestor, NOW(), :total,
                :proj, :phase, :desc
            )
        """), {
            "id": header_id,
            "mrrno": mrr_no,
            "reqtype": "RETURNABLE" if requisition_type == "RETURNABLE" else "NON-RETURNABLE",
            "comments": comments,
            "total": float(total_cost),
            "proj": resolved_project_id,
            "phase": resolved_phase_id,
            "desc": resolved_description,
            "user": user_id,
            "dept": user_dept,
            "requestor": requestor_id,
        })

        line_query = text("""
            INSERT INTO mrr_matrequisitionlines (
                MATREQUISITIONID, ITEMID, ITEMREVISIONID, UOMID,
                REQUISITIONQTY, ISSUEQTY, WHOCOLUMN, RETURNQUANTITY,
                STATUS, CLOSEREASON, ITEMCOST
            ) VALUES (
                :hid, :iid, 0, 0,
                :qty, 0, '', 0,
                'ENTERED', '', :itemcost
            )
        """)
        for it in validated_items:
            db.execute(line_query, {
                "hid": header_id,
                "iid": it["item_id"],
                "qty": it["qty"],
                "itemcost": it["total"],
            })

        db.commit()

        # Auto-verify (same 2000-rupee rule as evaluate_and_route)
        now = datetime.now()
        if total_cost < 2000:
            db.execute(text("""
                UPDATE mrr_matrequisitionheader
                SET VERIFICATION_STATUS='APPROVED', VERIFICATION_DATE=:now,
                    APPROVAL_STATUS='APPROVED', APPROVAL_DATE=:now,
                    ERP_APPROVAL_STATUS='PENDING',
                    COMMENTS=COALESCE(COMMENTS,'')
                WHERE MATREQUISITIONID = :rid
            """), {"now": now, "rid": header_id})
            db.commit()
            confirmation = (
                f"Requisition {mrr_no} (total \u20b9{total_cost:.2f}) submitted "
                f"and auto-approved at manager stage. Awaiting ERP approval."
            )
        else:
            db.execute(text("""
                UPDATE mrr_matrequisitionheader
                SET VERIFICATION_STATUS='APPROVED', VERIFICATION_DATE=:now,
                    APPROVAL_STATUS='PENDING'
                WHERE MATREQUISITIONID = :rid
            """), {"now": now, "rid": header_id})
            db.commit()
            confirmation = (
                f"Requisition {mrr_no} (total \u20b9{total_cost:.2f}) submitted "
                f"and is pending manager approval."
            )

    except Exception as e:
        db.rollback()
        return {
            "messages": [AIMessage(content=f"Could not submit the requisition due to a database error: {e}")],
            "execution_log": execution_log + [f"form_submit DB error: {e}"],
        }
    finally:
        db.close()

    # Reasoning addon (success only)
    confirmation = add_reasoning(
        confirmation,
        context=(
            f"MRR {mrr_no} created via form by {user_id}; total \u20b9{total_cost:.2f}; "
            f"{requisition_type.lower().replace('_', '-')}; "
            f"{len(validated_items)} item(s)."
        )
    )

    return {
        "messages": [AIMessage(content=confirmation)],
        "execution_log": execution_log + [
            f"form_submit: created {mrr_no} total={total_cost} items={len(validated_items)}"
        ],
    }


def creator_path_router(state: MaterialRequisitionState) -> str:
    """
    Routes to the correct sub-path for the creator persona.
    """
    print(f"[DIAG-MRR] creator_path_router entered. persona={state.get('selected_agent_role')}", flush=True)

    msgs = state.get("messages") or []
    last_msg = _get_last_user_message(msgs)

    # form_submit: JSON payload with action='form_submit'
    if _parse_form_submit_message(last_msg) is not None:
        print(f"[DIAG-MRR] creator_path_router -> form_submit_handler", flush=True)
        return "form_submit_handler"

    last_msg_raw = ""
    for m in reversed(msgs):
        if isinstance(m, HumanMessage):
            content = getattr(m, "content", None)
            if content is not None:
                last_msg_raw = str(content).strip().lower()
                break

    # Normalize: replace any whitespace runs and underscores so "confirm mrr",
    # "confirm_mrr", "confirm  mrr" all collapse to "confirm mrr".
    normalized = " ".join(last_msg_raw.replace("_", " ").split())

    pending = state.get("pending_mrr_data")
    print(f"[DIAG-MRR] creator_path_router: last_msg={last_msg_raw!r}, normalized={normalized!r}, has_pending={pending is not None}", flush=True)

    confirm_keywords = {"confirm", "confirm mrr", "confirm submit", "yes", "submit", "ok submit"}
    cancel_keywords = {"cancel", "cancel mrr", "no", "discard"}

    # User confirmed pending submission
    if pending and normalized in confirm_keywords:
        print(f"[DIAG-MRR] creator_path_router -> submit_mrr", flush=True)
        return "submit_mrr"

    # User cancelled
    if pending and normalized in cancel_keywords:
        print(f"[DIAG-MRR] creator_path_router -> cancel_mrr", flush=True)
        return "cancel_mrr"

    # form_submit: detect JSON payload with action='form_submit'
    msgs_raw = state.get("messages") or []
    form_payload = _parse_form_submit_message(_get_last_user_message(msgs_raw))
    if form_payload is not None:
        print(f"[DIAG-MRR] creator_path_router -> form_submit_handler", flush=True)
        return "form_submit_handler"

    # Excel uploaded
    uploaded = state.get("uploaded_files") or []
    if uploaded:
        print(f"[DIAG-MRR] creator_path_router -> excel_handler", flush=True)
        return "excel_handler"

    # No files and no confirm/cancel — ask user to upload Excel
    # (form_flow is currently broken for this case; bypass it)
    print(f"[DIAG-MRR] creator_path_router -> creator_needs_file", flush=True)
    return "creator_needs_file"


def excel_handler_node(state: MaterialRequisitionState) -> dict:
    """Handles MRR Excel upload."""
    print(f"[DIAG-MRR] excel_handler_node entered. emp_no={state.get('emp_no')}", flush=True)

    from app.services.mrr_validator import validate_and_resolve_mrr_excel

    uploaded_files = state.get("uploaded_files") or []
    
    # Safer way to handle potential empty list in diagnostics
    first_file = uploaded_files[0] if uploaded_files else None
    print(f"[DIAG-MRR] excel_handler_node: first file keys={list(first_file.keys()) if first_file else 'none'}, file={first_file}", flush=True)

    if not uploaded_files:
        return {
            "messages": [AIMessage(content=(
                "I didn't see an Excel file in your upload. Please upload the MRR Excel file."
            ))],
            "execution_log": (state.get("execution_log") or []) + [
                "Excel handler: no uploaded_files in state."
            ]
        }

    excel_file = None
    for f in uploaded_files:
        if not f:
            continue
        if f.get("file_type") == "excel" and f.get("data"):
            excel_file = f
            break

    print(f"[DIAG-MRR] excel_handler_node: excel_file found={excel_file is not None}", flush=True)

    if not excel_file:
        return {
            "messages": [AIMessage(content=(
                "The file you uploaded is not a valid Excel file. Please upload a .xlsx file with the MRR data."
            ))],
            "execution_log": (state.get("execution_log") or []) + [
                "Excel handler: no excel file_type found in uploaded_files."
            ]
        }

    from app.models.dto_schemas import CurrentUser
    try:
        current_user = CurrentUser(
            emp_no=state.get("emp_no") or "",
            name=state.get("user_info", {}).get("name", "") if state.get("user_info") else "",
            email=state.get("user_info", {}).get("email", "") if state.get("user_info") else "",
            hierarchy=state.get("user_info", {}).get("hierarchy", {}) if state.get("user_info") else {},
            group_idx=state.get("group_idx") or 0,
            role_ids=state.get("role_ids") or [],
            role_names=state.get("role_names") or [],
            dept=state.get("user_dept") or ""
        )
    except Exception as e:
        import traceback
        traceback.print_exc()
        return {
            "messages": [AIMessage(content=f"Could not build user context: {e}")],
            "execution_log": (state.get("execution_log") or []) + [
                f"Excel handler: CurrentUser construction failed: {e}"
            ]
        }

    print(f"[DIAG-MRR] excel_handler_node: calling validator with {len(excel_file['data'])} rows", flush=True)

    try:
        result = validate_and_resolve_mrr_excel(excel_file["data"], current_user)
    except Exception as e:
        import traceback
        traceback.print_exc()
        return {
            "messages": [AIMessage(content=f"Validator error: {e}")],
            "execution_log": (state.get("execution_log") or []) + [
                f"Excel handler: validator threw: {e}"
            ]
        }

    print(f"[DIAG-MRR] excel_handler_node: validator returned valid={result.get('valid')}", flush=True)

    if not result.get("valid"):
        errors = result.get("errors", [])
        error_text = "Your MRR upload has the following issues:\n\n"
        for i, err in enumerate(errors, 1):
            error_text += f"{i}. {err}\n"
        error_text += "\nPlease fix and re-upload the Excel file."
        return {
            "messages": [AIMessage(content=error_text)],
            "execution_log": (state.get("execution_log") or []) + [
                f"Excel validation failed: {len(errors)} errors."
            ]
        }

    summary = result.get("summary_for_user", "")
    warnings = result.get("warnings", [])
    warning_text = ""
    if warnings:
        warning_text = "\n\n**Warnings:**\n"
        for w in warnings:
            warning_text += f"- {w}\n"

    form_payload = {
        "type": "confirmation",
        "title": "Confirm MRR Submission",
        "fields": [],
        "buttons": [
            {"label": "Confirm Submit", "value": "confirm_mrr"},
            {"label": "Cancel", "value": "cancel_mrr"}
        ]
    }
    import json
    form_str = json.dumps(form_payload)
    full_message = (
        summary + warning_text +
        f"\n\nPlease confirm or cancel below:\n\n"
        f"<<FORM>>{form_str}<<ENDFORM>>"
    )

    return {
        "messages": [AIMessage(content=full_message)],
        "pending_mrr_data": result,
        "execution_log": (state.get("execution_log") or []) + [
            "Excel validated; awaiting user confirmation."
        ]
    }


def mrr_submission_node(state: MaterialRequisitionState) -> dict:
    """
    Performs DB inserts for the validated MRR data stored in
    pending_mrr_data. Then routes to auto_verifier_node.
    """
    print(f"[DIAG-MRR] mrr_submission_node entered. has_pending_data={state.get('pending_mrr_data') is not None}", flush=True)
    pending = state.get("pending_mrr_data")
    if not pending or not pending.get("valid"):
        return {
            "messages": [AIMessage(content=(
                "No MRR data to submit. Please upload an Excel file first."
            ))],
            "execution_log": state.get("execution_log", []) + [
                "Submission node: no pending_mrr_data in state."
            ]
        }

    header = pending["header"]
    lines = pending["lines"]

    db = SessionLocal()
    try:
        from app.services.mariadb_queries import (
            get_max_matrequisition_id, get_max_matrequisition_line_id
        )
        next_header_id = get_max_matrequisition_id() + 1
        next_line_id = get_max_matrequisition_line_id() + 1

        # Insert header
        db.execute(text("""
            INSERT INTO mrr_matrequisitionheader (
                MATREQUISITIONID, MATREQUISITIONNO, WAREHOUSEID,
                REQUISITIONTYPE, REQUESTORID, REQUISITIONDATE,
                DEPARTMENT, NEEDBYDATE, STATUS, PROJECTID,
                PROJECTPHASEID, REQTRANSACTIONTYPE, SUPPLIERID,
                SUPPLIERSITEID, DESCRIPTION, COMMENTS, TOTAL_COST
            ) VALUES (
                :mid, :mno, :wh, :rtype, :req, NOW(),
                :dept, :needby, :status, :proj,
                :phase, :rtt, :sup, :supsite, :desc, :comm, :total
            )
        """), {
            "mid": next_header_id,
            "mno": header["mrr_no"],
            "wh": header["warehouse_id"],
            "rtype": header["requisition_type"],
            "req": header["requestor_id"],
            "dept": header["department"],
            "needby": header["need_by_date"],
            "status": header["status"],
            "proj": header["project_id"],
            "phase": header["project_phase_id"],
            "rtt": header["req_transaction_type"],
            "sup": header["supplier_id"],
            "supsite": header["supplier_site_id"],
            "desc": header.get("description", ""),
            "comm": header.get("comments", ""),
            "total": header["total_cost"]
        })

        # Insert lines
        for i, line in enumerate(lines):
            db.execute(text("""
                INSERT INTO mrr_matrequisitionlines (
                    MATREQUISITIONLINEID, MATREQUISITIONID, ITEMID,
                    ITEMREVISIONID, UOMID, REQUISITIONQTY, ISSUEQTY,
                    RETURNQUANTITY, STATUS, CLOSEREASON, ITEMCOST,
                    RETURN_DATE
                ) VALUES (
                    :lid, :mid, :iid, :rev, :uom, :qty, 0, 0,
                    'ENTERED', '', :cost, :retdate
                )
            """), {
                "lid": next_line_id + i,
                "mid": next_header_id,
                "iid": line["item_id"],
                "rev": line["item_revision_id"],
                "uom": line["uom_id"],
                "qty": line["requisition_qty"],
                "cost": line["item_cost"],
                "retdate": line.get("return_date")
            })

        db.commit()

        # Update state for auto-verifier
        confirmation = add_reasoning(
            f"Your MRR **{header['mrr_no']}** has been submitted.\n"
            f"Total cost: \u20b9{header['total_cost']:,.2f}\n\n"
            f"Running verification...",
            context=f"MRR {header['mrr_no']} submitted by {header['requestor_id']}; "
                    f"total cost \u20b9{header['total_cost']:,.2f}; awaiting auto-verification."
        )

        return {
            "messages": [AIMessage(content=confirmation)],
            "new_requisition_id": next_header_id,
            "pending_mrr_data": None,  # clear
            "execution_log": state.get("execution_log", []) + [
                f"MRR {header['mrr_no']} inserted with id={next_header_id}, "
                f"{len(lines)} line items."
            ]
        }

    except Exception as e:
        db.rollback()
        import traceback
        traceback.print_exc()
        return {
            "messages": [AIMessage(content=(
                f"Submission failed: {str(e)}. "
                "Please try again or contact support."
            ))],
            "execution_log": state.get("execution_log", []) + [
                f"Submission node: insert failed: {e}"
            ]
        }
    finally:
        db.close()


