### 14. Code of auto_verifier_node (full)

```python
def auto_verifier_node(state: MaterialRequisitionState) -> dict:
    requisition_id = state.get("new_requisition_id")
    if not requisition_id:
        return {"messages": [AIMessage(content="No requisition to verify.")],
                "execution_log": state.get("execution_log", []) + ["Verifier: no requisition_id in state."]}
    db = SessionLocal()
    try:
        total_cost_row = db.execute(text("""
            SELECT COALESCE(SUM(ITEMCOST), 0) AS total FROM mrr_matrequisitionlines WHERE MATREQUISITIONID = :rid
        """), {"rid": requisition_id}).first()
        total_cost = float(total_cost_row.total or 0)
        now = datetime.now()

        if total_cost < 2000:
            db.execute(text("""
                UPDATE mrr_matrequisitionheader SET VERIFICATION_STATUS='APPROVED', VERIFICATION_DATE=:now,
                      APPROVAL_STATUS='APPROVED', APPROVAL_DATE=:now,
                      COMMENTS='Auto-approved by verifier (total < 2000).'
                WHERE MATREQUISITIONID = :rid
            """), {"now": now, "rid": requisition_id})
            db.commit()
            confirmation = f"Your requisition (total cost: ₹{total_cost:.2f}) was auto-approved and is now awaiting ERP approval."
        else:
            db.execute(text("""
                UPDATE mrr_matrequisitionheader SET VERIFICATION_STATUS='APPROVED', VERIFICATION_DATE=:now,
                      APPROVAL_STATUS='PENDING' WHERE MATREQUISITIONID = :rid
            """), {"now": now, "rid": requisition_id})
            db.commit()
            confirmation = f"Your requisition (total cost: ₹{total_cost:.2f}) has been submitted for manager approval."

        return {"messages": [AIMessage(content=confirmation)],
                "execution_log": state.get("execution_log", []) + [
                    f"Auto-verifier: total={total_cost}, {'auto-approved' if total_cost < 2000 else 'pending manager'}."
                ]}
    finally:
        db.close()
```

