```python
"""
MRR Intent Classification
=========================
LLM-driven classifier with keyword-fallback for MRR workflow routing.

Uses PydanticOutputParser for structured output.
Returns MRRIntentClassification with: domain, collection, persona, confidence, reasoning.
"""

from pydantic import BaseModel, Field
from typing import Literal
from langchain_core.output_parsers import PydanticOutputParser
from langchain_core.prompts import PromptTemplate

from app.core.llm import get_llm_non_streaming

MODULE_DOMAIN_DESCRIPTION = """The MRR (Material Requisition Request) module handles material/stock requisitions in the SCM domain.
Available collections:
  - mrr_general: create material requisitions, view pending approvals, approve at manager stage, approve at ERP stage, issue stock (nominal).
Available personas:
  - CREATOR: creates new material requisitions, requests items by quantity.
  - APPROVER: CTO/COO who approve manager-stage requisitions.
  - ERP_APPROVER: ERP HOD who approves at ERP stage.
  - ISSUER: store issuer who handles stock issuance (nominal, not functionally implemented)."""

CREATOR_KEYWORDS = ['create request', 'new requisition', 'material requisition', 'request items', 'add items', 'create mrr', 'order parts']
APPROVER_KEYWORDS = ['approve', 'reject', 'pending approvals', 'review request', 'mrr queue', 'authorize requisition', 'sign off', 'manager approval', 'manager approve']
ERP_APPROVER_KEYWORDS = ['erp approval', 'erp approve', 'erp reject', 'erp mrr', 'erp stage']
ISSUER_KEYWORDS = ['issue stock', 'release material', 'warehouse issue', 'handover items', 'stock issuance', 'mrr release']

class MRRIntentClassification(BaseModel):
    domain: Literal["IN_DOMAIN", "OUT_OF_DOMAIN"] = Field(description='Whether the user message falls within MRR scope.')
    collection: str = Field(description='Which MRR collection: "mrr_general" or empty if out of domain.')
    persona: str = Field(description='Which persona: "CREATOR", "APPROVER", "ERP_APPROVER", "ISSUER", or empty if out of domain.')
    confidence: Literal["HIGH", "MEDIUM", "LOW"] = Field(description='Confidence level in the classification.')
    reasoning: str = Field(description='One-sentence explanation of the classification.')

_parser = PydanticOutputParser(pydantic_object=MRRIntentClassification)
_prompt_template = PromptTemplate(
    template="{module_description}\n\nClassify the following user message into a structured response.\n\n{format_instructions}\n\nUser message: {user_message}\n",
    input_variables=["user_message"],
    partial_variables={"module_description": MODULE_DOMAIN_DESCRIPTION, "format_instructions": _parser.get_format_instructions()},
)

def classify_mrr_intent(user_message: str) -> MRRIntentClassification:
    llm = get_llm_non_streaming()
    try:
        prompt_value = _prompt_template.invoke({"user_message": user_message})
        llm_response = llm.invoke(prompt_value)
        raw_text = getattr(llm_response, "content", "") or ""
        return _parser.parse(raw_text)
    except Exception as e:
        import traceback; traceback.print_exc()
        return keyword_fallback(user_message)

def keyword_fallback(user_message: str) -> MRRIntentClassification:
    msg_lower = user_message.lower()
    for kw in ERP_APPROVER_KEYWORDS:
        if kw in msg_lower:
            return MRRIntentClassification(domain="IN_DOMAIN", collection="mrr_general", persona="ERP_APPROVER", confidence="LOW", reasoning="Keyword fallback used; LLM classifier unavailable.")
    for kw in APPROVER_KEYWORDS:
        if kw in msg_lower:
            return MRRIntentClassification(domain="IN_DOMAIN", collection="mrr_general", persona="APPROVER", confidence="LOW", reasoning="Keyword fallback used; LLM classifier unavailable.")
    for kw in ISSUER_KEYWORDS:
        if kw in msg_lower:
            return MRRIntentClassification(domain="IN_DOMAIN", collection="mrr_general", persona="ISSUER", confidence="LOW", reasoning="Keyword fallback used; LLM classifier unavailable.")
    for kw in CREATOR_KEYWORDS:
        if kw in msg_lower:
            return MRRIntentClassification(domain="IN_DOMAIN", collection="mrr_general", persona="CREATOR", confidence="LOW", reasoning="Keyword fallback used; LLM classifier unavailable.")
    return MRRIntentClassification(domain="IN_DOMAIN", collection="mrr_general", persona="CREATOR", confidence="LOW", reasoning="Keyword fallback used; LLM classifier unavailable.")
```

