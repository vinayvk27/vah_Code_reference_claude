  def tool_show_log_hours_form(user_context: dict, prefill: dict = None) -> str:
      """
      Emit a log hours form spec for the chat to render.
      Reviewer (Filler) persona only.
      """
      from app.forms.emit import build_form_emit
      from app.services import timesheet_store
      
      persona = (user_context or {}).get("persona")
      if persona != "reviewer":
          raise PermissionError("tool_show_log_hours_form requires reviewer persona")
      
      resource_id = int(user_context["user_id"])
      prefill = prefill or {}
      
      # Fetch user's assigned tasks for the dropdown
      db = SessionLocal()
      try:
          tasks = timesheet_store.list_tasks_for_resource(db, resource_id)
      except Exception:
          tasks = []
      finally:
          db.close()
      
      task_options = []
      for t in tasks:
          task_options.append({
              "value": t["task_id"],
              "label": f"Task #{t['task_id']} (Project {t.get('project_id', '?')}, {t.get('plan_hours', '?')}h planned)"
          })
      if not task_options:
          task_options = [{"value": 0, "label": "(no tasks assigned to you)"}]
      
      form_spec = {
          "version": 1,
          "form_id": "rms_log_hours",
          "title": "Log Work Hours",
          "description": "Record time spent on an assigned task.",
          "submit_label": "Log Hours",
          "cancel_label": "Cancel",
          "fields": [
              {
                  "name": "worklog_idx",
                  "label": "Task",
                  "type": "select",
                  "required": True,
                  "options": task_options,
                  "default": prefill.get("worklog_idx") or task_options[0]["value"],
              },
              {
                  "name": "task_date",
                  "label": "Work Date",
                  "type": "date",
                  "required": True,
                  "default": prefill.get("task_date") or "",
              },
              {
                  "name": "hours",
                  "label": "Hours Worked",
                  "type": "number",
                  "required": True,
                  "min": 0.25,
                  "max": 24,
                  "default": prefill.get("hours") or "",
                  "placeholder": "e.g., 4 or 4.5",
              },
              {
                  "name": "remarks",
                  "label": "Remarks",
                  "type": "textarea",
                  "required": True,
                  "max_length": 500,
                  "placeholder": "Brief description of work done",
                  "default": prefill.get("remarks") or "",
              },
          ],
      }
      
      return build_form_emit(form_spec)

