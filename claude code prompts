"""
Oracle ERP Query Helpers
=========================
Parameterized queries against the Oracle ERP database.
Each function gracefully degrades (returns None) on errors.
"""

import logging
from typing import Optional

from sqlalchemy import text

from app.dao.oracle import get_oracle_session

logger = logging.getLogger(__name__)


def get_item_availability(item_id: int) -> Optional[dict]:
    session = None
    try:
        session = get_oracle_session()
        row = session.execute(text("""
            SELECT i.ITEMID as item_id, i.NAME as name, q.ONHANDQUANTITY as onhand_quantity
            FROM SCMQUANTITYONHAND q JOIN scmitems i ON i.ITEMID = q.ITEMID
            WHERE q.ITEMID = :item_id FETCH FIRST 1 ROWS ONLY
        """), {"item_id": item_id}).first()
        if row:
            return {"item_id": row.item_id, "name": row.name, "onhand_quantity": row.onhand_quantity}
        return None
    except Exception as e:
        logger.warning("get_item_availability failed: %s", e)
        return None
    finally:
        if session:
            session.close()


def get_item_lpp(item_id: int, warehouse_id: int = 1) -> Optional[dict]:
    session = None
    try:
        session = get_oracle_session()
        row = session.execute(text("""
            SELECT i.ITEMID as item_id, i.NAME as name,
                   COALESCE(i.LPP_VALUE_UNITPRICE_INR, i.ITEMUNITPRICE, 0) as lpp_rate
            FROM scmitems i WHERE i.ITEMID = :item_id FETCH FIRST 1 ROWS ONLY
        """), {"item_id": item_id}).first()
        if row:
            return {"item_id": row.item_id, "name": row.name, "lpp_rate": float(row.lpp_rate or 0)}
        return None
    except Exception as e:
        logger.warning("get_item_lpp failed: %s", e)
        return None
    finally:
        if session:
            session.close()


def get_department_id(department_name: str) -> Optional[int]:
    session = None
    try:
        session = get_oracle_session()
        row = session.execute(text("""
            SELECT DEPARTMENTID FROM scmdepartments WHERE NAME = :name FETCH FIRST 1 ROWS ONLY
        """), {"name": department_name}).first()
        return row.DEPARTMENTID if row else None
    except Exception as e:
        logger.warning("get_department_id failed: %s", e)
        return None
    finally:
        if session:
            session.close()
