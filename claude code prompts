# app/controllers/auth_controller.py
"""
Authentication controller for DPAH.

AUTH_MODE controls authentication mode:
  'prod' (default) — use LDAP authentication (current production behavior)
  'dev'            — bypass LDAP, look up emp_no + dept in resources table

Set via environment variable: AUTH_MODE=dev
CRITICAL: Before production deployment, verify AUTH_MODE is unset OR explicitly 'prod'.
"""
from ldap3 import Server, Connection, SUBTREE
from sqlalchemy.orm import Session
from sqlalchemy import func
from sqlalchemy import or_
from typing import Optional, List
from app.core.config import settings
from app.models.db_schema import (
    Resource, UserRole, Role, Agent,
    Module, Collection, ModuleUserGroup, RoleAgentAccess,
)


class AuthController:

    @staticmethod
    def authenticate_ldap(uid: str, password: str) -> dict | bool:
        """Authenticate via LDAP. Unchanged from previous implementation."""
        print(f"\n--- [LOG] STARTING AUTH FOR: {uid} ---")

        try:
            server = Server(settings.LDAP_HOST, port=settings.LDAP_PORT)
            print(f"1. Server object created for {settings.LDAP_HOST}:{settings.LDAP_PORT}")

            search_conn = Connection(server, user='', password='', auto_bind=True)
            print("2. Anonymous connection successful.")

            search_filter = f"(uid={uid})"
            print(f"3. Searching in '{settings.LDAP_SEARCH_DN}' with filter '{search_filter}'...")

            search_conn.search(
                search_base=settings.LDAP_SEARCH_DN,
                search_filter=search_filter,
                search_scope=SUBTREE,
                attributes=['*']
            )

            if not search_conn.entries:
                print(f"4. SEARCH FAILED: No entries found for {uid}.")
                search_conn.unbind()
                return False

            user_entry = search_conn.entries[0]
            user_dn = user_entry.entry_dn
            print(f"4. SEARCH SUCCESS! Found User DN: {user_dn}")

            print("5. Attempting final password bind...")
            auth_conn = Connection(server, user=user_dn, password=password)

            if auth_conn.bind():
                print("6. AUTHENTICATION SUCCESSFUL!")
                raw_attrs = user_entry.entry_attributes_as_dict

                user_info = {
                    "uid": uid,
                    "dn": user_dn,
                    "mail": raw_attrs.get('mail', [None])[0],
                    "department": raw_attrs.get('department', [None])[0],
                    "employeeID": raw_attrs.get('employeeID', [uid])[0],
                }

                auth_conn.unbind()
                search_conn.unbind()
                return user_info
            else:
                print("6. BIND FAILED: Incorrect Password or Account Locked.")
                search_conn.unbind()
                return False

        except Exception as e:
            print(f"CRITICAL LDAP EXCEPTION: {e}")
            return False

    @staticmethod
    def generate_user_context(db: Session, uid: str, password: str) -> dict:
        """Master function: validates LDAP, then delegates to build_user_context_by_empno."""
        auth_result = AuthController.authenticate_ldap(uid, password)
        if not auth_result:
            return {"success": False, "error": "Invalid LDAP credentials"}

        ldap_emp_id = auth_result.get("employeeID")
        ldap_mail = auth_result.get("mail")

        db_user = db.query(Resource).filter(
            or_(
                Resource.Emp_no == ldap_emp_id,
                Resource.Emp_no == uid,
                Resource.Email == ldap_mail,
                Resource.Email == f"{uid}@datapatterns.co.in",
            ),
            Resource.IsActive == 1,
        ).first()

        if not db_user:
            return {"success": False, "error": "LDAP Login successful, but profile not found in DPAH Database."}

        return AuthController.build_user_context_by_empno(db, db_user.Emp_no)

    @staticmethod
    def build_user_context_by_empno(db: Session, emp_no: str) -> dict:
        """
        Build user context from emp_no using the new RBAC schema.
        Implements strict intersection: a module appears in access_tree
        only if BOTH (user's group has it) AND (user has agents in it).
        """
        db_user = db.query(Resource).filter(
            Resource.Emp_no == emp_no,
            Resource.IsActive == 1,
        ).first()

        if not db_user:
            return {"success": False, "error": "User not found in DPAH Database."}

        print(f"User context built for: {emp_no} ({db_user.Name})")

        # 1. Fetch active roles
        user_role_records = db.query(UserRole).filter(
            UserRole.emp_id == emp_no,
            UserRole.is_active == 1,
        ).all()

        role_ids = [ur.role_id for ur in user_role_records]

        role_names_list = []
        if role_ids:
            role_records = db.query(Role).filter(Role.role_id.in_(role_ids)).all()
            role_names_list = [r.role_name for r in role_records]

        # 2. STEP A — modules visible to user's group (from dpah_module_usergroups)
        group_idx = getattr(db_user, 'GroupIDx', None)
        if group_idx is None:
            group_idx = 0

        group_modules = db.query(ModuleUserGroup).filter(
            ModuleUserGroup.group_idx == group_idx,
            ModuleUserGroup.is_active == 1,
        ).all()

        visible_module_ids = {mug.module_id for mug in group_modules}

        # 3. STEP B — agents accessible via role_agent_access
        if role_ids:
            accessible_agent_rows = db.query(RoleAgentAccess).filter(
                RoleAgentAccess.group_id == group_idx,
                RoleAgentAccess.role_id.in_(role_ids),
            ).all()
        else:
            accessible_agent_rows = []

        # 4. STEP C — enrich agents with collection + module info
        agent_ids = {ra.agent_id for ra in accessible_agent_rows}
        agents_dict = {}
        if agent_ids:
            agents = db.query(Agent).filter(Agent.agent_id.in_(agent_ids)).all()
            for a in agents:
                agents_dict[a.agent_id] = a

        # Build module -> collection -> agents map from accessible agents
        module_collections_agents: dict = {}
        for ra in accessible_agent_rows:
            agent = agents_dict.get(ra.agent_id)
            if agent is None:
                continue

            collection = db.query(Collection).filter(
                Collection.collection_id == agent.collection_id
            ).first()
            if collection is None:
                continue

            module = db.query(Module).filter(
                Module.module_id == collection.module_id
            ).first()
            if module is None:
                continue

            # Parse persona from agent_name: split on "_", take last segment, uppercase
            parts = agent.agent_name.rsplit("_", 1)
            persona = parts[-1].upper() if len(parts) >= 2 else "UNKNOWN"

            mid = module.module_id
            if mid not in module_collections_agents:
                module_collections_agents[mid] = {
                    "module_id": mid,
                    "module_name": module.module_name,
                    "description": module.module_description,
                    "collections": {},
                }

            cid = collection.collection_id
            if cid not in module_collections_agents[mid]["collections"]:
                module_collections_agents[mid]["collections"][cid] = {
                    "collection_id": cid,
                    "collection_name": collection.collection_name,
                    "agents": [],
                }

            module_collections_agents[mid]["collections"][cid]["agents"].append({
                "agent_id": agent.agent_id,
                "agent_name": agent.agent_name,
                "persona": persona,
            })

        # 5. STEP E — strict intersection: only modules in BOTH visible_module_ids AND agent map
        intersection_module_ids = visible_module_ids & set(module_collections_agents.keys())

        modules_list = []
        for mid in sorted(intersection_module_ids):
            md = module_collections_agents[mid]
            collections_list = []
            for cid in sorted(md["collections"]):
                coll_data = md["collections"][cid]
                # Sort agents by persona then name
                agents = sorted(coll_data["agents"], key=lambda a: (a["persona"], a["agent_name"]))
                collections_list.append({
                    "collection_id": cid,
                    "collection_name": coll_data["collection_name"],
                    "agents": agents,
                })
            modules_list.append({
                "module_id": md["module_id"],
                "module_name": md["module_name"],
                "description": md["description"],
                "collections": collections_list,
            })

        user_profile = {
            "user_profile": {
                "emp_no": emp_no,
                "name": db_user.Name,
                "email": db_user.Email,
                "dept": db_user.Department,
                "group_idx": group_idx,
                "roles": [{"role_id": rid, "role_name": rname}
                          for rid, rname in zip(role_ids, role_names_list)],
                "hierarchy": {
                    "grade": db_user.Grade,
                    "grade_id": db_user.GradeID,
                    "reporting_to": db_user.ReportingToID,
                    "l1": db_user.level01,
                    "l2": db_user.level02,
                    "l3": db_user.level03,
                    "tslevel": db_user.tslevel,
                },
            },
            "access_tree": {
                "modules": modules_list,
            },
        }

        # DEBUG
        print(f"\n=== DEBUG: Resolved context for emp_no {emp_no} ===")
        print(f"  group_idx = {group_idx}")
        print(f"  role_ids = {role_ids}")
        print(f"  visible_module_ids = {visible_module_ids}")
        print(f"  intersection_module_ids = {intersection_module_ids}")
        print(f"  modules in access_tree = {len(modules_list)}")
        for mod in modules_list:
            print(f"    - {mod['module_name']}: {len(mod['collections'])} collections")
            for col in mod["collections"]:
                print(f"        - {col['collection_name']}: {len(col['agents'])} agents")
        print(f"=== END DEBUG ===")

        return {"success": True, "user_profile": user_profile, "access_tree": user_profile["access_tree"]}

    @staticmethod
    def authenticate_dev_mode(emp_no: str, dept: str, db: Session) -> dict:
        """
        Dev-mode authentication: looks up emp_no + dept in the resources table.
        No password check. Returns the new user context shape.
        """
        emp_no_clean = (emp_no or "").strip()
        dept_clean = (dept or "").strip().upper()

        if not emp_no_clean or not dept_clean:
            raise ValueError("emp_no and dept are both required for dev login")

        resource = db.query(Resource).filter(Resource.Emp_no == emp_no_clean).first()
        if not resource:
            raise ValueError(f"No employee found with emp_no={emp_no_clean}")

        resource_dept = (resource.Department or "").strip().upper()
        if resource_dept != dept_clean:
            raise ValueError(f"Dept mismatch — resource {emp_no_clean} is in {resource_dept}, not {dept_clean}")

        return AuthController.build_user_context_by_empno(db, emp_no_clean)

    @staticmethod
    def check_module_access(
        emp_no: str,
        group_idx: int,
        role_ids: List[int],
        module_id: int,
        db: Session,
    ) -> bool:
        """
        Gate 1: Does the user have access to any agent in this module?

        Caches the result in process-local permission cache (5-min TTL).
        """
        from app.core.permission_cache import cache_get, cache_set

        if not role_ids:
            return False

        cache_key = f"module_access:{emp_no}:{module_id}"
        cached = cache_get(cache_key)
        if cached is not None:
            return bool(cached)

        result = bool(
            db.query(RoleAgentAccess).join(
                Agent, Agent.agent_id == RoleAgentAccess.agent_id
            ).join(
                Collection, Collection.collection_id == Agent.collection_id
            ).filter(
                RoleAgentAccess.group_id == group_idx,
                RoleAgentAccess.role_id.in_(role_ids),
                Collection.module_id == module_id,
            ).count()
            > 0
        )
        cache_set(cache_key, result, ttl_seconds=300)
        return result

    @staticmethod
    def check_agent_access(
        emp_no: str, group_idx: int, role_ids: List[int], agent_id: int, db: Session
    ) -> Optional[Agent]:
        """
        Check if a user has access to a specific agent.
        Single JOIN query: dpah_agents JOIN dpah_role_agent_access.
        Returns Agent ORM object or None.

        Caching strategy: cache the Agent's primary fields as a plain dict.
        On cache hit, reconstruct a minimal Agent-like object (just the fields
        the downstream code uses: agent_id, agent_name, persona). This keeps
        the return type stable (Agent or None) without touching the DB.
        """
        from app.core.permission_cache import cache_get, cache_set

        if not role_ids:
            return None

        cache_key = f"agent_access:{emp_no}:{agent_id}"
        cached = cache_get(cache_key)
        if cached is not None:
            # Cache hit — reconstruct an Agent-like object from cached dict
            if cached is None:
                return None
            agent_dict = cached
            # Build a minimal object with the fields downstream code expects
            class _AgentProxy:
                """Minimal agent shape matching what downstream code needs."""

                def __init__(self, d):
                    self.agent_id = d["agent_id"]
                    self.agent_name = d["agent_name"]
            return _AgentProxy(agent_dict)

        result = db.query(Agent).join(
            RoleAgentAccess, Agent.agent_id == RoleAgentAccess.agent_id
        ).filter(
            Agent.agent_id == agent_id,
            RoleAgentAccess.group_id == group_idx,
            RoleAgentAccess.role_id.in_(role_ids),
        ).first()

        if result is not None:
            # Cache a plain dict of the fields we need (no ORM object)
            cache_set(cache_key, {"agent_id": result.agent_id, "agent_name": result.agent_name}, ttl_seconds=300)
        else:
            cache_set(cache_key, None, ttl_seconds=300)

        return result

    @staticmethod
    def get_module_id_by_name(module_name: str, db: Session) -> Optional[int]:
        """
        Look up a module's ID by name (case-insensitive).
        Returns the module_id or None if not found.
        """
        row = db.query(Module.module_id).filter(
            func.lower(Module.module_name) == module_name.lower()
        ).first()
        return row[0] if row else None

    @staticmethod
    def get_access_tree_for_empno(db: Session, emp_no: str) -> dict:
        """
        Build a fresh access_tree from DB for a given emp_no.
        Used by the /me/access endpoint and the debug endpoint.
        Calls build_user_context_by_empno and extracts access_tree.
        """
        result = AuthController.build_user_context_by_empno(db, emp_no)
        if result.get("success"):
            return result["access_tree"]
        return {"modules": []}

