  def _handle_log_hours_form(form_data: dict, user_context: dict) -> str:
      """
      Submission handler for rms_log_hours form.
      """
      from app.forms.spec import validate_form_data
      
      form_spec_for_validation = {
          "fields": [
              {"name": "worklog_idx", "type": "number", "required": True},
              {"name": "task_date", "type": "date", "required": True},
              {"name": "hours", "type": "number", "required": True, "min": 0.25, "max": 24},
              {"name": "remarks", "type": "text", "required": True, "max_length": 500},
          ]
      }
      err = validate_form_data(form_spec_for_validation, form_data)
      if err:
          return f"Form validation failed: {err}"
      
      try:
          worklog_idx = int(form_data["worklog_idx"])
          task_date = form_data["task_date"]
          hours = float(form_data["hours"])
          remarks = form_data["remarks"]
      except (KeyError, ValueError, TypeError) as e:
          return f"Invalid form data: {e}"
      
      reviewer_context = dict(user_context)
      reviewer_context["persona"] = "reviewer"
      
      return tool_log_hours(worklog_idx, hours, task_date, remarks, reviewer_context)

