def _handle_rms_form_submit(state, payload, current_emp_no,
                             execution_log):
    """
    Procedural handler for RMS task form_submit.
    Validates fields, inserts via timesheet_store.create_task.
    Mirrors MRR's form_submit_handler_node but uses
    timesheet_store instead of direct SQL.
    """
    import json as _json
    from datetime import datetime

    data = payload.get("data") or {}
    errors = {}

    # --- Validate header fields ---
    employee_id_raw = str(data.get("employee_id") or "").strip()
    if not employee_id_raw:
        errors["employee_id"] = "Employee ID is required"
    else:
        try:
            resource_id = int(employee_id_raw)
        except Exception:
            errors["employee_id"] = f"Employee ID must be a number"
            resource_id = None

    project_id = str(data.get("project_id") or "").strip()
    if not project_id:
        errors["project_id"] = "Project ID is required"

    product_id = str(data.get("product_id") or "").strip()
    if not product_id:
        errors["product_id"] = "Product ID is required"

    task_index_raw = data.get("task_index")
    if task_index_raw is None or str(task_index_raw).strip() == "":
        errors["task_index"] = "Task Index is required"
        task_idx = None
    else:
        try:
            task_idx = int(float(task_index_raw))
            if task_idx < 1:
                errors["task_index"] = "Task Index must be >= 1"
                task_idx = None
        except Exception:
            errors["task_index"] = "Task Index must be a number"
            task_idx = None

    activity_index_raw = data.get("activity_index")
    if activity_index_raw is None or str(activity_index_raw).strip() == "":
        errors["activity_index"] = "Activity Index is required"
        activity_idx = None
    else:
        try:
            activity_idx = int(float(activity_index_raw))
            if activity_idx < 1:
                errors["activity_index"] = "Activity Index must be >= 1"
                activity_idx = None
        except Exception:
            errors["activity_index"] = "Activity Index must be a number"
            activity_idx = None

    start_date = str(data.get("start_date") or "").strip()
    end_date = str(data.get("end_date") or "").strip()

    if not start_date:
        errors["start_date"] = "Start Date is required"
    else:
        try:
            datetime.strptime(start_date, "%Y-%m-%d")
        except Exception:
            errors["start_date"] = "Invalid date (use YYYY-MM-DD)"

    if not end_date:
        errors["end_date"] = "End Date is required"
    else:
        try:
            ed = datetime.strptime(end_date, "%Y-%m-%d")
            if start_date and not errors.get("start_date"):
                sd = datetime.strptime(start_date, "%Y-%m-%d")
                if ed < sd:
                    errors["end_date"] = "End Date must be on or after Start Date"
        except Exception:
            errors["end_date"] = "Invalid date (use YYYY-MM-DD)"

    planned_hours_raw = data.get("planned_hours")
    if planned_hours_raw is None or str(planned_hours_raw).strip() == "":
        errors["planned_hours"] = "Planned Hours is required"
        plan_hrs = None
    else:
        try:
            plan_hrs = float(planned_hours_raw)
            if plan_hrs <= 0:
                errors["planned_hours"] = "Planned Hours must be positive"
                plan_hrs = None
        except Exception:
            errors["planned_hours"] = "Planned Hours must be a number"
            plan_hrs = None

    # --- Return field errors if any ---
    if errors:
        import json as _json
        marker = "[[FORM_ERRORS:" + _json.dumps({
            "form_id": "rms_create_task_form",
            "errors": errors
        }) + "]]"
        full_text = (
            "I couldn't submit the form. Please fix the "
            "highlighted fields and try again.\n\n" + marker
        )
        execution_log.append(
            f"RMS form_submit validation: {len(errors)} errors"
        )
        return {
            "messages": [AIMessage(content=full_text)],
            "execution_log": execution_log,
        }

    # --- DB Insert via timesheet_store ---
    try:
        db = SessionLocal()
        try:
            result = timesheet_store.create_task(
                db=db,
                resource_id=resource_id,
                project_id=project_id,
                product_id=product_id,
                task_idx=task_idx,
                activity_idx=activity_idx,
                start_date=start_date,
                end_date=end_date,
                plan_hrs=plan_hrs,
                created_by=current_emp_no,
            )
            task_id = result.get("task_id")
            full_text = (
                f"Task created successfully (Task ID: {task_id}) "
                f"for employee {resource_id}, project {project_id}, "
                f"from {start_date} to {end_date}, "
                f"{plan_hrs} planned hours."
            )
            execution_log.append(f"RMS form_submit: task created id={task_id}")
        except Exception as e:
            db.rollback()
            full_text = (
                f"Could not create the task due to a database error: {e}"
            )
            execution_log.append(f"RMS form_submit DB error: {e}")
        finally:
            db.close()
    except Exception as e:
        full_text = f"Database error: {e}"
        execution_log.append(f"RMS form_submit session error: {e}")

    # Reasoning addon on success only
    if "Task created successfully" in full_text:
        from app.workflows.shared.reasoning_addon import add_reasoning
        full_text = add_reasoning(
            full_text,
            context=(
                f"RMS task created via form for employee {resource_id}, "
                f"project {project_id}, {plan_hrs} hours, "
                f"{start_date} to {end_date}."
            )
        )

    return {
        "messages": [AIMessage(content=full_text)],
        "execution_log": execution_log,
    }

