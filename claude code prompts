USE dpintranet;

CREATE TABLE IF NOT EXISTS hr_leave_types_demo (
    LeaveTypeIdx INT AUTO_INCREMENT PRIMARY KEY,
    Name VARCHAR(50) NOT NULL,
    MaxDays INT NOT NULL,
    CreatedBy VARCHAR(10),
    CreatedDate DATE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE IF NOT EXISTS hr_leave_requests_demo (
    RequestIdx INT AUTO_INCREMENT PRIMARY KEY,
    Resource INT NOT NULL,
    LeaveTypeIdx INT NOT NULL,
    FromDate DATE NOT NULL,
    ToDate DATE NOT NULL,
    NumDays INT NOT NULL,
    Reason VARCHAR(500),
    IsApproved INT DEFAULT NULL,
    ApprovedBy INT DEFAULT NULL,
    ApprovedDate DATE DEFAULT NULL,
    ApproverRemarks VARCHAR(500),
    CreatedDate DATE,
    INDEX idx_resource (Resource),
    INDEX idx_isapproved (IsApproved)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE IF NOT EXISTS hr_payslips_demo (
    PayslipIdx INT AUTO_INCREMENT PRIMARY KEY,
    Resource INT NOT NULL,
    PayMonth VARCHAR(7) NOT NULL,
    Basic FLOAT,
    Allowances FLOAT,
    Deductions FLOAT,
    NetPay FLOAT,
    CreatedBy VARCHAR(10),
    CreatedDate DATE,
    INDEX idx_resource (Resource),
    INDEX idx_paymonth (PayMonth)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
