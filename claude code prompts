def _parse_approval_command(message: str) -> dict:
    """
    Parses an approval command from the user's message.
    Returns dict with:
      'action': 'approve_one' | 'approve_all' | 'reject_one' | 'list'
      'mrr_id': int | None
    """
    msg = (message or "").lower().strip()

    if re.search(r'\bapprove\s+all\b', msg):
        return {"action": "approve_all", "mrr_id": None}

    match = re.search(
        r'\b(approve|reject)\s+(?:requisition\s+)?(?:mrr/)?(\d+)(?:/[\d\-]+)?\b',
        msg
    )
    if match:
        verb = match.group(1)
        mrr_id = int(match.group(2))
        action = "approve_one" if verb == "approve" else "reject_one"
        return {"action": action, "mrr_id": mrr_id}

    return {"action": "list", "mrr_id": None}


def _get_last_user_message(messages) -> str:
    """Extract the last HumanMessage content from the messages list."""
    for msg in reversed(messages):
        if isinstance(msg, HumanMessage):
            return str(msg.content)
    return ""


def _describe_assumed_action_mrr(persona: str, collection: str) -> str:
    """Describe the assumed action for soft-correction messages."""
    persona = (persona or "").lower()
    collection = (collection or "").lower()
    if persona == "creator":
        return "create a material requisition"
    elif persona == "approver":
        return "approve a pending requisition"
    elif persona == "erp_approver":
        return "approve at the ERP stage"
    elif persona == "issuer":
        return "issue stock for a requisition"
    return "do that"


